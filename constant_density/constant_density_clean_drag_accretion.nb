76ba6a824d22"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fMachLow", "[", "m_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"Log", "[", 
      FractionBox[
       RowBox[{"1", "+", " ", "m"}], 
       RowBox[{"1", " ", "-", " ", "m"}]], "]"}]}], " ", "-", " ", "m"}]}], 
  " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fMachhigh", "[", "m_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"Log", "[", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox["1", 
       SuperscriptBox["m", "2"]]}], "]"}]}], "  ", "+", " ", 
   "10"}]}]}], "Input",
 CellChangeTimes->{{3.982656752103551*^9, 3.9826567847752333`*^9}, {
