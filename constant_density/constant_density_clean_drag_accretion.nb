Cell[CellGroupData[{

Cell["\<\
Converting back to the areal radius to see the 2D graph and if it is different\
\>", "Section",
 CellChangeTimes->{{3.979742050307272*^9, 3.979742076927948*^9}, {
  3.979743799063179*^9, 3.9797438051640453`*^9}, {3.982816070306059*^9, 
  3.982816084208893*^9}},ExpressionUUID->"71e1bab6-036d-4299-9faf-\
009da95e5275"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Areal", " ", "radius", " ", "as", " ", "a", " ", "function", " ", "of", " ",
     "isotropic", " ", "radius"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"rFromRbar", "[", "rbar_", "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"A", "[", "rbar", "]"}], "*", "rbar"}], ",", 
          RowBox[{"rbar", ">=", "rbarStar"}]}], "}"}], ",", 
        RowBox[{"(*", "exterior", "*)"}], 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"AInside", "[", "rbar", "]"}], "*", "rbar"}], ",", 
          RowBox[{"rbar", "<", "rbarStar"}]}], "}"}]}], "    ", 
       RowBox[{"(*", "interior", "*)"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Areal", " ", "radius", " ", "along", " ", "the", " ", "orbit"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"arealr", "[", "t_", "]"}], ":=", 
     RowBox[{"rFromRbar", "[", 
      RowBox[{"rbarNumIn", "[", "t", "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.979742229262013*^9, 3.979742295009645*^9}, {
  3.979742342432342*^9, 3.979742365872905*^9}, {3.97974240807908*^9, 
  3.9797424084926853`*^9}, {3.979742475262102*^9, 3.979742504402256*^9}, {
  3.9797427606342077`*^9, 3.9797427648932753`*^9}, {3.979743386095112*^9, 
  3.9797433864274178`*^9}, {3.979743472807996*^9, 3.979743475754581*^9}},
 CellLabel->
  "In[173]:=",ExpressionUUID->"e73543dc-f651-443b-a602-c39dcdc90649"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"x", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"arealr", "[", "t", "]"}], " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"phiNumIn", "[", "t", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"y", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"arealr", "[", "t", "]"}], " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"phiNumIn", "[", "t", "]"}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.979742774293977*^9, 3.979742775136449*^9}, {
  3.979743389786322*^9, 3.979743391409541*^9}},
 CellLabel->
  "In[175]:=",ExpressionUUID->"e8f70c7a-bc65-4c95-8418-e014368e3be6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"orbit2D", "=", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", "[", "t", "]"}], ",", 
       RowBox[{"y", "[", "t", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "t0", ",", 
       RowBox[{"0.999", " ", "tFinish"}]}], "}"}], ",", 
     RowBox[{"AspectRatio", "->", "1"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Blue"}], "}"}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.979559828063959*^9, 3.979559833895805*^9}, {
  3.9797425311876307`*^9, 3.979742538139497*^9}, {3.979742716868277*^9, 
  3.979742717822167*^9}, {3.979742782200715*^9, 3.979742783471751*^9}, {
  3.979742817552215*^9, 3.979742820743737*^9}},
 CellLabel->
  "In[177]:=",ExpressionUUID->"fb24f4ba-6bde-4ec3-a9ed-779d5095ec08"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Areal", " ", "radius", " ", "of", " ", "the", " ", "stellar", " ", 
    "surface"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"rstarAreal", "=", 
     RowBox[{
      RowBox[{"A", "[", "rbarStar", "]"}], " ", "rbarStar"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"centralBody", "=", 
     RowBox[{"Graphics", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"GrayLevel", "[", "0.9", "]"}], ",", 
        RowBox[{"Disk", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], ",", "rstarAreal"}], "]"}]}], 
       "}"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9797428229566517`*^9, 3.979742835417776*^9}, {
  3.97974332393603*^9, 3.979743370159604*^9}},
 CellLabel->
  "In[178]:=",ExpressionUUID->"75a3cccb-45ee-4b53-8ca7-571b5ec1ae46"],

