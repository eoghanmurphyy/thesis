 CellLabel->"Out[16]=",ExpressionUUID->"09e27de1-8e4c-446d-9458-24aef1591aea"],

Cell[BoxData[
 FractionBox[
  RowBox[{"1", "-", 
   FractionBox["1", 
    RowBox[{"2", " ", "rbar"}]]}], 
  RowBox[{"1", "+", 
   FractionBox["1", 
    RowBox[{"2", " ", "rbar"}]]}]]], "Output",
 CellChangeTimes->{3.980420043831006*^9, 3.980421537483362*^9, 
  3.9804241728060923`*^9, 3.980430984152763*^9, 3.9804311872940693`*^9, 
  3.98047978276925*^9, 3.9804801596463346`*^9, 3.980492627552642*^9, 
