  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"urInit", "[", 
      RowBox[{"psi_", ",", " ", "Einit_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"umagE", "[", 
        RowBox[{"Einit", " ", ",", " ", "rbarStar"}], "]"}]}], 
      RowBox[{"Cos", "[", "psi", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
