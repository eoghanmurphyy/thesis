Cell[CellGroupData[{

Cell[TextData[{
 "Checking the analytic integral and NDSolve agree on the same \[Tau](",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
