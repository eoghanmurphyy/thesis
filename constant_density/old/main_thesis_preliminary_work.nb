Cell["\<\
Setting up variables and equations to be used (no speed up factor)\
\>", "Subsubsection",
 CellChangeTimes->{{3.979556508409439*^9, 3.979556519625342*^9}, {
  3.980412992502317*^9, 
  3.980412997243355*^9}},ExpressionUUID->"23c59d11-d9c4-4965-8e34-\
3f1869c7400a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"m", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "6"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"mass", " ", "of", " ", 
    RowBox[{"PBH", "?"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ivariable", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"??", 
    RowBox[{
     RowBox[{"?", " ", 
      RowBox[{"Just", " ", "got", " ", "from", " ", "paper"}]}], ",", " ", 
     RowBox[{
     "something", " ", "got", " ", "to", " ", "do", " ", "with", " ", 
      "Coulomb", " ", "something", " ", "or", " ", "other"}]}]}], "*)"}], 
  " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   FractionBox[
    RowBox[{"Abs", "[", "ur", "]"}], 
    RowBox[{"AInside", "[", "rbar", "]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"P", "[", "rbar_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"\[Rho]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         SqrtBox[
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"2", 
            FractionBox[
             RowBox[{"M", " ", 
              SuperscriptBox["r", "2"]}], 
             SuperscriptBox["RStar", "3"]]}]}]], "-", 
         SqrtBox[
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"2", 
            FractionBox["M", "RStar"]}]}]]}], 
        RowBox[{
         RowBox[{"3", 
          SqrtBox[
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"2", 
             FractionBox["M", "RStar"]}]}]]}], " ", "-", " ", 
         SqrtBox[
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"2", 
            FractionBox[
             RowBox[{"M", " ", 
              SuperscriptBox["r", "2"]}], 
             SuperscriptBox["RStar", "3"]]}]}]]}]], ")"}]}], " ", "/.", 
     RowBox[{"r", "->", 
      RowBox[{"rofRbarInside", "[", "rbar", "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Derived", " ", "from", " ", "TOV", " ", "as", " ", "I", " ", "done", " ", 
    "last", " ", "year"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
