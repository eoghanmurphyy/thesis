  3.9783332286165457`*^9}, {3.979555661448534*^9, 3.979555668023937*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"9488e013-9108-4095-bf4d-d4999a26eab5"]
}, Open  ]],

