Cell["\<\
Defining the Isotropic metric components for external Schwarzschild spacetime\
\
\>", "Text",
 CellChangeTimes->{{3.978080680202964*^9, 3.978080698553022*^9}, {
  3.978268989555698*^9, 
  3.9782689965556726`*^9}},ExpressionUUID->"5b9b60d0-0c1f-4469-a1af-\
61be65f73c12"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"A", "[", "rbar_", "]"}], " ", "=", " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "+", " ", 
       RowBox[{"M", "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "[", "rbar_", "]"}], " ", "=", " ", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{"M", "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{"1", " ", "+", " ", 
       RowBox[{"M", "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}]}]}], "]"}]}]}], "Input",\

 CellChangeTimes->{{3.978080703602681*^9, 3.9780808115943537`*^9}, {
  3.980420042256241*^9, 3.980420043437194*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"5d15e3dc-ab5f-454a-a724-8b2bc3b93d2c"],

Cell[BoxData[
 SuperscriptBox[
  RowBox[{"(", 
   RowBox[{"1", "+", 
    FractionBox["1", 
     RowBox[{"2", " ", "rbar"}]]}], ")"}], "2"]], "Output",
 CellChangeTimes->{3.980420043831006*^9, 3.980421537483362*^9, 
  3.9804241728060923`*^9, 3.980430984152763*^9, 3.9804311872940693`*^9, 
