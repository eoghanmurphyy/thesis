 CellLabel->"In[25]:=",ExpressionUUID->"acacf55f-bdc1-4797-be1a-99f858acc35e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tauIsotropic", "[", 
   RowBox[{"rStart_", ",", " ", "rFinish_"}], "]"}], " ", ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Urdrop", "[", "rBar", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"rBar", ",", "rStart", ",", "rFinish"}], "}"}], ",", 
    RowBox[{"WorkingPrecision", "->", "40"}]}], "]"}]}]], "Input",
