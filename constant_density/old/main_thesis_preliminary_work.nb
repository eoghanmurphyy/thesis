Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Solved", " ", "the", " ", "differential", " ", "eqn", " ", "below", " ", 
     "and", " ", "by", " ", "hand"}], ",", " ", 
    RowBox[{
    "by", " ", "hand", " ", "was", " ", "better", " ", "as", " ", "it", " ", 
     "was", " ", "the", " ", "same", " ", "as", " ", "the", " ", "one", " ", 
     "from", " ", "the", " ", 
     RowBox[{"paper", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eq", " ", "=", " ", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"rbar", "[", "r", "]"}], ",", " ", "r"}], "]"}], " ", "==", 
      " ", 
      RowBox[{
       RowBox[{"rbar", "[", "r", "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"r", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", " ", "-", " ", 
           RowBox[{
            RowBox[{"k", "^", "2"}], " ", 
            RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"DSolve", "[", 
      RowBox[{"eq", ",", " ", "rbar", ",", " ", "r"}], "]"}], "]"}], " ", 
    ";"}]}]}]], "Input",
