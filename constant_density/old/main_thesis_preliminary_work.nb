 StyleBox["Solver goes cuckoo at r = 0 unless I switch the sign of the \
velocity ",
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}],
 StyleBox["ur",
  IgnoreSpellCheck->True,
  FontWeight->"Bold",
  FontVariations->{"Underline"->True}]
}], "Text",
