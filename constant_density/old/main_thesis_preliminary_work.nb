Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"tauNDSolve", "[", "tf_", "]"}], " ", ":=", " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{"\[Alpha]", "[", 
         RowBox[{"rbarNum", "[", "t", "]"}], "]"}], "2"], "E0"], ",", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "t0", ",", " ", "tf"}], "}"}]}], "]"}]}], ";"}],
   " ", 
  RowBox[{"(*", 
   RowBox[{
   "Numerically", " ", "solving", " ", "one", " ", "of", " ", "the", " ", 
    "ODEs", " ", "above", " ", "for", " ", "tau"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.978270632130148*^9, 3.978270706425108*^9}, {
  3.979555289883136*^9, 3.979555304643355*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"26089fa5-30fe-41f3-9a25-3c1a4cae2dd2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"tauIsotropic", "[", 
      RowBox[{"rbar0", ",", " ", "r"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "rbar0", ",", " ", "rbarStar"}], "}"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Plot", " ", "from", " ", "starting", " ", "r0", " ", "down", " ", 
        "to", " ", "R"}], ",", " ", 
       RowBox[{"as", " ", "r", " ", "decreases"}]}], "*)"}], ",", " ", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], "\[IndentingNewLine]", ",",
    " ", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rbarNum", "[", "tf", "]"}], ",", " ", 
       RowBox[{"tauNDSolve", "[", "tf", "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"tf", ",", " ", "t0", ",", " ", "tEnd"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Dashing", "[", "0.1", "]"}], ",", " ", "Red"}], "}"}]}]}], 
    "]"}], ",", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*OverscriptBox[\(r\), \(_\)]\)\>\"", ",", 
      " ", "\"\<\[Tau](\!\(\*OverscriptBox[\(r\), \(_\)]\))\>\""}], "}"}]}]}],
   "]"}]], "Input",
