Cell["Convert r = 4M and r = 20M to isotropic coords", "Text",
 CellChangeTimes->{{3.978079323077736*^9, 3.97807934117108*^9}, {
  3.9780806264439907`*^9, 
  3.978080626746502*^9}},ExpressionUUID->"ff95e128-d83f-413d-bce3-\
9001410525ef"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rSchw", "[", "rbar_", "]"}], " ", "=", " ", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", " ", "=", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"rbar", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"M", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}]}], 
     "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Block", " ", "says", " ", "use", " ", "this", " ", "value", " ", "of", " ",
     "M", " ", "then", " ", "forget", " ", "it"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rBarSchw", "[", "r_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", " ", "=", " ", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "M"}], " ", "+", " ", "r", " ", "+", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"r", "^", "2"}], " ", "-", " ", 
          RowBox[{"2", " ", "M", " ", "r"}]}], "]"}]}], ")"}]}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.97807934283286*^9, 3.978079369400134*^9}, {
   3.978079402777368*^9, 3.9780795776311913`*^9}, {3.978080022118476*^9, 
   3.978080024313818*^9}, {3.978080174544195*^9, 3.978080176090117*^9}, {
   3.9780803181102123`*^9, 3.978080318317086*^9}, {3.978080413073202*^9, 
   3.9780804190546*^9}, {3.978080491928432*^9, 3.978080532244804*^9}, 
   3.9782689020528307`*^9, {3.978269033139801*^9, 3.97826903993154*^9}, {
   3.979554013414093*^9, 3.9795540140300293`*^9}, 3.979554370275063*^9},
 CellLabel->"In[12]:=",ExpressionUUID->"47d5b18c-802a-45c5-aa2c-36088a2d9881"],

