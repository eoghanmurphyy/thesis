Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"LogPlot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"umagphi", "[", 
      RowBox[{
       RowBox[{"rbarNumIn", "[", "t", "]"}], ",", 
       RowBox[{"urNumIn", "[", "t", "]"}], ",", 
       RowBox[{"uphiNumIn", "[", "t", "]"}]}], "]"}], "/.", " ", "solIn"}], 
    "]"}], ",", 
   RowBox[{"{", 
