54e226ea7629"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Einf", " ", "=", " ", 
  RowBox[{
   RowBox[{"InitialEnergyAtInfinity", "[", "vinf", "]"}], " ", "//", 
   "N"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SuperscriptBox[
    RowBox[{"\[Alpha]", "[", "rbarStar", "]"}], "2"], "  ", 
   RowBox[{"Ut", "[", 
    RowBox[{"rbarStar", ",", " ", "ur0", ",", " ", "uphi0"}], "]"}]}], " ", "//",
