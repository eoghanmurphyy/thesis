93536edeaedd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Alpha]Inside", "[", "rbar_", "]"}], ":=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       FractionBox["3", "2"], 
       SqrtBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], ")"}]]}], "-", 
      RowBox[{
       FractionBox["1", "2"], 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"M", " ", 
            SuperscriptBox[
             RowBox[{"rofrbarInside", "[", "rbar", "]"}], "2"]}], 
           SuperscriptBox["RStar", "3"]]}]}]]}]}], ")"}]}], ";"}], " ", 
  RowBox[{"(*", "Lapse", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AInside", "[", "rbar_", "]"}], ":=", 
    FractionBox[
     RowBox[{"rofrbarInside", "[", "rbar", "]"}], "rbar"]}], ";"}], 
  RowBox[{"(*", "Shift", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.968510507921006*^9, 3.968510547883458*^9}, {
