   RowBox[{"rofrbarInside", "[", "rbar_", "]"}], ":=", 
   RowBox[{
    FractionBox["1", "\[Kappa]"], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Tanh", "[", 
        RowBox[{"Log", "[", 
         FractionBox["rbar", "Const"], "]"}], "]"}], "2"]}]]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.982814726454424*^9, 3.98281473592638*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"3f4512f3-fa42-44ba-aed5-66bbc45b5f1b"]
