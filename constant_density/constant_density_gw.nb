Cell[CellGroupData[{

Cell["Average, physical energy loss per orbit", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 
  3.982908628893798*^9}},ExpressionUUID->"643ddebb-db50-4488-a3e4-\
90c0d74d63bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", "3"}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", "5"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"73", "/", "24"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"37", "/", "96"}], ")"}], " ", 
      RowBox[{"e", "^", "4"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}},
 CellLabel->
  "In[126]:=",ExpressionUUID->"29830255-57a1-41cf-a250-67809f8ff8c9"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t)\
\>", "Text",
