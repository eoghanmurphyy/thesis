  3.982909620589813*^9}},ExpressionUUID->"f50de761-5a81-427b-8190-\
1a2a34ed15e3"],

Cell[CellGroupData[{

Cell["Instantaneous energy loss (coordinate system dependent)", "Subsection",
 CellChangeTimes->{{3.98290861036561*^9, 
  3.982908637213344*^9}},ExpressionUUID->"dbb25126-40a2-4062-8057-\
475a16b7ec8c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtInside", "[", 
   RowBox[{"m_", ",", "rbar_", ",", "ur_", ",", "uphi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], ",", "rd", ",", 
      "phid"}], "}"}], ",", 
    RowBox[{
     RowBox[{"rd", "=", 
      RowBox[{"drBardtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", "=", 
      RowBox[{"dphidtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"8", " ", 
         RowBox[{"m", "^", "2"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"15", " ", 
         RowBox[{"r", "^", "4"}]}], ")"}]}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"MassFunction", "[", "r", "]"}], "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"8", " ", 
            RowBox[{"rd", "^", "2"}]}], "+", 
           RowBox[{"6", " ", 
            RowBox[{
             RowBox[{"(", 
