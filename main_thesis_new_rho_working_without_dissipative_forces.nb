Cell[CellGroupData[{

Cell["\<\
Gets very messy from here downwards: doing it the Taylor expansion way\
\>", "Subsubsection",
 CellChangeTimes->{{3.98214322179744*^9, 3.982143233197159*^9}, {
  3.982208794960548*^9, 
  3.982208802303178*^9}},ExpressionUUID->"2bed9dc5-480c-4f3f-95fa-\
ea5b96ce94e9"],

Cell["Limit at RStar diverges -> Taylor expland", "Text",
 CellChangeTimes->{{3.9821325104444838`*^9, 3.982132533202694*^9}, {
  3.982299975183461*^9, 
  3.98229998529342*^9}},ExpressionUUID->"27668e9a-c049-4ac9-8b12-\
41fee34e0ce9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Pdoubleprime", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"dPdr", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"Pressure", "[", "x", "]"}]}], "]"}], ",", " ", "x"}], "]"}], 
   " ", "/.", " ", 
   RowBox[{"x", "->", "r", "  ", 
    RowBox[{"(*", 
     RowBox[{"Must", " ", "use", " ", "D", " ", 
      RowBox[{"as", " ", "'"}], " ", "only", " ", "differentiates", " ", 
      RowBox[{"wrt", ".", " ", "the"}], " ", "first", " ", "argument"}], 
     "*)"}]}]}]}]], "Input",
 CellChangeTimes->{{3.982133314509489*^9, 3.98213336595647*^9}, {
   3.982133937327779*^9, 3.9821339585195017`*^9}, 3.982134059126745*^9, {
   3.982134099310668*^9, 3.982134117798394*^9}},
 CellLabel->"In[82]:=",ExpressionUUID->"3f4d4978-489d-458c-ae33-8f3956de7f25"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"asosprimenearRStar", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", 
     SqrtBox[
      RowBox[{"asos", "[", "r", "]"}]]}]], 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"Pdoubleprime", "[", "r", "]"}], 
      RowBox[{"drhodr", "[", "r", "]"}]], " ", "-", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"dPdr", "[", 
        RowBox[{"r", ",", " ", 
         RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"drhodr", "[", "r", "]"}], ")"}], "2"]], 
      RowBox[{
