Cell[CellGroupData[{

Cell[TextData[{
 "Solving for the new ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8bcac07a-5e67-4f4b-8c61-795c9b60472b"],
 "(r) and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", 
    OverscriptBox["r", "_"], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5e20a1ad-08e2-4e60-98a6-116d2b3b8699"],
 " inside, obtaining ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", 
    OverscriptBox["r", "_"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6bb94468-d81f-4084-b344-5d21705ad02c"],
 ") via the interpolation trick Sarp explained"
}], "Subsubsection",
 CellChangeTimes->{{3.9821241092691*^9, 3.982124151653302*^9}, {
  3.982124203125842*^9, 
  3.982124221268506*^9}},ExpressionUUID->"70037c0d-c0dd-43c3-9542-\
4665bc223b37"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Defining", " ", "the", " ", "ODE"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"drbardr", "[", 
    RowBox[{"rbar_", ",", " ", "r_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    FractionBox["rbar", "r"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox[
        RowBox[{"2", 
         RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
     RowBox[{"-", 
      FractionBox["1", "2"]}]]}]}]}]], "Input",
 CellChangeTimes->{{3.982124161189411*^9, 3.98212418850879*^9}, {
   3.982124241267745*^9, 3.9821242702282133`*^9}, {3.982124302635882*^9, 
   3.982124346387186*^9}, 3.982124382595275*^9, {3.982124431866364*^9, 
   3.982124441298533*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"a29dec26-d9a8-4798-af01-02e21511adde"],

Cell["Numerically Integrating the above equation.", "Text",
 CellChangeTimes->{{3.9821243981068573`*^9, 
  3.982124406532078*^9}},ExpressionUUID->"c2bbe5a5-0dc1-4f7e-ab60-\
33a0469aaa6c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"rbarofr", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"drbardr", "[", 
     RowBox[{
      RowBox[{"rbarofr", "[", "r", "]"}], ",", " ", "r"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BC", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rbarofr", "[", "RStar", "]"}], " ", "==", " ", "rbarStar"}], 
    "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9821244079560432`*^9, 3.9821245139540443`*^9}, {
  3.982124592345339*^9, 3.9821246242649517`*^9}, {3.982124799991644*^9, 
  3.9821248022163687`*^9}, {3.982124857431315*^9, 3.982124873838958*^9}, {
  3.982125338067565*^9, 3.982125342979814*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"44213e05-865d-4a7c-9474-74b1c697a447"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol2", " ", "=", " ", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eq", ",", "\[IndentingNewLine]", "BC"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "rbarofr", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "RStar", ",", " ", "rmin"}], "}"}]}], 
     "\[IndentingNewLine]", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9821246285773573`*^9, 3.982124693072137*^9}, {
   3.98212482919914*^9, 3.98212486767115*^9}, {3.982124915870698*^9, 
