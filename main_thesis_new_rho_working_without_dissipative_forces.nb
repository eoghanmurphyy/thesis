Cell[CellGroupData[{

Cell[TextData[{
 "Writing clean full ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", 
    OverscriptBox["r", "_"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5fccb0a7-1cf3-49c4-89be-935b45d67742"],
 ") equation to try and rid discontinuities"
}], "Subsubsection",
 CellChangeTimes->{{3.9822967908794928`*^9, 3.9822968095038643`*^9}, {
  3.9823092357668*^9, 3.9823092487802773`*^9}, {3.982309297276383*^9, 
  3.982309317660322*^9}},ExpressionUUID->"730c7a50-c008-4b19-a307-\
a067523528a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"rofrbarFull", "[", 
    RowBox[{"rbar_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rofrbarInside", "[", "rbar", "]"}], ",", " ", 
        RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rofrbarOutside", "[", "rbar", "]"}], ",", " ", 
        RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.982220778550305*^9, 3.982220780253932*^9}, {
   3.982220827165804*^9, 3.982220855333397*^9}, 3.9822209820604887`*^9, {
