Cell[BoxData[
 RowBox[{
  RowBox[{"asosPiecewise", "[", "rbar_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], "}"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"rbar", "<", "cutoffIso"}], ",", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"dPdr", "[", 
         RowBox[{"r", ",", 
          RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], "]"}], "/", 
        RowBox[{"drhodr", "[", "r", "]"}]}], "]"}], ",", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"M", " ", 
          RowBox[{"(", 
           RowBox[{"RStar", "-", "r"}], ")"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"6", " ", "RStar", " ", 
          RowBox[{"(", 
           RowBox[{"RStar", "-", 
            RowBox[{"2", " ", "M"}]}], ")"}]}], ")"}]}], "]"}]}], "]"}]}], 
