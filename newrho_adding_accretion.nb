 CellLabel->"In[20]:=",ExpressionUUID->"404238f2-0b25-414e-8dee-8556b9a1809d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Pressure", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"P", "[", "r", "]"}], " ", "/.", " ", "sol1"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
