 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"rbarofr", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"drbardr", "[", 
     RowBox[{
      RowBox[{"rbarofr", "[", "r", "]"}], ",", " ", "r"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BC", " ", "=", " ", 
   RowBox[{"{", 
