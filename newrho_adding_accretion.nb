Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"x", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"rbarNumIn", "[", "t", "]"}], " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"phiNumIn", "[", "t", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"y", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"rbarNumIn", "[", "t", "]"}], " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"phiNumIn", "[", "t", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"orbit2D", "=", 
    RowBox[{"ParametricPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
