 RowBox[{
  RowBox[{
   RowBox[{"EnergyPerUnitMass", "[", 
    RowBox[{"ptilde_", ",", " ", "eccen_"}], "]"}], " ", ":=", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"ptilde", " ", "-", "2"}], ")"}], "2"], " ", "-", " ", 
      RowBox[{"4", " ", "*", 
       SuperscriptBox["eccen", "2"]}]}], 
     RowBox[{"ptilde", "*", 
      RowBox[{"(", 
       RowBox[{"ptilde", " ", "-", " ", "3", " ", "-", " ", 
        SuperscriptBox["eccen", "2"]}], ")"}]}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
