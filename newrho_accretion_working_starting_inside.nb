Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"dpdtaccretionr", "[", 
    RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"(", 
       RowBox[{"4", " ", "Pi", " ", 
        RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], " ", 
        RowBox[{"(", "1.49", ")"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"rho", "[", "rbar", "]"}], " ", "+", " ", 
          RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], ")"}], 
        SuperscriptBox["m", "2"]}], ")"}], ")"}]}], 
    RowBox[{"(", 
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"umagInside", "[", 
           RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
          RowBox[{
           RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], " ", 
           RowBox[{"UtInside", "[", 
            RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
         ")"}], "2"]}]], ")"}], "ur"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.982645102464734*^9, 3.982645130456156*^9}},
 CellLabel->
  "In[156]:=",ExpressionUUID->"51b1ef4a-b56b-4849-af31-036decf26691"],

