Cell[BoxData[
 RowBox[{
  RowBox[{"dpdtaccretionphi", "[", 
   RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
   "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"(", 
     RowBox[{"(", 
      RowBox[{"4", " ", "Pi", " ", 
       RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], " ", 
       RowBox[{"(", "1.49", ")"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rho", "[", "rbar", "]"}], " ", "+", " ", 
         RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], ")"}], 
       SuperscriptBox["m", "2"]}], ")"}], ")"}]}], 
   RowBox[{"(", 
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{"umagInside", "[", 
          RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
         RowBox[{
          RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], " ", 
          RowBox[{"UtInside", "[", 
           RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
        ")"}], "2"]}]], ")"}], "uphi"}]}]], "Input",
 CellChangeTimes->{{3.982645229624877*^9, 3.982645251008081*^9}, {
  3.9826454195513163`*^9, 3.982645422176188*^9}},
