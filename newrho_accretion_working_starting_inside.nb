       RowBox[{"PlotLegends", "->", 
        RowBox[{"LineLegend", "[", 
         RowBox[{"Automatic", ",", 
          RowBox[{"{", 
           
           RowBox[{"\"\<\!\(\*OverscriptBox[\(r\), \(_\)]\)(t)\>\"", 
