Cell[BoxData[
 RowBox[{
  RowBox[{"outFigRadial", "=", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"rbarNumIn", "[", "t", "]"}], ",", 
