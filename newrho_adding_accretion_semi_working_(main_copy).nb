         RowBox[{"(", 
          FractionBox[
           RowBox[{"dPdr", "[", 
            RowBox[{"r", ",", " ", 
             RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], 
           RowBox[{"drhodr", "[", "r", "]"}]], ")"}], 
         FractionBox["1", "2"]], ",", " ", 
        RowBox[{"r", " ", "<", "cutoff"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
