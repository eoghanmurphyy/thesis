           RowBox[{"6", "RStar", 
            RowBox[{"(", 
             RowBox[{"RStar", "-", 
              RowBox[{"2", "M"}]}], ")"}]}]], ")"}], 
         FractionBox["1", "2"]], ",", " ", 
        RowBox[{"r", " ", ">=", " ", "cutoff"}]}], "}"}]}], 
