 CellChangeTimes->{{3.9807597890247583`*^9, 3.980759803632635*^9}, {
  3.982122166723227*^9, 
  3.9821221709313107`*^9}},ExpressionUUID->"46b04e52-e9a1-4708-9713-\
b8d73fa20fee"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"rho", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rho0", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["r", "RStar"]}], ")"}], "6"]}], ",", " ", 
        RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9807577923623877`*^9, 3.98075785617692*^9}, {
   3.9807579037758617`*^9, 3.980758119918268*^9}, {3.980759150141821*^9, 
   3.980759229085232*^9}, {3.98075970148167*^9, 3.9807597184254913`*^9}, {
   3.980759983167514*^9, 3.980760030871025*^9}, 3.980760548251651*^9, {
   3.980760610330676*^9, 3.98076062375484*^9}, {3.9807606770346537`*^9, 
   3.980760724658237*^9}, {3.980762059247533*^9, 3.9807620598878193`*^9}, {
   3.980762157230887*^9, 3.980762163950886*^9}, {3.9816058484984283`*^9, 
   3.981605848905244*^9}, {3.982121659845503*^9, 3.98212166630149*^9}, {
   3.982132058454728*^9, 3.982132065998157*^9}, {3.9822082367232447`*^9, 
   3.982208236971711*^9}, 3.982296663190221*^9},
 CellLabel->
  "In[182]:=",ExpressionUUID->"6807bacf-7b4d-4913-b619-75336105eb80"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Getting new equations for the new interior metric:", "Subsection",
 CellChangeTimes->{{3.980759833065682*^9, 3.980759839256179*^9}, {
  3.982122248004889*^9, 3.982122264995124*^9}, {3.982126398426784*^9, 
  3.982126413874289*^9}},ExpressionUUID->"e582958d-dac6-487a-9e68-\
b4681244c6e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"TOV", " ", "differential", " ", "equation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPdr", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"rho", "[", "r", "]"}], " ", "+", " ", "Pressure"}], ")"}]}], 
     
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
        RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
         SuperscriptBox["r", "3"]}]}], 
       RowBox[{"r", 
        RowBox[{"(", 
         RowBox[{"r", "-", 
          RowBox[{"2", 
           RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.9807601294062366`*^9, 3.98076013474163*^9}, {
   3.980760167277755*^9, 3.980760297804946*^9}, {3.98076131275782*^9, 
   3.980761317285252*^9}, {3.980761630595008*^9, 3.980761651114334*^9}, {
   3.981015108916844*^9, 3.9810151437874613`*^9}, {3.981015203498157*^9, 
   3.981015209182917*^9}, 3.9816058987047577`*^9, {3.982122185731833*^9, 
   3.982122238987522*^9}, {3.9821222783397818`*^9, 3.982122281595154*^9}, {
   3.982391355256955*^9, 3.982391409128538*^9}, {3.98239155213509*^9, 
   3.9823915790869703`*^9}, {3.982404709363402*^9, 3.9824047098352737`*^9}, {
   3.982556501089521*^9, 3.982556502833229*^9}},
 CellLabel->
  "In[183]:=",ExpressionUUID->"12df92a2-2e1f-449f-87a5-f63bd0a458e4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Phi", " ", "differential", " ", "equation", " ", "for", " ", "metric"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"(", 
     FractionBox[
      RowBox[{
       RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
       RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
        SuperscriptBox["r", "3"]}]}], 
      RowBox[{"r", 
       RowBox[{"(", 
        RowBox[{"r", "-", 
         RowBox[{"2", 
          RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.982122270771688*^9, 3.982122347371161*^9}, 
   3.982391602103158*^9, {3.9825565041772747`*^9, 3.982556505897291*^9}, 
   3.9825566470569277`*^9},
 CellLabel->
  "In[184]:=",ExpressionUUID->"16fc508b-83cc-44fd-8caa-34e7955c55cc"],

Cell[CellGroupData[{

Cell["\<\
Numerically Integrate these two partially coupled differential equations\
\>", "Subsubsection",
 CellChangeTimes->{{3.982122414666267*^9, 3.982122461514476*^9}, {
  3.982124096429223*^9, 
  3.982124100636909*^9}},ExpressionUUID->"83a3fc05-26f4-48f4-bc08-\
afcf248d88b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rmin", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "16"}]]}], " ", 
  RowBox[{"(*", 
   RowBox[{"For", " ", "these", " ", "integrations"}], "*)"}], ";"}]], "Input",\

 CellChangeTimes->{{3.982124889135005*^9, 3.982124904695006*^9}, {
  3.9822966879901857`*^9, 3.982296688061829*^9}},
 CellLabel->
  "In[185]:=",ExpressionUUID->"213df192-ab7f-4a84-a52b-d93b1d63f9d1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq1", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"P", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPdr", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq2", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Phi", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BCs", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"P", "[", "RStar", "]"}], " ", "==", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"Phi", "[", "RStar", "]"}], " ", "==", " ", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], "]"}]}]}]}], "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Phi", "[", "RStar", "]"}], " ", "from", " ", "the", " ", 
    "Schwarzschild", " ", "metric"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982122468706362*^9, 3.9821225498339243`*^9}, {
  3.982123843807171*^9, 3.982123907678915*^9}, {3.9823916180786943`*^9, 
  3.982391618438609*^9}},
 CellLabel->
  "In[186]:=",ExpressionUUID->"7b8d8367-53bf-41c1-9952-3066776a590d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"sol1", " ", "=", " ", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "eq1", ",", "\[IndentingNewLine]", "eq2", ",", "\[IndentingNewLine]", 
         "BCs"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"P", ",", " ", "Phi"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "RStar", ",", " ", "rmin"}], "}"}]}], 
      "\[IndentingNewLine]", "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Very", " ", "small", " ", "rmin", " ", "to", " ", "avoid", " ", 
    "singularity", " ", "sarp", " ", "mentioned"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.980761191230756*^9, 3.9807611984861517`*^9}, {
   3.9807612617574863`*^9, 3.98076139206083*^9}, {3.980761732033964*^9, 
