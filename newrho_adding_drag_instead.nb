Cell["Sorting out the speed of sound as a function of r: a(r)", "Subsection",
 CellChangeTimes->{{3.9821318046645107`*^9, 
  3.982131844559926*^9}},ExpressionUUID->"f4f3c91a-af19-4bac-a8ad-\
2a96cc3236f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Getting", " ", "the", " ", "derivative", " ", "of", " ", "the", " ", 
    "density"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"rhodummy", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{"rho0", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox["r", "RStar"]}], ")"}], "6"]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rhodummy", "'"}], "[", "r", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"drhodr", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"-", "6"}], " ", "rho0"}], "RStar"], 
     SuperscriptBox[
