          RowBox[{
           RowBox[{"rho", "[", "rbar", "]"}], " ", "+", " ", 
           RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], ")"}], 
         SuperscriptBox["m", "2"]}], ")"}], ")"}]}], 
     RowBox[{"(", 
      FractionBox["1", 
