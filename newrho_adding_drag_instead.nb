Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"rho", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rho0", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["r", "RStar"]}], ")"}], "6"]}], ",", " ", 
        RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}]], "Input",
