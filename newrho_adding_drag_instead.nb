Cell[BoxData[
 RowBox[{
  RowBox[{"asosPiecewise", "[", 
   RowBox[{"rbar_", "?", "NumericQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], "}"}], ",", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "@", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"dPdr", "[", 
             RowBox[{"r", ",", 
              RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], "/", 
            RowBox[{"drhodr", "[", "r", "]"}]}], "]"}]}], ",", 
         RowBox[{"rbar", "<", "cutoffIso"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "@", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"M", " ", 
              RowBox[{"(", 
               RowBox[{"RStar", "-", "r"}], ")"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"6", " ", "RStar", " ", 
              RowBox[{"(", 
               RowBox[{"RStar", "-", 
                RowBox[{"2", " ", "M"}]}], ")"}]}], ")"}]}], "]"}]}], ",", 
         RowBox[{"cutoffIso", "<=", "rbar", "<", "rbarStar"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
      "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
