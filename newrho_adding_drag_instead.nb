Cell["Defining the constants to define the motion", "Subsection",
 CellChangeTimes->{{3.9806797967818213`*^9, 
  3.980679802669787*^9}},ExpressionUUID->"81d48100-b508-44ea-9558-\
1604853da643"],

Cell[CellGroupData[{

Cell["Eccentricity and semi-latus rectum", "Subsubsection",
 CellChangeTimes->{{3.980679832941638*^9, 
  3.9806798406134243`*^9}},ExpressionUUID->"ad2adaea-6d56-4a2c-9230-\
da091c1ceb2e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"eccentricity", " ", "=", " ", "0.4"}], ";"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eccentricity", " ", "=", " ", 
     FractionBox["9", "11"]}], ";"}], " ", 
   RowBox[{"(*", 
