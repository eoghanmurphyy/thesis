  3.980418658653262*^9, 3.980418733921682*^9}, {3.980420231879798*^9, 
  3.9804202353180428`*^9}},
 CellLabel->"In[96]:=",ExpressionUUID->"f1cc6208-1587-4fc9-8015-8c76c9024271"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Setting the Initial conditions", "Subsubsection",
 CellChangeTimes->{{3.980417374617618*^9, 
  3.980417378785927*^9}},ExpressionUUID->"6e8326df-a96d-42a0-b32b-\
7609f73866d1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"we", " ", "start", " ", "at", " ", "rbarStar"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"phi0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Einf", " ", "=", " ", 
     RowBox[{"InitialEnergyAtInfinity", "[", "vinf", "]"}]}], ";"}], "\[IndentingNewLine]",
    " ", 
   RowBox[{
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"umagE", "[", 
      RowBox[{"Einf", ",", " ", "rbarStar"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ImpactAngle", " ", "=", " ", 
     FractionBox["Pi", "4"]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"In", " ", "radians"}], ",", " ", 
     RowBox[{
     "measured", " ", "from", " ", "center", " ", "of", " ", "star", " ", 
      "to", " ", "the", " ", "position", " ", "of", " ", "particle"}], ",", 
     " ", 
     RowBox[{"in", " ", "unit", " ", "circle", " ", "fashion"}], ",", " ", 
     RowBox[{
      RowBox[{"pi", "/", "2"}], " ", "corresponds", " ", "to", " ", "grazing",
       " ", "the", " ", "star", " ", "as", " ", "it", " ", "enters", " ", 
      "and", " ", "0", " ", "corresponds", " ", "to", " ", "a", " ", "radial",
       " ", "drop"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ur0", " ", "=", " ", 
     RowBox[{
      RowBox[{"-", "u"}], "*", 
      RowBox[{"Cos", "[", "ImpactAngle", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"uphi0", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", "rbarStar", ")"}], 
      RowBox[{"(", "u", ")"}], " ", 
      RowBox[{"Sin", "[", "ImpactAngle", "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9804173808295593`*^9, 3.9804174607879868`*^9}, {
  3.980417560868024*^9, 3.98041773116045*^9}, {3.980417823546092*^9, 
