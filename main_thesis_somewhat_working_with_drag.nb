Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"rofrbarFull", "[", 
    RowBox[{"rbar_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rofrbarInside", "[", "rbar", "]"}], ",", " ", 
        RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rofrbarOutside", "[", "rbar", "]"}], ",", " ", 
        RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
