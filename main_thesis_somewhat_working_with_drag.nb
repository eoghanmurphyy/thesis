Cell[CellGroupData[{

Cell["Rates of change of velocities", "Subsubsection",
 CellChangeTimes->{{3.98229881060014*^9, 
  3.9822988183975*^9}},ExpressionUUID->"ece96e93-c603-4e4f-9b97-b21aedddf033"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"drBardt", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"], 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "ur"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dphidtOutside", "[", 
     RowBox[{"rbar_", ",", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", " ", 
    
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["rbar", "2"], "*", 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"], "*", 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", "uphi"}], "]"}]}]], "uphi"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt2DOutside", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
   " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]", "[", "rbar", "]"}]}], " ", 
     RowBox[{"Ut", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{"DER\[Alpha]Outside", "[", "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
