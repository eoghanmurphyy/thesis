Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ut", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
   " ", 
   FractionBox[
    SqrtBox[
     RowBox[{"1", " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["ur", 
         RowBox[{"A", "[", "rbar", "]"}]], ")"}], "2"], " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["uphi", 
         RowBox[{"rbar", " ", 
          RowBox[{"A", "[", "rbar", "]"}]}]], ")"}], "2"]}]], 
    RowBox[{"\[Alpha]", "[", "rbar", "]"}]]}], ";"}]], "Input",
