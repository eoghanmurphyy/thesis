             SuperscriptBox["r", "2"]}], 
            SuperscriptBox["RStar", "3"]]}]}]]}]}], ")"}], "/.", 
     RowBox[{"r", "->", 
      RowBox[{"rofRbarInside", "[", "rbar", "]"}]}]}]}], ";"}], " ", 
  RowBox[{"(*", "Lapse", "*)"}]}], "\[IndentingNewLine]", 
