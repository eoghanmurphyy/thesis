Cell[CellGroupData[{

Cell["\<\
Schwarzschild and Isotropic interior coordinate conversion formulas\
\>", "Subsubsection",
 CellChangeTimes->{{3.9806789303493757`*^9, 3.980678935965378*^9}, {
  3.980679131228282*^9, 
  3.980679156483783*^9}},ExpressionUUID->"d70d6f46-1ad1-4b61-a533-\
157307a4a03e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rBarofrInside", "[", "r_", "]"}], "=", 
   RowBox[{"Const", " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}], 
      RowBox[{"1", "+", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}]]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rofRbarInside", "[", "R_", "]"}], "=", 
   RowBox[{
    FractionBox["1", "\[Kappa]"], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Tanh", "[", 
        RowBox[{"Log", "[", 
         FractionBox["R", "Const"], "]"}], "]"}], "2"]}]]}]}], 
  ";"}]}], "Input",
 CellLabel->
  "In[981]:=",ExpressionUUID->"3f4512f3-fa42-44ba-aed5-66bbc45b5f1b"]
}, Open  ]],

