Cell[BoxData[{
 RowBox[{
  RowBox[{"x1", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x2", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", " ", "=", " ", "3.03"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y2", " ", "=", " ", "6.67"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"anaylticline", "[", "\[CapitalMu]ach_", "]"}], " ", ":=", " ", 
   RowBox[{"y1", " ", "+", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"y2", " ", "-", " ", "y1"}], ")"}], " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", " ", "-", " ", "x1"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"x2", " ", "-", " ", "x1"}], ")"}]}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9806811143147*^9, 3.980681141609749*^9}, {
  3.980681296608494*^9, 3.980681314784219*^9}},
 CellLabel->
  "In[992]:=",ExpressionUUID->"64393063-df6d-488b-91c2-efc7ca9baf13"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"IVariableInterpolated", "[", "\[CapitalMu]ach_", "]"}], " ", ":=",
    " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"1", "+", " ", "\[CapitalMu]ach"}], 
            RowBox[{"1", " ", "-", " ", "\[CapitalMu]ach"}]], "]"}]}], " ", "-",
          " ", "\[CapitalMu]ach"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", "<", " ", "0.9999"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"anaylticline", "[", "\[CapitalMu]ach", "]"}], ",", " ", 
        RowBox[{
        "0.9999", " ", "<", " ", "\[CapitalMu]ach", "  ", "<", " ", 
         "1.0001"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["1", 
             SuperscriptBox["\[CapitalMu]ach", "2"]]}], "]"}]}], "  ", "+", 
         " ", "10"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", ">", " ", "1.0001"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9806813197521677`*^9, 3.980681355455866*^9}, {
