     RowBox[{
      RowBox[{"(", "ptilde", ")"}], "*", "Mass"}], 
     RowBox[{"1", " ", "-", " ", "eccen"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "In", " ", "Schwarzschild", " ", "areal", " ", "r", " ", "coordinates"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
