 CellLabel->
  "In[259]:=",ExpressionUUID->"e29ed64b-50bd-4e49-b2df-6c4ddd49c01a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"epsilon", " ", "=", " ", "0.026"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"from", " ", "RStar"}], " ", "-", " ", 
    RowBox[{
    "7.974", " ", "which", " ", "is", " ", "oscillating", " ", "only", " ", 
     "in", " ", "the", " ", "1", "e"}], "-", 
