Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"for", " ", "\[CapitalGamma]"}], " ", "=", " ", 
    RowBox[{"2", " ", "accretion", " ", "rate"}]}], "*)"}], " ", 
  RowBox[{"(*", 
   RowBox[{"This", " ", "is", " ", "my", " ", "dmdt", " ", "equation"}], 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"mdot", "[", 
      RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
      "]"}], " ", ":=", " ", 
     RowBox[{"1.49", "*", " ", 
      FractionBox[
       RowBox[{"4", "Pi", " ", "rho0", " ", 
        SuperscriptBox["m", "2"]}], 
       RowBox[{
        SuperscriptBox[
         RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], " ", "+", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"umagphi", "[", 
