         RowBox[{"rho", "[", "r", "]"}], " ", "+", " ", "Pressure"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", 
         FractionBox[
          RowBox[{"4", " ", "Pi", " ", 
           RowBox[{"(", "Pressure", ")"}], " ", 
           SuperscriptBox["r", "3"]}], 
          RowBox[{"MassFunc", "[", "r", "]"}]]}], ")"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", " ", "-", " ", 
          FractionBox[
           RowBox[{"2", " ", 
            RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
        RowBox[{"-", "1"}]]}], "]"}]}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.9807601294062366`*^9, 3.98076013474163*^9}, {
