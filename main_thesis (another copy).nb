Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"TOV", " ", "differential", " ", "equation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPdr", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"-", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"MassFunc", "[", "r", "]"}], 
        SuperscriptBox["r", "2"]], 
