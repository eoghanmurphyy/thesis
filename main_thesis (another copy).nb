        SuperscriptBox["r", "2"]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "0", ",", " ", "R"}], "}"}]}], "]"}]}]}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Set", " ", "equal", " ", "to", " ", "1"}], "*)"}]}]}], "Input",
