  RowBox[{"(*", 
   RowBox[{
   "Phi", " ", "differential", " ", "equation", " ", "for", " ", "metric"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
