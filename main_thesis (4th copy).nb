   RowBox[{
    RowBox[{
     RowBox[{"P", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPdr", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq2", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Phi", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPhidrMetric", "[", 
