Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DERAFull", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "rbar",
          "]"}], ",", " ", 
        RowBox[{"rbar", " ", ">=", "rbarStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         FractionBox[
          RowBox[{"drdrbar", "[", "rbar", "]"}], "rbar"], " ", "-", " ", 
         FractionBox[
          RowBox[{"rofrbarFull", "[", "rbar", "]"}], 
          SuperscriptBox["rbar", "2"]]}], ",", " ", 
        RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
