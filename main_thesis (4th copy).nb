Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"epsilon", " ", "=", " ", "0.026"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"from", " ", "RStar"}], " ", "-", " ", 
    RowBox[{
    "7.974", " ", "which", " ", "is", " ", "oscillating", " ", "only", " ", 
