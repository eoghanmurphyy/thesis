         RowBox[{"MassFunc", "[", "r", "]"}]]}], ")"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", " ", "-", " ", 
         FractionBox[
          RowBox[{"2", " ", 
           RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
       RowBox[{"-", "1"}]]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.982122270771688*^9, 3.982122347371161*^9}},
 CellLabel->
