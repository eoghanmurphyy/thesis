590b2172bc05"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rho0", " ", "=", " ", 
   RowBox[{
    RowBox[{"rhoCentre", "[", "RStar", "]"}], " ", "//", "N"}]}], 
  ";"}]], "Input",
