Cell[BoxData[{
 RowBox[{
  RowBox[{"drbardr", "[", 
   RowBox[{"rbar_", ",", " ", "r_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["rbar", "r"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
    RowBox[{"-", 
     FractionBox["1", "2"]}]]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"drdrbar", "[", "rbar_", "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox[
    RowBox[{"rofrbarFull", "[", "rbar", "]"}], "rbar"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", 
         RowBox[{"rofrbarFull", "[", "rbar", "]"}], "]"}]}], 
       RowBox[{"rofrbarFull", "[", "rbar", "]"}]]}], ")"}], 
    FractionBox["1", "2"]]}]}]}], "Input",
 CellChangeTimes->{{3.982309801432266*^9, 3.982309835904133*^9}},
