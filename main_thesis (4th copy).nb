Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rho", "[", 
     RowBox[{"rbar_", "?", "NumericQ"}], "]"}], " ", ":=", 
    RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"rho0", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"1", " ", "-", " ", 
             FractionBox[
              RowBox[{"rofrbarFull", "[", "rbar", "]"}], "RStar"]}], ")"}], 
           "6"]}], ",", " ", 
         RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
