Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"for", " ", "\[CapitalGamma]"}], " ", "=", " ", 
    RowBox[{"2", " ", "accretion", " ", "rate"}]}], "*)"}], " ", 
  RowBox[{"(*", 
   RowBox[{"This", " ", "is", " ", "my", " ", "dmdt", " ", "equation"}], 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"mdot", "[", 
      RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
      "]"}], " ", ":=", " ", 
     RowBox[{"1.49", "*", " ", 
      FractionBox[
       RowBox[{"4", "Pi", " ", "rho0", " ", 
        SuperscriptBox["m", "2"]}], 
       RowBox[{
        SuperscriptBox[
         RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], " ", "+", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"umagphi", "[", 
            RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
           RowBox[{
            RowBox[{"\[Alpha]Full", "[", "rbar", "]"}], " ", 
            RowBox[{"UtInside", "[", 
             RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
          ")"}], "2"]}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"dpdtaccretionr", "[", 
       RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
       "]"}], " ", ":=", " ", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"4", " ", "Pi", " ", 
            RowBox[{"\[Alpha]Full", "[", "rbar", "]"}], " ", 
            RowBox[{"\[Lambda]GR", "[", "rbar", "]"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"rho", "[", "rbar", "]"}], " ", "+", " ", 
              RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], ")"}], 
            
            SuperscriptBox["m", "2"]}], ")"}], "/", 
          SuperscriptBox[
           RowBox[{"asosPiecewise", "[", "rbar", "]"}], "3"]}], ")"}]}], 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], 
          RowBox[{
           SuperscriptBox[
            RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], "+", 
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox[
              RowBox[{"umagphi", "[", 
               RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
              RowBox[{
               RowBox[{"\[Alpha]Full", "[", "rbar", "]"}], " ", 
               RowBox[{"UtInside", "[", 
                RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
             ")"}], "2"]}]], ")"}], 
        FractionBox["q", "2"]], "ur"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"dpdtaccretionphi", "[", 
       RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
       "]"}], " ", ":=", " ", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
