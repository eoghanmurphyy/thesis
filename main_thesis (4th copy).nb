Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dPhidrMetric", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"MassFunc", "[", 
       RowBox[{"rofrbarFull", "[", "rbar", "]"}], "]"}], 
      SuperscriptBox[
       RowBox[{"rofrbarFull", "[", "rbar", "]"}], "2"]], 
     RowBox[{"(", 
      RowBox[{"1", " ", "+", " ", 
       FractionBox[
        RowBox[{"4", " ", "Pi", " ", 
         RowBox[{"(", 
          RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}], ")"}], " ", 
         SuperscriptBox[
          RowBox[{"rofrbarFull", "[", "rbar", "]"}], "3"]}], 
        RowBox[{"MassFunc", "[", 
         RowBox[{"rofrbarFull", "[", "rbar", "]"}], "]"}]]}], ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox[
         RowBox[{"2", " ", 
          RowBox[{"MassFunc", "[", 
           RowBox[{"rofrbarFull", "[", "rbar", "]"}], "]"}]}], 
         RowBox[{"rofrbarFull", "[", "rbar", "]"}]]}], ")"}], 
      RowBox[{"-", "1"}]]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DER\[Alpha]Inside", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{
