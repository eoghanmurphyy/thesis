Cell[BoxData[{
 RowBox[{
  RowBox[{"E0", "=", 
   RowBox[{"\[Alpha]", "[", "rbar0", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"0", "<", "E0", "<=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ut0", "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "rbar0", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Utdrop", "[", "rbar_", "]"}], "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "rbar", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Urdrop", "[", "rbar_", "]"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     RowBox[{"A", "[", "rbar", "]"}]], 
    SqrtBox[
     RowBox[{
      FractionBox[
       SuperscriptBox["E0", "2"], 
       SuperscriptBox[
        RowBox[{"\[Alpha]", "[", "rbar", "]"}], "2"]], "-", "1"}]]}]}], 
  ";"}]}], "Input",
