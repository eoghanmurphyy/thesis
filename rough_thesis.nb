Cell["Checking Inside and outside transformations agree on RSTAR", "Text",
 CellChangeTimes->{{3.978330800147243*^9, 3.978330814786989*^9}, {
  3.978331846955274*^9, 
  3.978331848643408*^9}},ExpressionUUID->"a1ebda03-376e-4630-9ed2-\
f20ca4125599"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rbarStar", " ", "=", " ", 
   RowBox[{"rBarSchw", "[", "RStar", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RStarVal", " ", "==", " ", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"rofRbarInside", "[", "%", "]"}], " ", "/.", " ", 
      RowBox[{"M", " ", "->", " ", "M"}]}], " ", "/.", " ", 
     RowBox[{"RStar", " ", "->", " ", "RStar"}]}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"and", " ", "it", " ", "matchesm"}], ",", " ", 
    RowBox[{
    "%", " ", "takes", " ", "previous", " ", "lines", " ", "answer"}]}], 
   "*)"}]}], "\[IndentingNewLine]"}], "Input",
