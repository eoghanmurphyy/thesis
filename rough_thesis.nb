Cell[BoxData[
 RowBox[{"rbar", "\[Equal]", 
  RowBox[{"C", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{"1", "-", 
      SqrtBox[
       RowBox[{"1", "-", 
        RowBox[{
         SuperscriptBox["k", "2"], " ", 
         SuperscriptBox["r", "2"]}]}]]}], 
     RowBox[{"1", "+", 
      SqrtBox[
       RowBox[{"1", "+", 
        RowBox[{
         SuperscriptBox["k", "2"], " ", 
         SuperscriptBox["r", "2"]}]}]]}]]]}]}]], "Output",
