  3.9783316301168423`*^9}},ExpressionUUID->"e5eaf4d7-0443-4e38-baf2-\
d7ee1017fdb5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]Inside", "[", "rbar_", "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       FractionBox["3", "2"], 
       SqrtBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], ")"}]]}], "-", 
