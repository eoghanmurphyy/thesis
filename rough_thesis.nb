Cell["\<\
Defining the Isotropic metric components for external Schwarzschild spacetime\
\
\>", "Text",
 CellChangeTimes->{{3.978080680202964*^9, 3.978080698553022*^9}, {
  3.978268989555698*^9, 
  3.9782689965556726`*^9}},ExpressionUUID->"f190c2a7-9ba7-44ab-8e9c-\
25bdd3faaa3c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}]}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.978080703602681*^9, 3.9780808115943537`*^9}},
 CellLabel->
  "In[512]:=",ExpressionUUID->"b5a7a50c-0a23-4252-a9b4-2db657c992b0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"E0", "=", 
   RowBox[{"\[Alpha]", "[", "rbar0", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"0", "<", "E0", "<=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ut0", "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "rbar0", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Utdrop", "[", "rbar_", "]"}], "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "rbar", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Urdrop", "[", "rbar_", "]"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     RowBox[{"A", "[", "rbar", "]"}]], 
    SqrtBox[
     RowBox[{
      FractionBox[
       SuperscriptBox["E0", "2"], 
       SuperscriptBox[
        RowBox[{"\[Alpha]", "[", "rbar", "]"}], "2"]], "-", "1"}]]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.968383101060911*^9, 3.9683831220780077`*^9}, {
  3.968383226462936*^9, 3.9683832418428698`*^9}, {3.968383303505459*^9, 
  3.968383347812524*^9}, {3.968383464033807*^9, 3.9683835004428253`*^9}, {
