Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}]}]}], "]"}]}], 
  ";"}]}], "Input",
