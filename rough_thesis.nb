439914a4b495"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tSchw", "[", 
    RowBox[{"R_", ",", "rf_"}], "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "1"}], 
       SqrtBox[
        RowBox[{"2", "M"}]]], 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          SqrtBox[
           RowBox[{"1", "-", 
            RowBox[{"2", 
             RowBox[{"M", "/", "R"}]}]}]], 
          SqrtBox[
           RowBox[{
            FractionBox["1", "r"], "-", 
            FractionBox["1", "R"]}]]], 
         FractionBox["1", 
          RowBox[{"1", "-", 
           RowBox[{"2", 
            FractionBox["M", "r"]}]}]]}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "R", ",", "rf"}], "}"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"from", " ", "MTW", " ", "book"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.978329504841354*^9, 3.978329516621935*^9}},
 CellLabel->
