 RowBox[{
  RowBox[{"t0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rEnd", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rBarEnd", " ", "=", " ", 
   RowBox[{"rBarSchw", "[", "rEnd", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tEnd", " ", "=", " ", 
   RowBox[{"tSchw", "[", 
    RowBox[{"R0", ",", " ", "RStar"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "  ", "=", " ", 
  RowBox[{
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"drBardt", "[", 
         RowBox[{
          RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
          RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"ur", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"durdt", "[", 
         RowBox[{
          RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
          RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
       
       RowBox[{
        RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"rbar", ",", " ", "ur"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "t0", ",", " ", "tEnd"}], "}"}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]}], "Input",
