  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"rbar", "[", "r", "]"}], ",", " ", "r"}], "]"}], " ", "==", " ", 
    RowBox[{
     RowBox[{"rbar", "[", "r", "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"r", " ", 
