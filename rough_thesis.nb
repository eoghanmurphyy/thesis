  3.978329943730052*^9}},ExpressionUUID->"a5501c44-c596-4ae4-a398-\
3ed0820089c9"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "r", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"M", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RStar", " ", "=", " ", "5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.978329952795225*^9, 3.97832996470603*^9}, {
  3.9783314229347754`*^9, 3.9783314272944937`*^9}},
 CellLabel->
  "In[215]:=",ExpressionUUID->"ebff72d3-7629-46fd-a488-121c3fec320f"],

Cell[CellGroupData[{

Cell["Interior Solution functions", "Subsubsection",
 CellChangeTimes->{{3.9783300115373487`*^9, 
  3.978330022665663*^9}},ExpressionUUID->"8d323fbe-d83a-4e10-9d85-\
0877b1f23dcb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mfunc", "[", "r_", "]"}], " ", "=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M", " ", 
         FractionBox[
          SuperscriptBox["r", "3"], 
          SuperscriptBox["RStar", "3"]]}], ",", " ", 
        RowBox[{"r", " ", "<=", " ", "RStar"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"M", ",", " ", 
        RowBox[{"r", ">", "RStar"}]}], "}"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"grrTOV", "[", "r_", "]"}], " ", "=", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox[
        RowBox[{"2", 
         RowBox[{"Mfunc", "[", "r", "]"}]}], "r"]}], ")"}], 
     RowBox[{"-", "1"}]]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Kappa]", " ", "=", " ", 
    SqrtBox[
     RowBox[{"2", 
      FractionBox["M", 
       SuperscriptBox["RStar", "3"]]}]]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Int", " ", "const"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Const", " ", "=", " ", 
    RowBox[{
     RowBox[{"rBarSchw", "[", "RStar", "]"}], 
     SqrtBox[
      FractionBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", 
          FractionBox[
           RowBox[{"2", "M"}], "RStar"]}]]}], 
       RowBox[{"1", "-", 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}]]}]]]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Can", " ", "use", " ", "schw", " ", "to", " ", "convert", " ", "RStar", " ",
     "as", " ", "the", " ", "value", " ", "should", " ", "be", " ", "the", " ",
     "same", " ", "inside", " ", "and", " ", "outside"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rBarofrInside", "[", "r_", "]"}], "=", 
   RowBox[{"Const", " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}], 
      RowBox[{"1", "+", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}]]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rofRbarInside", "[", "R_", "]"}], "=", 
   RowBox[{
    FractionBox["1", "\[Kappa]"], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Tanh", "[", 
        RowBox[{"Log", "[", 
         FractionBox["R", "Const"], "]"}], "]"}], "2"]}]]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9783301118015347`*^9, 3.978330182920364*^9}, {
  3.9783302193359118`*^9, 3.978330320711*^9}, {3.978330396647119*^9, 
  3.9783304724143457`*^9}, {3.978330637788574*^9, 3.978330649268416*^9}, {
  3.9783306935323772`*^9, 3.9783307658920507`*^9}, {3.978330991234181*^9, 
  3.978331001017686*^9}, {3.978331277912362*^9, 3.978331311255105*^9}, {
  3.978331379335352*^9, 3.978331390374861*^9}, {3.978331820731887*^9, 
  3.978331839027294*^9}},
 CellLabel->
  "In[218]:=",ExpressionUUID->"b42bc04d-77e6-488b-80e3-6bd8d833e27f"],

