Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tauSchw", "[", 
    RowBox[{"RStart_", ",", " ", "rFinish_"}], "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", " ", "M"}], "]"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rFinish", " ", "RStart", " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"1", "/", "rFinish"}], " ", "-", " ", 
            RowBox[{"1", "/", "RStart"}]}], "]"}]}], " ", "+", " ", 
         RowBox[{
          RowBox[{"RStart", "^", 
           RowBox[{"(", 
            RowBox[{"3", "/", "2"}], ")"}]}], " ", 
          RowBox[{"ArcTan", "[", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"RStart", "/", "rFinish"}], " ", "-", " ", "1"}], "]"}], 
           "]"}]}]}], ")"}]}], " ", "-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"2", " ", "M"}], "]"}]}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"RStart", " ", "RStart", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"1", "/", "RStart"}], " ", "-", " ", 
             RowBox[{"1", "/", "RStart"}]}], "]"}]}], " ", "+", " ", 
          RowBox[{
           RowBox[{"RStart", "^", 
            RowBox[{"(", 
             RowBox[{"3", "/", "2"}], ")"}]}], " ", 
           RowBox[{"ArcTan", "[", 
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"RStart", "/", "RStart"}], " ", "-", " ", "1"}], "]"}], 
            "]"}]}]}], ")"}]}], ")"}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.978269325769779*^9, 3.9782693302099333`*^9}, {
  3.978269364001452*^9, 3.978269367337305*^9}},
