Cell["Final eqn obtained for rbar, more on r on paper in my copy", "Text",
 CellChangeTimes->{{3.978004493639595*^9, 3.9780045120516787`*^9}, {
  3.978268831124888*^9, 
  3.9782688479646893`*^9}},ExpressionUUID->"cf0bda9c-6df4-462c-8876-\
944872679c32"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"eq", " ", "=", " ", 
  RowBox[{"rbar", " ", "==", " ", 
   RowBox[{"C", " ", "*", " ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.978004513351121*^9, 3.978004643198886*^9}, {
  3.9782687601899357`*^9, 3.978268764981827*^9}},
 CellLabel->
  "In[573]:=",ExpressionUUID->"a6d83e4c-41ff-4233-880e-01fdb0663a2b"],

Cell[BoxData[
 RowBox[{"rbar", "\[Equal]", 
  RowBox[{"C", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{"1", "-", 
      SqrtBox[
       RowBox[{"1", "-", 
        RowBox[{
         SuperscriptBox["k", "2"], " ", 
         SuperscriptBox["r", "2"]}]}]]}], 
     RowBox[{"1", "+", 
      SqrtBox[
       RowBox[{"1", "+", 
        RowBox[{
         SuperscriptBox["k", "2"], " ", 
         SuperscriptBox["r", "2"]}]}]]}]]]}]}]], "Output",
 CellChangeTimes->{{3.978004625544403*^9, 3.97800464413841*^9}, {
   3.978079894756591*^9, 3.978079919464169*^9}, 3.9782679356525183`*^9, 
   3.978268595278194*^9, 3.9782686324948378`*^9, {3.9782687616199493`*^9, 
   3.978268766098298*^9}, 3.978268916396501*^9, 3.978269083993701*^9, 
   3.9782695725135927`*^9, 3.9782697232437477`*^9, 3.978269840994905*^9, 
   3.978269950391592*^9, 3.978269999462145*^9},
 CellLabel->
  "Out[573]=",ExpressionUUID->"3e6ba433-98d3-4ede-a11a-9d06c1d162cb"]
}, Open  ]]
}, Open  ]],

