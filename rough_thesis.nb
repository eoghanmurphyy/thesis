944872679c32"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"eq", " ", "=", " ", 
  RowBox[{"rbar", " ", "==", " ", 
   RowBox[{"C", " ", "*", " ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.978004513351121*^9, 3.978004643198886*^9}, {
  3.9782687601899357`*^9, 3.978268764981827*^9}},
 CellLabel->
  "In[421]:=",ExpressionUUID->"a6d83e4c-41ff-4233-880e-01fdb0663a2b"],

Cell[BoxData[
 RowBox[{"rbar", "\[Equal]", 
  RowBox[{"C", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{"1", "-", 
      SqrtBox[
       RowBox[{"1", "-", 
        RowBox[{
         SuperscriptBox["k", "2"], " ", 
         SuperscriptBox["r", "2"]}]}]]}], 
     RowBox[{"1", "+", 
      SqrtBox[
       RowBox[{"1", "+", 
        RowBox[{
         SuperscriptBox["k", "2"], " ", 
         SuperscriptBox["r", "2"]}]}]]}]]]}]}]], "Output",
 CellChangeTimes->{{3.978004625544403*^9, 3.97800464413841*^9}, {
