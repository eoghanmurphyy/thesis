  3.973158361420114*^9}, {3.973158411823929*^9, 3.973158417066166*^9}, {
  3.97833163800502*^9, 3.9783316756127453`*^9}, {3.978333228296906*^9, 
  3.9783332286165457`*^9}},
 CellLabel->
  "In[230]:=",ExpressionUUID->"c4497187-8f71-4164-85a2-e1559df02ac8"],

Cell["Checking if spacetime is regular at rbar = 0 and it is", "Text",
 CellChangeTimes->{{3.9783324902221413`*^9, 
  3.978332501246169*^9}},ExpressionUUID->"2263cc82-57a2-47a6-b006-\
a00e30d5c6be"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ALim0", " ", "=", " ", 
   RowBox[{
    RowBox[{"Limit", "[", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{"AInside", "[", "rbar", "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"rbar", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], ",",
         " ", 
        RowBox[{"rbar", " ", ">", "0"}]}], "]"}], ",", " ", 
      RowBox[{"rbar", "->", "0"}]}], "]"}], " ", "//", " ", "N"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Means", " ", "give", " ", "it", " ", "to", " ", "me", " ", "as", " ", "a",
     " ", "number"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"alphaLim0", " ", "=", " ", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Limit", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Simplify", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"rbar", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], ",",
        " ", 
       RowBox[{"rbar", " ", ">", "0"}]}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"rbar", " ", "->", " ", "0"}]}], "]"}], " ", "//", " ", 
   "N"}]}]}], "Input",
 CellChangeTimes->{{3.968510507921006*^9, 3.968510547883458*^9}, {
