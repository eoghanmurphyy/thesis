944872679c32"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"eq", " ", "=", " ", 
  RowBox[{"rbar", " ", "==", " ", 
   RowBox[{"C", " ", "*", " ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.978004513351121*^9, 3.978004643198886*^9}, {
  3.9782687601899357`*^9, 3.978268764981827*^9}},
 CellLabel->
