        RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
       
       RowBox[{
        RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}]}], "}"}], ",", 
