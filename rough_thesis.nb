 CellChangeTimes->{{3.9783333353033447`*^9, 
  3.9783333529113483`*^9}},ExpressionUUID->"dfa9a1b6-1fde-40fa-b3f2-\
63acf2aa4fbb"],

Cell["Solver goes cuckoo at r = 0 ", "Text",
 CellChangeTimes->{{3.978333435158465*^9, 3.978333448510854*^9}, {
  3.9783515037112007`*^9, 
  3.9783515049264727`*^9}},ExpressionUUID->"937ebd0d-5fe4-4154-b5a7-\
f799e2abe565"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", " ", "=", " ", "2500"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rStop", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "4"}]]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", " ", "=", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], " ", "==", " ", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Center", " ", "velocity", " ", "switch"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"WhenEvent", "[", " ", 
