Cell[CellGroupData[{

Cell["\<\
Checking that the simple solution using the analytic integral and ND solving \
the ODES agree on the same proper time as a function of rbarFinal\
\>", "Subsubsection",
 CellChangeTimes->{{3.978270533803668*^9, 
  3.978270597777411*^9}},ExpressionUUID->"da1a47a7-c44e-4a56-ab59-\
25fcf4beac4c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tauNDSolve", "[", "tf_", "]"}], " ", ":=", " ", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"\[Alpha]", "[", 
        RowBox[{"rbarNum", "[", "t", "]"}], "]"}], "2"], "E0"], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "t0", ",", " ", "tf"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.978270632130148*^9, 3.978270706425108*^9}},
 CellLabel->"In[57]:=",ExpressionUUID->"c556c70d-3bae-4610-9c13-fcea544feb4f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"tauIsotropic", "[", 
      RowBox[{"rbar0", ",", " ", "r"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "rbar0", ",", " ", "rbarStar"}], "}"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Plot", " ", "from", " ", "starting", " ", "r0", " ", "down", " ", 
        "to", " ", "R"}], ",", " ", 
       RowBox[{"as", " ", "r", " ", "decreases"}]}], "*)"}], ",", " ", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], "\[IndentingNewLine]", ",",
    " ", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rbarNum", "[", "tf", "]"}], ",", " ", 
       RowBox[{"tauNDSolve", "[", "tf", "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"tf", ",", " ", "t0", ",", " ", "tEnd"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Dashing", "[", "0.1", "]"}], ",", " ", "Red"}], "}"}]}]}], 
    "]"}], ",", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*OverscriptBox[\(r\), \(_\)]\)\>\"", ",", 
      " ", "\"\<\[Tau](\!\(\*OverscriptBox[\(r\), \(_\)]\))\>\""}], "}"}]}]}],
   "]"}]], "Input",
