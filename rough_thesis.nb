Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", " ", "=", " ", "2300"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rStop", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "5"}]]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", " ", "=", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], " ", "==", " ", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
