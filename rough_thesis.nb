Now to convert the TOV metric to isotropic coords to compute the radial drop.

Solved the differential eqn below and by hand, by hand was better as it was \
copied from the paper.\
\>", "Text",
 CellChangeTimes->{{3.9780028682081327`*^9, 3.978002900997077*^9}, {
  3.97826858266254*^9, 3.9782685832467117`*^9}, {3.978268781685136*^9, 
  3.978268801189144*^9}},ExpressionUUID->"e689ad8f-a9e0-40d6-950e-\
f3a531d1cc3b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"rbar", "[", "r", "]"}], ",", " ", "r"}], "]"}], " ", "==", " ", 
    RowBox[{
     RowBox[{"rbar", "[", "r", "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"r", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{
          RowBox[{"k", "^", "2"}], " ", 
          RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FullSimplify", "[", 
   RowBox[{"DSolve", "[", 
    RowBox[{"eq", ",", " ", "rbar", ",", " ", "r"}], "]"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Different", " ", "answer", " ", "given", " ", "in", " ", "paper", " ", 
    "which", " ", "i", " ", "also", " ", "got"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.978002909394045*^9, 3.978002973068386*^9}, {
   3.978003185454453*^9, 3.9780031899311132`*^9}, 3.9782685931114397`*^9, 
   3.978268640758565*^9, {3.978268693341791*^9, 3.978268701454033*^9}},
 CellLabel->
  "In[175]:=",ExpressionUUID->"03ee603c-2521-45f8-a8d5-059050488102"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"rbar", "\[Rule]", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", "r", "}"}], ",", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         RowBox[{"ArcTanh", "[", 
          SqrtBox[
           RowBox[{"1", "-", 
            RowBox[{
             SuperscriptBox["k", "2"], " ", 
             SuperscriptBox["r", "2"]}]}]], "]"}]}]], " ", 
       TemplateBox[{"1"},
        "C"]}]}], "]"}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{
  3.978002978117202*^9, 3.978003190740634*^9, {3.978079894584607*^9, 
   3.978079919292354*^9}, 3.9782679355801353`*^9, 3.978268595195166*^9, 
   3.9782686324330063`*^9, 3.978268916314539*^9, 3.978269083915392*^9, 
   3.978269572431719*^9, 3.9782697231614437`*^9, 3.978269840910879*^9, 
   3.978269950314336*^9, 3.978269999361349*^9, 3.978329538064712*^9, 
   3.978336368598001*^9, 3.978336997209358*^9, 3.978337212640963*^9, 
   3.97834965212075*^9, 3.9783512541053467`*^9, 3.9783546757199078`*^9, 
   3.978418009990221*^9, 3.9784202519656553`*^9, 3.9784207954218082`*^9, 
   3.978423925671322*^9, 3.978424047686307*^9, 3.9784245713489122`*^9, 
   3.979046707032317*^9, 3.979046868993887*^9, 3.979047424817539*^9, 
