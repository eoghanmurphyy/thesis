      RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", 
     " ", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Alpha]", "[", "rbar", "]"}]}], " ", 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur"}], "]"}], " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
        "rbar", "]"}]}], " ", "+", " ", 
      RowBox[{
       FractionBox[
        SuperscriptBox["ur", "2"], 
        RowBox[{"Ut", "[", 
         RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
       RowBox[{"(", 
        FractionBox[
         RowBox[{
          RowBox[{
           RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", 
          "rbar", "]"}], 
         SuperscriptBox[
          RowBox[{"A", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
