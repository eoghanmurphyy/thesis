Cell["Times:", "Text",
 CellChangeTimes->{{3.978269979988565*^9, 
  3.9782699833747396`*^9}},ExpressionUUID->"9f3f1e63-ef0f-4e2e-afa3-\
439914a4b495"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tSchw", "[", 
    RowBox[{"R_", ",", "rf_"}], "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "1"}], 
       SqrtBox[
        RowBox[{"2", "M"}]]], 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          SqrtBox[
           RowBox[{"1", "-", 
            RowBox[{"2", 
             RowBox[{"M", "/", "R"}]}]}]], 
          SqrtBox[
           RowBox[{
            FractionBox["1", "r"], "-", 
            FractionBox["1", "R"]}]]], 
         FractionBox["1", 
          RowBox[{"1", "-", 
           RowBox[{"2", 
            FractionBox["M", "r"]}]}]]}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "R", ",", "rf"}], "}"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"from", " ", "MTW", " ", "book"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.978329504841354*^9, 3.978329516621935*^9}},
 CellLabel->
  "In[519]:=",ExpressionUUID->"1c3bf085-3755-48c0-955b-5907c63b9e93"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tauSchw", "[", 
    RowBox[{"RStart_", ",", " ", "rFinish_"}], "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", " ", "M"}], "]"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rFinish", " ", "RStart", " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"1", "/", "rFinish"}], " ", "-", " ", 
            RowBox[{"1", "/", "RStart"}]}], "]"}]}], " ", "+", " ", 
         RowBox[{
          RowBox[{"RStart", "^", 
           RowBox[{"(", 
            RowBox[{"3", "/", "2"}], ")"}]}], " ", 
          RowBox[{"ArcTan", "[", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"RStart", "/", "rFinish"}], " ", "-", " ", "1"}], "]"}], 
           "]"}]}]}], ")"}]}], " ", "-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"2", " ", "M"}], "]"}]}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"RStart", " ", "RStart", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"1", "/", "RStart"}], " ", "-", " ", 
             RowBox[{"1", "/", "RStart"}]}], "]"}]}], " ", "+", " ", 
          RowBox[{
           RowBox[{"RStart", "^", 
            RowBox[{"(", 
             RowBox[{"3", "/", "2"}], ")"}]}], " ", 
           RowBox[{"ArcTan", "[", 
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"RStart", "/", "RStart"}], " ", "-", " ", "1"}], "]"}], 
            "]"}]}]}], ")"}]}], ")"}]}]}], "]"}]}], ";"}]], "Input",
