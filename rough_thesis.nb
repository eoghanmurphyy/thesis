 CellLabel->
  "In[442]:=",ExpressionUUID->"6f688a34-476b-4afe-b2ac-9abff13ddf11"],

Cell["\<\
not following 2M part of the notebook as we are dealing with a star, so rEnd \
= 4\
\>", "Text",
 CellChangeTimes->{{3.978264587397623*^9, 
  3.978264609133751*^9}},ExpressionUUID->"a806851d-6c84-4ae4-be76-\
8ed367184cf8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rEnd", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rBarEnd", " ", "=", " ", 
   RowBox[{"rBarSchw", "[", "rEnd", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tEnd", " ", "=", " ", 
   RowBox[{"tSchw", "[", 
    RowBox[{"R0", ",", " ", "RStar"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "  ", "=", " ", 
  RowBox[{
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"drBardt", "[", 
         RowBox[{
          RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
          RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"ur", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"durdt", "[", 
         RowBox[{
          RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
          RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
       
       RowBox[{
        RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"rbar", ",", " ", "ur"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "t0", ",", " ", "tEnd"}], "}"}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.978266713046627*^9, 3.978266715310351*^9}, {
   3.978266777141737*^9, 3.978266785974221*^9}, 3.978266968405346*^9, {
