Cell[BoxData[
 RowBox[{"\n", 
  RowBox[{
   RowBox[{
    RowBox[{"r", "[", "rbar_", "]"}], " ", "=", " ", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", " ", "=", " ", "1"}], "}"}], ",", " ", 
      RowBox[{"rbar", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"M", "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}]}], 
     "]"}]}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "Block", " ", "says", " ", "use", " ", "this", " ", "value", " ", "of", " ",
      "M", " ", "then", " ", "forget", " ", "it"}], "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"rBar", "[", "r_", "]"}], " ", "=", " ", 
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", " ", "=", " ", "1"}], "}"}], ",", " ", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "M"}], " ", "+", " ", "r", " ", "+", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"r", "^", "2"}], " ", "-", " ", 
           RowBox[{"2", " ", "M", " ", "r"}]}], "]"}]}], ")"}]}]}], 
     "]"}]}]}]}]], "Input",
