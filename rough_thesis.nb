Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Ut", "[", 
    RowBox[{"rbar_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Alpha]", "[", "rbar", "]"}]], 
    SqrtBox[
     RowBox[{"1", "+", 
      FractionBox[
       SuperscriptBox["ur", "2"], 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"]]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"drBardt", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"A", "[", "rbar", "]"}], "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]}]], "ur"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]", "[", "rbar", "]"}]}], " ", 
     RowBox[{"Ut", "[", 
      RowBox[{"rbar", ",", " ", "ur"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
      "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "rbar", 
        "]"}], 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "3"]], ")"}]}]}]}], ";"}]}], "Input",\

