Cell[CellGroupData[{

Cell["Doing radial drop pretending to be an observer at infinity", \
"Subsubsection",
 CellChangeTimes->{{3.978259830728229*^9, 3.978259843656719*^9}, {
  3.978269852253587*^9, 
  3.978269852701602*^9}},ExpressionUUID->"74570e1e-1507-4b90-b8a5-\
2750712e4bf9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Ut", "[", 
    RowBox[{"rbar_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Alpha]", "[", "rbar", "]"}]], 
    SqrtBox[
     RowBox[{"1", "+", 
      FractionBox[
       SuperscriptBox["ur", "2"], 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"]]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"drBardt", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"A", "[", "rbar", "]"}], "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]}]], "ur"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]", "[", "rbar", "]"}]}], " ", 
     RowBox[{"Ut", "[", 
      RowBox[{"rbar", ",", " ", "ur"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
      "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "rbar", 
        "]"}], 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "3"]], ")"}]}]}]}], ";"}]}], "Input",\

 CellChangeTimes->{{3.978259861968741*^9, 3.978259868040573*^9}, {
  3.978260022975293*^9, 3.978260040159266*^9}, {3.978260084934874*^9, 
  3.978260124894596*^9}, {3.978264294455785*^9, 3.978264421910756*^9}, {
  3.9782645707981*^9, 3.978264582614053*^9}, {3.978266961813055*^9, 
  3.9782669622129602`*^9}, {3.978270148020853*^9, 3.978270151452063*^9}},
 CellLabel->
  "In[607]:=",ExpressionUUID->"6f688a34-476b-4afe-b2ac-9abff13ddf11"],

Cell["\<\
not following 2M part of the notebook as we are dealing with a star, so rEnd \
= 4\
\>", "Text",
 CellChangeTimes->{{3.978264587397623*^9, 
  3.978264609133751*^9}},ExpressionUUID->"a806851d-6c84-4ae4-be76-\
8ed367184cf8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rEnd", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rBarEnd", " ", "=", " ", 
   RowBox[{"rBarSchw", "[", "rEnd", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tEnd", " ", "=", " ", 
   RowBox[{"tSchw", "[", 
    RowBox[{"R0", ",", " ", "RStar"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "  ", "=", " ", 
  RowBox[{
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"drBardt", "[", 
         RowBox[{
          RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
          RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"ur", "'"}], "[", "t", "]"}], " ", "==", " ", 
        RowBox[{"durdt", "[", 
         RowBox[{
          RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
          RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
       
       RowBox[{
        RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"rbar", ",", " ", "ur"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"t", ",", " ", "t0", ",", " ", "tEnd"}], "}"}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.978266713046627*^9, 3.978266715310351*^9}, {
   3.978266777141737*^9, 3.978266785974221*^9}, 3.978266968405346*^9, {
