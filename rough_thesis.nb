Cell["Lapse and shift functions from metric", "Subsubsection",
 CellChangeTimes->{{3.9783316231888103`*^9, 
  3.9783316301168423`*^9}},ExpressionUUID->"e5eaf4d7-0443-4e38-baf2-\
d7ee1017fdb5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]Inside", "[", "rbar_", "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       FractionBox["3", "2"], 
       SqrtBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], ")"}]]}], "-", 
      RowBox[{
       FractionBox["1", "2"], 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"M", " ", 
            SuperscriptBox["r", "2"]}], 
           SuperscriptBox["RStar", "3"]]}]}]]}]}], ")"}], "/.", 
    RowBox[{"r", "->", 
     RowBox[{"rofRbarInside", "[", "rbar", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AInside", "[", "rbar_", "]"}], "=", 
   FractionBox[
    RowBox[{"rofRbarInside", "[", "rbar", "]"}], "rbar"]}], ";"}]}], "Input",
 CellChangeTimes->{{3.968510507921006*^9, 3.968510547883458*^9}, {
  3.9685105922792187`*^9, 3.968510621455763*^9}, {3.968573085595805*^9, 
  3.968573140792346*^9}, {3.968574515628276*^9, 3.96857455594086*^9}, {
  3.968574589307501*^9, 3.968574625077162*^9}, {3.968574700803419*^9, 
  3.9685747025252743`*^9}, {3.968662972324091*^9, 3.9686629804620047`*^9}, {
