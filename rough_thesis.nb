Cell[BoxData[
 RowBox[{"tSurface", "=", 
  RowBox[{"t", "/.", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"rbarNumIn", "[", "t", "]"}], "==", "rbarStar"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "100", ",", "10", ",", "2300"}], "}"}]}], 
    RowBox[{"(*", 
     RowBox[{"{", 
      RowBox[{"variable", ",", " ", 
       RowBox[{"initial", " ", "guess"}], ",", " ", "tmin", ",", " ", 
       "tmax"}], "}"}], "*)"}], "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "t", " ", "is", " ", "just", " ", "a", " ", "variable", " ", "here"}], ",",
      " ", 
     RowBox[{"this", " ", "returns", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"t", " ", "."}], "/", " ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"t", " ", "->", " ", 
           RowBox[{"X", " ", "seconds"}]}], "}"}], " ", "."}]}], "/", " ", 
       "replaces"}], " ", "all"}], ",", " ", 
     RowBox[{
     "so", " ", "then", " ", "t", " ", "just", " ", "becomes", " ", "the", " ",
       "number", " ", "which", " ", "becomes", " ", "tSurface"}]}], 
