Cell["Or see limit by analysing the series expansion", "Text",
 CellChangeTimes->{{3.978331894882657*^9, 
  3.9783319052504787`*^9}},ExpressionUUID->"8d978d64-1529-4e2e-aa5e-\
d70d4a349362"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"0", " ", "==", " ", 
   RowBox[{"Limit", "[", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{"rBarofrInside", "[", "r", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "0", ",", " ", "1"}], "}"}]}], " ", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "Variable", " ", "we", " ", "are", " ", "expanding", 
           " ", "\"\<r\>\""}], ",", " ", 
          RowBox[{"expand", " ", "about", " ", "\"\<0\>\""}], ",", " ", 
          RowBox[{
          "keep", " ", "terms", " ", "up", " ", "to", " ", "order", 
           " ", "\"\<1\>\""}]}], "*)"}], "]"}], ",", "\[IndentingNewLine]", 
       "\t", 
       RowBox[{"0", " ", "<", " ", "r", " ", "<", " ", "RStar"}]}], 
      "\[IndentingNewLine]", "\t", "]"}], ",", "\[IndentingNewLine]", "\t", 
     RowBox[{"r", "->", "0"}]}], "\[IndentingNewLine]", "\t", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"0", " ", "==", " ", 
  RowBox[{"Limit", "[", "\[IndentingNewLine]", "\t", 
   RowBox[{
    RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"rofRbarInside", "[", "rbar", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"rbar", ",", " ", "0", ",", " ", "1"}], "}"}]}], " ", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Variable", " ", "we", " ", "are", " ", "expanding", 
          " ", "\"\<r\>\""}], ",", " ", 
         RowBox[{"expand", " ", "about", " ", "\"\<0\>\""}], ",", " ", 
         RowBox[{
         "keep", " ", "terms", " ", "up", " ", "to", " ", "order", 
          " ", "\"\<1\>\""}]}], "*)"}], "]"}], ",", "\[IndentingNewLine]", 
      "\t", 
      RowBox[{"rbar", " ", ">", " ", "0"}]}], " ", 
     RowBox[{"(*", "??", "*)"}], "\[IndentingNewLine]", "\t", "]"}], ",", 
    "\[IndentingNewLine]", "\t", 
    RowBox[{"rbar", "->", "0"}]}], "\[IndentingNewLine]", "\t", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.978331910876224*^9, 3.978332021417762*^9}, {
  3.978332059849392*^9, 3.9783321453848963`*^9}, {3.978332268159979*^9, 
  3.978332271800252*^9}},
 CellLabel->
  "In[469]:=",ExpressionUUID->"4d30a7d9-d7aa-4c15-85f8-2ca2ed74cbec"],

