Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"durdtInsideDrag", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}], " ", 
     RowBox[{"UtInside", "[", 
      RowBox[{"rbar", ",", " ", "ur"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]Inside", "]"}], "[",
       "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
        "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    
    RowBox[{
     FractionBox["1", "m"], 
     RowBox[{"(", 
      RowBox[{"dpdtdragr", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.978353916195648*^9, 3.978353954131928*^9}, {
