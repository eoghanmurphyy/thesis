Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"tauIsotropic", "[", 
      RowBox[{"rbar0", ",", " ", "r"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "rbar0", ",", " ", "rbarStar"}], "}"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Plot", " ", "from", " ", "starting", " ", "r0", " ", "down", " ", 
        "to", " ", "R"}], ",", " ", 
       RowBox[{"as", " ", "r", " ", "decreases"}]}], "*)"}], ",", " ", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], "\[IndentingNewLine]", ",",
    " ", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rbarNum", "[", "tf", "]"}], ",", " ", 
       RowBox[{"tauNDSolve", "[", "tf", "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"tf", ",", " ", "t0", ",", " ", "tEnd"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Dashing", "[", "0.1", "]"}], ",", " ", "Red"}], "}"}]}]}], 
    "]"}], ",", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*OverscriptBox[\(r\), \(_\)]\)\>\"", ",", 
