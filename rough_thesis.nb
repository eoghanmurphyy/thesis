f3a531d1cc3b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"rbar", "[", "r", "]"}], ",", " ", "r"}], "]"}], " ", "==", " ", 
    RowBox[{
     RowBox[{"rbar", "[", "r", "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"r", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{
          RowBox[{"k", "^", "2"}], " ", 
          RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FullSimplify", "[", 
   RowBox[{"DSolve", "[", 
    RowBox[{"eq", ",", " ", "rbar", ",", " ", "r"}], "]"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Different", " ", "answer", " ", "given", " ", "in", " ", "paper", " ", 
    "which", " ", "i", " ", "also", " ", "got"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.978002909394045*^9, 3.978002973068386*^9}, {
   3.978003185454453*^9, 3.9780031899311132`*^9}, 3.9782685931114397`*^9, 
