       FractionBox[
        SuperscriptBox["uphi", "2"], 
        RowBox[{"Ut", "[", 
         RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
       RowBox[{"(", 
        RowBox[{
         FractionBox["1", 
          RowBox[{
           SuperscriptBox["rbar", "3"], " ", "*", 
           SuperscriptBox[
            RowBox[{"A", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
         FractionBox[
          RowBox[{
           RowBox[{
            RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", 
           "rbar", "]"}], 
          RowBox[{
           SuperscriptBox["rbar", "2"], "*", 
           SuperscriptBox[
            RowBox[{"A", "[", "rbar", "]"}], "3"]}]]}], ")"}]}]}]}], 
    ";"}]}]}]], "Input",
