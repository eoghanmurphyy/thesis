Cell[BoxData[
 RowBox[{"solIn", "=", 
  RowBox[{
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"Piecewise", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"drBardtInside", "[", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
               RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
             RowBox[{
              RowBox[{"r", "[", "t", "]"}], "<=", "rbarStar"}]}], "}"}], ",", 
           
           RowBox[{"{", 
            RowBox[{
             RowBox[{"drBardt", "[", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
               RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
             RowBox[{
              RowBox[{"r", "[", "t", "]"}], ">", "rbarStar"}]}], "}"}]}], 
          "}"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"ur", "'"}], "[", "t", "]"}], "==", 
        RowBox[{"Piecewise", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"durdtInside", "[", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
               RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
             RowBox[{
              RowBox[{"r", "[", "t", "]"}], "<=", "rbarStar"}]}], "}"}], ",", 
           
           RowBox[{"{", 
            RowBox[{
             RowBox[{"durdt", "[", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
               RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
             RowBox[{
              RowBox[{"r", "[", "t", "]"}], ">", "rbarStar"}]}], "}"}]}], 
          "}"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"r", "[", "0", "]"}], "==", "rbar0"}], ",", 
       RowBox[{
        RowBox[{"ur", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "ur"}], "}"}], ",", 
