 RowBox[{
  RowBox[{"ALim0", " ", "=", " ", 
   RowBox[{
    RowBox[{"Limit", "[", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"Series", "[", 
