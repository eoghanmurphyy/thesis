              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}], ",", " ", 
        RowBox[{"WhenEvent", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"rbar", "[", "t", "]"}], " ", "==", " ", "rStop"}], ",", 
          " ", 
          RowBox[{
           RowBox[{"ur", "[", "t", "]"}], " ", "->", " ", 
