Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", " ", "=", " ", "2300"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rStop", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "5"}]]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", " ", "=", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], " ", "==", " ", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdtInsideDrag", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}], ",", " ", 
        RowBox[{"WhenEvent", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"rbar", "[", "t", "]"}], " ", "==", " ", "rStop"}], ",", 
          " ", 
          RowBox[{
           RowBox[{"ur", "[", "t", "]"}], " ", "->", " ", 
           RowBox[{"-", 
            RowBox[{"ur", "[", "t", "]"}]}]}]}], "]"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"rbar", ",", " ", "ur"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "t0", ",", " ", "tEnd"}], "}"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
