         RowBox[{"rBarofrInside", "[", "r", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "0", ",", " ", "1"}], "}"}]}], " ", 
        RowBox[{"(*", 
