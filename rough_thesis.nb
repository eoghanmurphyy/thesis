              RowBox[{"durdtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
        RowBox[{
