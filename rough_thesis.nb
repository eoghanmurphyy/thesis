      RowBox[{"Abs", "[", "ur", "]"}], 
      RowBox[{"AInside", "[", "rbar", "]"}]]}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"P", "[", "rbar_", "]"}], " ", "=", " ", 
     RowBox[{
      RowBox[{"\[Rho]", 
       RowBox[{"(", 
