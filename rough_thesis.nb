Cell["\<\
Defining the Isotropic metric components for external Schw SpaceTime\
\>", "Text",
 CellChangeTimes->{{3.978080680202964*^9, 
  3.978080698553022*^9}},ExpressionUUID->"f190c2a7-9ba7-44ab-8e9c-\
25bdd3faaa3c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}]}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.978080703602681*^9, 3.9780808115943537`*^9}},
 CellLabel->
  "In[138]:=",ExpressionUUID->"b5a7a50c-0a23-4252-a9b4-2db657c992b0"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"M", ",", " ", "R", ",", " ", "r"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tauSchw", "[", 
    RowBox[{"rFinish_", ",", " ", "RStart_"}], "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", " ", "M"}], "]"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rFinish", " ", "RStart", " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"1", "/", "rFinish"}], " ", "-", " ", 
            RowBox[{"1", "/", "RStart"}]}], "]"}]}], " ", "+", " ", 
         RowBox[{
          RowBox[{"RStart", "^", 
           RowBox[{"(", 
            RowBox[{"3", "/", "2"}], ")"}]}], " ", 
          RowBox[{"ArcTan", "[", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"RStart", "/", "rFinish"}], " ", "-", " ", "1"}], "]"}], 
           "]"}]}]}], ")"}]}], " ", "-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"2", " ", "M"}], "]"}]}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"RStart", " ", "RStart", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"1", "/", "RStart"}], " ", "-", " ", 
             RowBox[{"1", "/", "RStart"}]}], "]"}]}], " ", "+", " ", 
          RowBox[{
           RowBox[{"RStart", "^", 
            RowBox[{"(", 
             RowBox[{"3", "/", "2"}], ")"}]}], " ", 
           RowBox[{"ArcTan", "[", 
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"RStart", "/", "RStart"}], " ", "-", " ", "1"}], "]"}], 
            "]"}]}]}], ")"}]}], ")"}]}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9780842964272547`*^9, 3.9780843087377462`*^9}, {
  3.97808436399194*^9, 3.978084596051601*^9}, {3.9780846297190733`*^9, 
