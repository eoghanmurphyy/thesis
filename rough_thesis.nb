Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"D", "[", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{
      RowBox[{"Tanh", "[", "x", "]"}], "^", "2"}]}], ",", "x"}], "]"}], " ", 
