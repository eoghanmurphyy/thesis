  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"dphidtOutside", "[", 
      RowBox[{"rbar_", ",", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", " ", 
     
     RowBox[{
      FractionBox["1", 
       RowBox[{
        SuperscriptBox["rbar", "2"], "*", 
        SuperscriptBox[
         RowBox[{"A", "[", "rbar", "]"}], "2"], "*", 
        RowBox[{"Ut", "[", 
         RowBox[{"rbar", ",", " ", "ur"}], "]"}]}]], "uphi"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
