Cell[BoxData[
 RowBox[{"eq", " ", "=", " ", 
  RowBox[{"rbar", " ", "==", " ", 
   RowBox[{"C", " ", "*", " ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{
           RowBox[{"k", "^", "2"}], " ", 
           RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}], 
     "]"}]}]}]}]], "Input",
