Cell["\<\
Now to convert the TOV metric to isotropic coords to compute the radial drop.

Solved the differential eqn below and by hand, by hand was better as it was \
copied from the paper.\
\>", "Text",
 CellChangeTimes->{{3.9780028682081327`*^9, 3.978002900997077*^9}, {
  3.97826858266254*^9, 3.9782685832467117`*^9}, {3.978268781685136*^9, 
  3.978268801189144*^9}},ExpressionUUID->"e689ad8f-a9e0-40d6-950e-\
f3a531d1cc3b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"rbar", "[", "r", "]"}], ",", " ", "r"}], "]"}], " ", "==", " ", 
    RowBox[{
     RowBox[{"rbar", "[", "r", "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"r", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{
          RowBox[{"k", "^", "2"}], " ", 
          RowBox[{"r", "^", "2"}]}]}], "]"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FullSimplify", "[", 
   RowBox[{"DSolve", "[", 
    RowBox[{"eq", ",", " ", "rbar", ",", " ", "r"}], "]"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Different", " ", "answer", " ", "given", " ", "in", " ", "paper", " ", 
    "which", " ", "i", " ", "also", " ", "got"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.978002909394045*^9, 3.978002973068386*^9}, {
   3.978003185454453*^9, 3.9780031899311132`*^9}, 3.9782685931114397`*^9, 
