 RowBox[{
  RowBox[{"solIn", " ", "=", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
