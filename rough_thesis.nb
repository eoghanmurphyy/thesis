    RowBox[{"Ivariable", " ", "=", " ", "10"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"??", "?"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", "1000"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Speed", " ", "up", " ", "parameter"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Rho]", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
