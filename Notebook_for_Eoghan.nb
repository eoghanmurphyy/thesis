Cell[CellGroupData[{

Cell["Lapse and shift", "Subsection",
 CellChangeTimes->{{3.968574495586829*^9, 
  3.968574497899808*^9}},ExpressionUUID->"eef29698-0f77-4d8a-a410-\
905bc17bfca5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]Inside", "[", "R_", "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       FractionBox["3", "2"], 
       SqrtBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["Mst", "Rst"]}]}], ")"}]]}], "-", 
      RowBox[{
       FractionBox["1", "2"], 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mst", " ", 
            SuperscriptBox["r", "2"]}], 
           SuperscriptBox["Rst", "3"]]}]}]]}]}], ")"}], "/.", 
    RowBox[{"r", "->", 
     RowBox[{"rofRbarInside", "[", "R", "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ainside", "[", "R_", "]"}], "=", 
    FractionBox[
     RowBox[{"rofRbarInside", "[", "R", "]"}], "R"]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     StyleBox["CHECK",
      FontColor->RGBColor[1, 0, 0]], " ", "that", " ", "the", " ", 
     "spacetime", " ", "is", " ", "regular", " ", "at", " ", "R"}], "=", " ", 
    "0"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"\[Alpha]Lim0", "=", 
  RowBox[{
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{"Ainside", "[", "R", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"R", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
       RowBox[{"R", ">", "0"}]}], "]"}], ",", 
     RowBox[{"R", "->", "0"}]}], "]"}], "//", 
   "N"}]}], "\[IndentingNewLine]", 
 RowBox[{"ALim0", "=", 
  RowBox[{
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{"\[Alpha]Inside", "[", "R", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"R", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
       RowBox[{"R", ">", "0"}]}], "]"}], ",", 
     RowBox[{"R", "->", "0"}]}], "]"}], "//", "N"}]}]}], "Input",
 CellChangeTimes->{{3.968510507921006*^9, 3.968510547883458*^9}, {
