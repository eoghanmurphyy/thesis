Cell[TextData[{
 "% is the symbol for the most recent output, in this case  ",
 Cell[BoxData[
  RowBox[{"M", "+", 
   FractionBox[
    SuperscriptBox["M", "2"], 
    RowBox[{"4", " ", "R"}]], "+", "R"}]], "Output",
  CellChangeTimes->{{3.973151912945882*^9, 3.973151927855679*^9}, 
    3.973151968138049*^9},ExpressionUUID->
  "7f5719f6-6640-459c-bd58-a427f24df62e"],
 ", %% is the on before it. You can also use numbers like %2, %3 but the \
numbering follows a different rule (evaluations since you started a Kernel)"
}], "Text",
 CellChangeTimes->{{3.97315197404712*^9, 3.9731520301096582`*^9}, {
  3.9731520792979937`*^9, 
  3.9731520991569567`*^9}},ExpressionUUID->"c1614b9e-dd09-4b9e-8507-\
a463d2429852"],

Cell["\<\
We get two solutions, pick the correct one by looking at the Limit of R/r at \
infinity\
\>", "Text",
 CellChangeTimes->{{3.973152229561277*^9, 3.973152234264081*^9}, {
  3.973152380437665*^9, 
  3.9731523934815397`*^9}},ExpressionUUID->"a19e5245-5b6f-40b9-8b30-\
f791c5a9a2e2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Rsol", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"r", "==", "%"}], ",", "R"}], "]"}]}]], "Input",
