 CellChangeTimes->{{3.973152981697084*^9, 3.973152991469295*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"989c0ed8-f219-4843-abd0-42d538a23175"],

Cell["\<\
Convert r=20M and r=2M to isotropic coordinate rBar,  written as R when the \
argument of a function \
\>", "Text",
 CellChangeTimes->{{3.973153013815333*^9, 3.973153031228598*^9}, {
  3.973153257616907*^9, 
  3.973153273442374*^9}},ExpressionUUID->"6410b050-c1db-4982-94cd-\
89be484240e4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rofRbar", "[", "R_", "]"}], "=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     FractionBox[
      RowBox[{
       SuperscriptBox["M", "2"], "+", 
       RowBox[{"4", " ", "M", " ", "R"}], "+", 
       RowBox[{"4", " ", 
        SuperscriptBox["R", "2"]}]}], 
      RowBox[{"4", " ", "R"}]]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rBarofr", "[", "r_", "]"}], "=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "M"}], "+", "r", "+", 
        SqrtBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "2"}], " ", "M", " ", "r"}], "+", 
          SuperscriptBox["r", "2"]}]]}], ")"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rbar0", "=", 
   RowBox[{"rBarofr", "[", "R0", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rBarEH", "=", 
   RowBox[{"rBarofr", "[", "2", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.968339232927403*^9, 3.9683393001764708`*^9}, 
   3.9683393309653463`*^9, {3.968339960666769*^9, 3.968339981757739*^9}, {
   3.9683838408120327`*^9, 3.968383852699059*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"e74a05fa-5878-4ede-b9b1-c08e29b56f7f"],

Cell["Check limits at Infty and horizon (r=2M)", "Text",
