Cell[CellGroupData[{

Cell["\<\
Proper times calculated in either coord. system should match! \
\>", "Subsection",
 CellChangeTimes->{{3.968383924347587*^9, 3.9683839369456797`*^9}, 
   3.9731533159964247`*^9},ExpressionUUID->"c0603994-ae14-470e-b327-\
666a23d02241"],

Cell["\<\
Set delay := only evaluates something when it\[CloseCurlyQuote]s called. The \
Schwarzschild result is the analytical solution from the MTW textbook\
\>", "Text",
 CellChangeTimes->{{3.973153404847673*^9, 3.973153417401107*^9}, {
  3.973153559140954*^9, 
  3.973153581555278*^9}},ExpressionUUID->"a9088459-ab3f-49f1-818d-\
2128f665022b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tSch", "[", 
    RowBox[{"R_", ",", "rf_"}], "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "1"}], 
       SqrtBox[
        RowBox[{"2", "M"}]]], 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{
         FractionBox[
          SqrtBox[
           RowBox[{"1", "-", 
            RowBox[{"2", 
             RowBox[{"M", "/", "R"}]}]}]], 
          SqrtBox[
           RowBox[{
            FractionBox["1", "r"], "-", 
            FractionBox["1", "R"]}]]], 
         FractionBox["1", 
          RowBox[{"1", "-", 
           RowBox[{"2", 
            FractionBox["M", "r"]}]}]]}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "R", ",", "rf"}], "}"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Tau]Sch", "[", 
    RowBox[{"R_", ",", "r_"}], "]"}], "=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "1"}], 
       SqrtBox[
        RowBox[{"2", "M"}]]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "r"}], " ", 
         SqrtBox[
          RowBox[{
           FractionBox["1", "r"], "-", 
           FractionBox["1", "R"]}]], " ", "R"}], "-", 
        RowBox[{
         SuperscriptBox["R", 
          RowBox[{"3", "/", "2"}]], " ", 
         RowBox[{"ArcTan", "[", 
          RowBox[{
           SqrtBox[
            RowBox[{
             FractionBox["1", "r"], "-", 
             FractionBox["1", "R"]}]], " ", 
           SqrtBox["R"]}], "]"}]}]}], ")"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Tau]Isotropic", "[", 
   RowBox[{"r0_", ",", "r_"}], "]"}], ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Urdrop", "[", "R", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"R", ",", "r0", ",", "r"}], "}"}], ",", 
    RowBox[{"WorkingPrecision", "->", "40"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.968383742005087*^9, 3.968383809819488*^9}, {
  3.9683839091017103`*^9, 3.968383911652955*^9}, {3.968384356397997*^9, 
  3.968384367191753*^9}, {3.9731533849503317`*^9, 3.973153395056559*^9}, {
  3.973153638350754*^9, 3.973153641250354*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"01e04018-fca9-438e-9f83-c5fed70ee107"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"NumericQ", "@", 
  RowBox[{"\[Tau]Isotropic", "[", 
   RowBox[{"Rbar0", ",", "rBarEH"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<\!\(\*StyleBox[\"CHECK\",FontColor->RGBColor[1, 0, 0]]\) \
proper time equality: \>\"", ",", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"1", "-", 
      RowBox[{
       RowBox[{"\[Tau]Sch", "[", 
        RowBox[{"20", ",", "2"}], "]"}], "/", 
       RowBox[{"\[Tau]Isotropic", "[", 
        RowBox[{"Rbar0", ",", "rBarEH"}], "]"}]}]}], "]"}], "<", 
