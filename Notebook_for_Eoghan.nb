   3.968599112240411*^9, 3.968662404879068*^9, 3.968683317534204*^9, {
   3.973158097043777*^9, 3.973158138250801*^9}, 3.973159835925106*^9},
 CellLabel->"Out[60]=",ExpressionUUID->"bec575ce-5b63-4b78-930f-97b37587794e"]
