Cell[CellGroupData[{

Cell["The constant density inner solution", "Chapter",
 CellChangeTimes->{{3.968402585312684*^9, 
  3.968402591610818*^9}},ExpressionUUID->"6880a38e-a2df-46a6-85b6-\
107135fdbe7c"],

Cell[CellGroupData[{

Cell["Set up the metric and the coord. transformation", "Section",
 CellChangeTimes->{{3.968572682117607*^9, 
  3.968572690421739*^9}},ExpressionUUID->"715ece0b-af33-4f84-8f36-\
546ab132144c"],

Cell["\<\
Remember the mass sets the entire scale for the spacetime so easiest thing to \
do is setting it to one. Accordingly, we must pick a star radius which can be \
anything as long as it is greater than 2M (Sch. black hole radius). For a \
neutron star, R*=5M is reasonable.\
\>", "Text",
 CellChangeTimes->{{3.973157949570047*^9, 
  3.973158018696262*^9}},ExpressionUUID->"593b1fc7-dfc6-4422-94b1-\
adddc32236f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Mst", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rst", "=", "5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.968511780405604*^9, 3.9685117917144117`*^9}, {
  3.973158046912839*^9, 3.9731580492894573`*^9}},
 CellLabel->"In[51]:=",ExpressionUUID->"e2a99631-c609-4857-b453-806414798bdf"],

Cell[CellGroupData[{

Cell["Interior solution functions", "Subsection",
 CellChangeTimes->{{3.9731580291011*^9, 
  3.973158033744577*^9}},ExpressionUUID->"cd486a71-62c9-472c-8e5c-\
bde7eb43461b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"M", "[", "r_", "]"}], "=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Mst", " ", 
         FractionBox[
          SuperscriptBox["r", "3"], 
          SuperscriptBox["Rst", "3"]]}], ",", 
        RowBox[{"r", "<=", "Rst"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Mst", ",", 
        RowBox[{"r", ">", "Rst"}]}], "}"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"grrIn", "[", "r_", "]"}], "=", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"2", 
       FractionBox[
        RowBox[{"M", "[", "r", "]"}], "r"]}]}], ")"}], 
    RowBox[{"-", "1"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Kappa]", "=", 
    SqrtBox[
     RowBox[{"2", 
      FractionBox["Mst", 
       SuperscriptBox["Rst", "3"]]}]]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"Integration", " ", "constant"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Cc", "=", 
   RowBox[{
    RowBox[{"rBarofr", "[", "Rst", "]"}], 
    SqrtBox[
     FractionBox[
      RowBox[{"1", "+", 
       SqrtBox[
        RowBox[{"1", "-", 
         FractionBox[
          RowBox[{"2", "Mst"}], "Rst"]}]]}], 
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox["Mst", "Rst"]}]}]]}]]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rBarofrInside", "[", "r_", "]"}], "=", 
   RowBox[{"Cc", " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"M", "[", "r", "]"}], "r"]}]}]]}], 
      RowBox[{"1", "+", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"M", "[", "r", "]"}], "r"]}]}]]}]]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rofRbarInside", "[", "R_", "]"}], "=", 
   RowBox[{
    FractionBox["1", "\[Kappa]"], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Tanh", "[", 
        RowBox[{"Log", "[", 
         FractionBox["R", "Cc"], "]"}], "]"}], "2"]}]]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.968424696899384*^9, 3.968424709148704*^9}, {
  3.9684247642234173`*^9, 3.968424801238613*^9}, {3.968424846420388*^9, 
  3.9684249916521263`*^9}, {3.968425163783038*^9, 3.968425174609316*^9}, {
  3.9685099795731783`*^9, 3.96850998773483*^9}, {3.968510032009472*^9, 
  3.96851017276581*^9}, {3.968510317817713*^9, 3.968510384045863*^9}, {
  3.9685730685596323`*^9, 3.968573073233075*^9}, {3.968573113035561*^9, 
  3.968573113982511*^9}, {3.9731580664312677`*^9, 3.9731580750331373`*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"a70af115-30f7-462d-ba41-687b7f9a8a05"],

Cell["\<\
Check that the inside/outside transformations agree on the surface\
\>", "Text",
 CellChangeTimes->{
  3.9731580892042923`*^9},ExpressionUUID->"82f37fb0-fe3a-47e2-848a-\
8306a150d0c2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"RbarSt", "=", 
   RowBox[{"rBarofr", "[", "Rst", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"RstVal", "==", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"rofRbarInside", "[", "%", "]"}], "/.", 
     RowBox[{"Mst", "->", "Mst"}]}], "/.", 
    RowBox[{"Rst", "->", "Rst"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9685101749788227`*^9, 3.968510266569407*^9}, {
  3.968510369472135*^9, 3.968510432119912*^9}, {3.968511797123575*^9, 
  3.9685118138558693`*^9}, {3.968572885907608*^9, 3.9685729540560627`*^9}, {
  3.968599096206883*^9, 3.9685991042566547`*^9}, {3.973158083333727*^9, 
  3.973158137684317*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"564e5ab7-e691-410a-8038-54ae895098be"],

Cell[BoxData[
 RowBox[{"RstVal", "\[Equal]", "5.`"}]], "Output",
 CellChangeTimes->{{3.96851017998989*^9, 3.968510225284298*^9}, 
   3.968510267024688*^9, {3.96851037800121*^9, 3.968510405413932*^9}, 
