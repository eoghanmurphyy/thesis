Cell["Get the time where the \[OpenCurlyDoubleQuote]crash\
\[CloseCurlyDoubleQuote] occurs", "Text",
 CellChangeTimes->{{3.973159158718896*^9, 
  3.9731591751265593`*^9}},ExpressionUUID->"40ebe9b5-815a-470e-9ccd-\
a8c0a50b72d8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"tCentralCrossing", "=", 
   RowBox[{
    RowBox[{"rNumIn", "[", "\"\<Domain\>\"", "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Get", " ", "the", " ", "surface", " ", "crossing", " ", "time", " ", 
    "for", " ", "plots"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"tSurface", "=", 
  RowBox[{"t", "/.", 
   RowBox[{"FindRoot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"rNumIn", "[", "t", "]"}], "==", "RbarSt"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "10", ",", "10", ",", "tCentralCrossing"}], "}"}]}], 
    "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.968682613770103*^9, 3.968682667050261*^9}, {
