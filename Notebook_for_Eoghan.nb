Cell[CellGroupData[{

Cell["Metric functions in isotropic coordinates", "Subsection",
 CellChangeTimes->{{3.973153069598733*^9, 
  3.973153081729889*^9}},ExpressionUUID->"702b9972-64b7-4a53-bbd3-\
d0b079bac8bd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "R_", "]"}], "=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", 
        FractionBox["M", 
         RowBox[{"2", "R"}]]}], ")"}], "2"]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]", "[", "R_", "]"}], "=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", 
     FractionBox[
      RowBox[{"1", "-", 
       FractionBox["M", 
        RowBox[{"2", "R"}]]}], 
      RowBox[{"1", "+", 
       FractionBox["M", 
        RowBox[{"2", "R"}]]}]]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.968339743899913*^9, 3.968339949538521*^9}, {
  3.968340003109964*^9, 3.968340043686717*^9}, {3.968340075322187*^9, 
  3.9683401088342857`*^9}, {3.9683401595508757`*^9, 3.968340186814144*^9}, {
  3.9683402680746403`*^9, 3.96834027621273*^9}, {3.968383211458456*^9, 
  3.968383219840745*^9}, {3.968385309969728*^9, 3.9683853115904293`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"e81e5931-516b-4429-bec7-85bd8552d74b"],

Cell[TextData[{
 "At r=R0 <---> ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],ExpressionUUID->
  "2b8e47a3-90fe-4bf2-8126-fb92f4299f5a"],
 "= ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["R", "_"], TraditionalForm]],ExpressionUUID->
  "30e74818-bc5a-4768-a022-3c42cd686c36"],
 "0 we have ur = 0 (the drop problem). I have {x,x\[CloseCurlyQuote]} ODEs, \
ie. \\dot{x}=ODE1, \\ddot{x} = ODE2, specifically {\\dot{",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],ExpressionUUID->
  "bd327734-1b15-4af0-8e6f-6494bcd2c050"],
 "}, \\dot{ur}} system"
}], "Text",
