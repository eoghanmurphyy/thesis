Cell[CellGroupData[{

Cell["Radial drop via NDSolving  Eqs. (25a, 25b) of 2404.08735", "Subsection",
 CellChangeTimes->{{3.96838533807421*^9, 
  3.968385374239368*^9}},ExpressionUUID->"84b63c22-6593-4e2f-8bd2-\
a60f7c030bd0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Ut", "[", 
    RowBox[{"R_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Alpha]", "[", "R", "]"}]], 
    SqrtBox[
     RowBox[{"1", "+", 
      FractionBox[
       SuperscriptBox["ur", "2"], 
       SuperscriptBox[
        RowBox[{"A", "[", "R", "]"}], "2"]]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"drBardt", "[", 
    RowBox[{"R_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"A", "[", "R", "]"}], "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"R", ",", "ur"}], "]"}]}]], "ur"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt", "[", 
    RowBox[{"R_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]", "[", "R", "]"}]}], 
     RowBox[{"Ut", "[", 
      RowBox[{"R", ",", "ur"}], "]"}], 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
      "R", "]"}]}], "+", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"R", ",", "ur"}], "]"}]], 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "R", 
       "]"}], 
      SuperscriptBox[
       RowBox[{"A", "[", "R", "]"}], "3"]]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.968385388606235*^9, 3.968385399889524*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"724197b5-ea78-45df-b421-54d874500e97"],

Cell[TextData[{
 "We set the start time to t0 = 0. The end time is tricky, if we pick \
something too large the ODE solver might get stuck trying to solve inside the \
black hole where we have no information at this point. So we use the \
analytical Sch. coordinate time t drop time to guide us. Note that t \[Rule]\
\[Infinity]  as r\[Rule]2M so we pick rEnd=2.01, and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "82f754fe-ed82-4d6f-850b-41c3f849bd65"],
 " accordingly."
}], "Text",
 CellChangeTimes->{{3.973153651498003*^9, 
  3.973153754433127*^9}},ExpressionUUID->"7ab37d0c-fd71-4c45-9688-\
921f1a710c53"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rEnd", "=", "2.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rBarEnd", "=", 
   RowBox[{"rBarofr", "[", "rEnd", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tEnd", "=", 
   RowBox[{"tSch", "[", 
    RowBox[{"R0", ",", "rEnd"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
         RowBox[{"drBardt", "[", 
          RowBox[{
           RowBox[{"r", "[", "t", "]"}], ",", 
           RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], "==", 
         RowBox[{"durdt", "[", 
          RowBox[{
           RowBox[{"r", "[", "t", "]"}], ",", 
           RowBox[{"ur", "[", "t", "]"}]}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"r", "[", "0", "]"}], "==", "Rbar0"}], ",", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "ur"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "t0", ",", "tEnd"}], "}"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rNum", "=", 
   RowBox[{"r", "/.", "sol"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"urNum", "=", 
   RowBox[{"ur", "/.", "sol"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.968385458281145*^9, 3.968385460717524*^9}, {
   3.968385499374179*^9, 3.968385613284844*^9}, 3.968385672086113*^9, {
   3.9683863105644293`*^9, 3.9683863712691*^9}, {3.968401416460413*^9, 
   3.968401431736992*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"f29f0822-3ca0-4465-88db-8cdefb8b3ffb"],

Cell["Plot the solutions r(t) and ur(t)", "Text",
 CellChangeTimes->{{3.9731537692173023`*^9, 
  3.973153780074339*^9}},ExpressionUUID->"eb063bd7-64ea-43cb-86b9-\
9dd59e15150c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rNum", "[", "t", "]"}], ",", 
     RowBox[{"urNum", "[", "t", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "t0", ",", "tEnd"}], "}"}]}], "]"}]], "Input",
