Cell[CellGroupData[{

Cell["Construct the ODEs for the interior solution", "Subsection",
 CellChangeTimes->{{3.973158365657248*^9, 
  3.973158375735704*^9}},ExpressionUUID->"d288cfac-f17b-44df-b5bc-\
78f28ec46d0c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"UtInside", "[", 
    RowBox[{"R_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Alpha]Inside", "[", "R", "]"}]], 
    SqrtBox[
     RowBox[{"1", "+", 
      FractionBox[
       SuperscriptBox["ur", "2"], 
       SuperscriptBox[
        RowBox[{"Ainside", "[", "R", "]"}], "2"]]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"drBardtInside", "[", 
    RowBox[{"R_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"Ainside", "[", "R", "]"}], "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"R", ",", "ur"}], "]"}]}]], "ur"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdtInside", "[", 
    RowBox[{"R_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "R", "]"}]}], 
     RowBox[{"UtInside", "[", 
      RowBox[{"R", ",", "ur"}], "]"}], 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]Inside", "]"}], "[",
       "R", "]"}]}], "+", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"R", ",", "ur"}], "]"}]], 
     FractionBox[
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "1", "]"}], "[", "Ainside", "]"}], "[", 
       "R", "]"}], 
      SuperscriptBox[
       RowBox[{"Ainside", "[", "R", "]"}], "3"]]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.973158351860127*^9, 3.973158356745811*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"0fa205fc-951b-4b67-8f6c-e63db2d6d13a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solve the ODEs for the infalling ``leg\[CloseCurlyQuote]\
\[CloseCurlyQuote]", "Section",
 CellChangeTimes->{{3.968663069235688*^9, 3.968663085822163*^9}, {
  3.968663376751039*^9, 3.968663401117983*^9}, {3.968681596343651*^9, 
  3.968681640341058*^9}},ExpressionUUID->"f8ac8126-de1e-4c9d-9212-\
00b3b36661ab"],

Cell["The solver bails at r=0+\[Epsilon], \[Epsilon]<<1", "Text",
 CellChangeTimes->{{3.968681648230007*^9, 
  3.968681674597333*^9}},ExpressionUUID->"6db40762-01c9-4b92-874b-\
97386e4b52ab"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tEnd", "=", "200"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"r", "'"}], "[", "t", "]"}], "==", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardtInside", "[", 
               RowBox[{
                RowBox[{"Abs", "[", 
                 RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"r", "[", "t", "]"}], "<=", "RbarSt"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"Abs", "[", 
                 RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"r", "[", "t", "]"}], ">", "RbarSt"}]}], "}"}]}], 
           "}"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], "==", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdtInside", "[", 
               RowBox[{
                RowBox[{"Abs", "[", 
                 RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"r", "[", "t", "]"}], "<=", "RbarSt"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt", "[", 
               RowBox[{
                RowBox[{"Abs", "[", 
                 RowBox[{"r", "[", "t", "]"}], "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"r", "[", "t", "]"}], ">", "RbarSt"}]}], "}"}]}], 
           "}"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"r", "[", "0", "]"}], "==", "Rbar0"}], ",", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", "ur"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "t0", ",", "tEnd"}], "}"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rNumIn", "=", 
   RowBox[{"r", "/.", "solIn"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"urNumIn", "=", 
   RowBox[{"ur", "/.", "solIn"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.968680677846011*^9, 3.968680735923402*^9}, 
   3.9686817745947933`*^9, {3.973158539819975*^9, 3.973158544130025*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"97c3a5d4-6c97-4a8e-a923-42b76f3a00ee"],

Cell[BoxData[
 TemplateBox[{
  "NDSolve", "ndsz", 
   "\"At \\!\\(\\*RowBox[{\\\"t\\\"}]\\) == \
\\!\\(\\*RowBox[{\\\"115.54331098797681`\\\"}]\\), step size is effectively \
zero; singularity or stiff system suspected.\"", 2, 75, 3, 
