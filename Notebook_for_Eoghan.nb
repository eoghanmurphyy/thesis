     RowBox[{"-", "16"}]]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.96838381698069*^9, 3.968383826577582*^9}, {
  3.968383862238208*^9, 3.968383986560354*^9}, {3.968384535163228*^9, 
