Cell[CellGroupData[{

Cell["Exterior coordinate transformation", "Section",
 CellChangeTimes->{{3.973151839904791*^9, 
  3.973151850290588*^9}},ExpressionUUID->"76a3b97d-102d-4f16-b7f3-\
72c80c48ec0e"],

Cell[TextData[{
 "Here R is ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "61d35061-208f-46ed-857d-10e4d8dc5944"],
 " of the hand-written notes. OVerbar is written by highlighting the variable \
(in this case r) then hitting Ctrl+7"
}], "Text",
 CellChangeTimes->{{3.973152128589281*^9, 
  3.9731522128412952`*^9}},ExpressionUUID->"47d86be5-007f-4987-a120-\
60ac10785795"],

Cell[CellGroupData[{

Cell[TextData[{
 "Choosing: ",
 Cell[BoxData[
  RowBox[{"\[Integral]", 
   RowBox[{
    SuperscriptBox["R", 
     RowBox[{"-", "1"}]], 
    RowBox[{"\[DifferentialD]", "R"}]}]}]],ExpressionUUID->
  "958e1ae0-f4b5-4e6b-b6f2-0eb03d3cf251"],
 " = log[2R/M] yields R \[Rule] r as r \[Rule] \[Infinity]"
}], "Subsection",
 CellChangeTimes->{{3.967736627682164*^9, 3.967736691433547*^9}, {
  3.9677369779812307`*^9, 3.967737007138155*^9}, {3.967737153774251*^9, 
  3.967737156410081*^9}},ExpressionUUID->"4e4f6ff2-5ca3-4fc8-96bc-\
c873a2f458ca"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rSol", "=", 
  RowBox[{
   RowBox[{"r", "/.", 
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", 
         RowBox[{"2", 
          RowBox[{"R", "/", 
           RowBox[{"(", "M", ")"}]}]}], "]"}], "==", 
        RowBox[{"2", " ", 
         RowBox[{"ArcTanh", "[", 
          SqrtBox[
           RowBox[{"1", "-", 
            FractionBox[
             RowBox[{"2", " ", "M"}], "r"]}]], "]"}]}]}], ",", "r"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}], "//", "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.9672820383068438`*^9, 3.967282077650647*^9}, 
   3.96728343835728*^9, {3.9672835395148163`*^9, 3.967283553358698*^9}, {
   3.9672836097340403`*^9, 3.967283611585478*^9}, 3.96763180411003*^9, 
   3.967737012541238*^9, {3.967737052257159*^9, 3.967737053871461*^9}, {
   3.967737115933421*^9, 3.9677371180825367`*^9}, {3.9731518731939993`*^9, 
   3.973151874253911*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"c8317f15-6433-4eb5-954e-9233f9ebdd81"],

