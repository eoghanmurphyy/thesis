Cell[CellGroupData[{

Cell[TextData[{
 "Check that the simple solution from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Integral]", 
    FractionBox["1", 
     SuperscriptBox["u", "r"]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2fdfbb83-03e3-4ed3-bf99-8dc83e99ded9"],
 "dr and NDSolving the ODEs agree on the same ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "760b0fa7-9867-4a96-919c-e8a5eed24e61"],
 "(\[Tau]) \[LeftRightArrow] \[Tau](",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "80c4b1e3-1383-4fc8-ab13-3802511e5498"],
 ")  as a function of the proper time"
}], "Subsection",
 CellChangeTimes->{{3.973153824041609*^9, 
  3.9731539095236797`*^9}},ExpressionUUID->"ec2533ba-3f2f-40e6-b86e-\
e7de6d254546"],

Cell["Use ParametricPlot here", "Text",
 CellChangeTimes->{{3.9731539251259527`*^9, 
  3.97315393119351*^9}},ExpressionUUID->"dc31f78e-4f1a-4d8e-affb-\
7baddc719b9f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Tau]NDsolve", "[", "tf_", "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"\[Alpha]", "[", 
        RowBox[{"rNum", "[", "t", "]"}], "]"}], "2"], "E0"], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "t0", ",", "tf"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.968386017053357*^9, 3.968386042381826*^9}, {
   3.968386398288023*^9, 3.968386500505351*^9}, 3.9683866927216797`*^9},
 CellLabel->"In[49]:=",ExpressionUUID->"585f7c90-1928-4c77-9ea2-2a4168bcd051"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"\[Tau]Isotropic", "[", 
      RowBox[{"Rbar0", ",", "r"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "Rbar0", ",", "rBarEH"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], "\[IndentingNewLine]", ",", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rNum", "[", "tf", "]"}], ",", 
       RowBox[{"\[Tau]NDsolve", "[", "tf", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"tf", ",", "t0", ",", "tEnd"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Dashing", "[", "0.05", "]"}], ",", "Orange"}], "}"}]}]}], 
    "]"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*OverscriptBox[\(r\), \(_\)]\)\>\"", 
      ",", "\"\<\[Tau](\!\(\*OverscriptBox[\(r\), \(_\)]\))\>\""}], "}"}]}]}],
   "]"}]], "Input",
 CellChangeTimes->{{3.968385818183168*^9, 3.968385831133855*^9}, {
  3.968386800059149*^9, 3.968386842161257*^9}, {3.968401144305681*^9, 
  3.968401192945367*^9}},
