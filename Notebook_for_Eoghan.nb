  3.96834043146364*^9}},ExpressionUUID->"cc721e4c-92b0-48da-bc27-\
74ec91b252e2"],

Cell["\<\
 Check that the energy is between 0 and 1 (bound)  and get the components of \
the 4-velocity at the initial drop point\
\>", "Text",
 CellChangeTimes->{{3.973153164191551*^9, 3.973153178793634*^9}, {
  3.9731532848613358`*^9, 
  3.973153289552269*^9}},ExpressionUUID->"f37d65c6-bc69-45c1-ac9e-\
4fdaeb2ea84a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"E0", "=", 
   RowBox[{"\[Alpha]", "[", "Rbar0", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"0", "<", "E0", "<=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ut0", "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "Rbar0", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Utdrop", "[", "R_", "]"}], "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "R", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Urdrop", "[", "R_", "]"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     RowBox[{"A", "[", "R", "]"}]], 
    SqrtBox[
     RowBox[{
      FractionBox[
       SuperscriptBox["E0", "2"], 
       SuperscriptBox[
        RowBox[{"\[Alpha]", "[", "R", "]"}], "2"]], "-", "1"}]]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.968383101060911*^9, 3.9683831220780077`*^9}, {
  3.968383226462936*^9, 3.9683832418428698`*^9}, {3.968383303505459*^9, 
  3.968383347812524*^9}, {3.968383464033807*^9, 3.9683835004428253`*^9}, {
