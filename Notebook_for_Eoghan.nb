a36126135abf"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"0", "==", 
  RowBox[{"Limit", "[", 
   RowBox[{
    RowBox[{"rBarofrInside", "[", "r", "]"}], ",", 
    RowBox[{"r", "->", "0"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"0", "==", 
  RowBox[{"Limit", "[", 
   RowBox[{
    RowBox[{"rofRbarInside", "[", "R", "]"}], ",", 
    RowBox[{"R", "->", "0"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"0", "==", 
  RowBox[{"Limit", "[", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"rBarofrInside", "[", "r", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"R", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
      RowBox[{"0", "<", "r", "<", "Rst"}]}], "]"}], ",", 
    RowBox[{"r", "->", "0"}]}], "]"}]}], "\n", 
 RowBox[{"0", "==", 
  RowBox[{"Limit", "[", 
   RowBox[{
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"rofRbarInside", "[", "R", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"R", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
      RowBox[{"R", ">", "0"}]}], "]"}], ",", 
    RowBox[{"R", "->", "0"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.968574363424719*^9, 3.968574386860362*^9}, {
  3.968574451274637*^9, 3.968574456774364*^9}, {3.973158144810258*^9, 
