Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"outFigMass", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"massNumIn", "[", "t", "]"}], ",", 
        RowBox[{
         RowBox[{"massNumIn", "''"}], "[", "t", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "t0", ",", 
        RowBox[{".999", " ", "tFinish"}]}], "}"}], ",", 
      RowBox[{"PlotLegends", "->", 
       RowBox[{"LineLegend", "[", 
        RowBox[{"Automatic", ",", 
         RowBox[{"{", 
          RowBox[{"\"\<m(t)\>\"", ",", "\"\<m'(t)\>\""}], "}"}]}], "]"}]}]}], 
     "]"}], ",", 
    RowBox[{"Plot", "[", 
     RowBox[{"rbarStar", ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "tSurface", ",", 
        RowBox[{"tSurface", "+", "tFinish"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"Directive", "[", 
        RowBox[{"Gray", ",", 
         RowBox[{"Opacity", "[", "0.1", "]"}]}], "]"}]}], ",", 
      RowBox[{"Filling", "->", "Bottom"}]}], "]"}]}], "]"}]}]], "Input",
