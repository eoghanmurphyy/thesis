Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"NumericQ", "@", 
  RowBox[{"tauIsotropic", "[", 
   RowBox[{"rbar0", ",", " ", "rbarStar"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Check proper time equality: \>\"", ",", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"tauSchw", "[", 
         RowBox[{"20", ",", "4"}], "]"}], "/", 
        RowBox[{"tauIsotropic", "[", 
         RowBox[{"rbar0", ",", "rbarStar"}], "]"}]}]}], "]"}], "<", 
     SuperscriptBox["10", 
      RowBox[{"-", "16"}]]}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Coordinate", " ", "proper", " ", "times", " ", "agree", " ", "which", " ",
     "means", " ", "I", " ", "am", " ", "correct", " ", "so", " ", "far"}], 
