1648adcccd94"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"UtInside", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", 
   " ", 
   FractionBox[
    SqrtBox[
     RowBox[{"1", " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["ur", 
         RowBox[{"AInside", "[", "rbar", "]"}]], ")"}], "2"], " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["uphi", 
         RowBox[{"rbar", " ", 
          RowBox[{"AInside", "[", "rbar", "]"}]}]], ")"}], "2"]}]], 
    RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Epsilon]", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "1"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"regularisation", " ", "parameter"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"umagphi", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", 
    " ", 
    FractionBox[
     SqrtBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["ur", "2"], "+", 
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox["uphi", "rbar"], ")"}], "2"], " ", "+", " ", 
        SuperscriptBox["\[Epsilon]", "2"]}], ")"}]], 
     RowBox[{"AInside", "[", "rbar", "]"}]]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"paper", " ", "eqn", " ", "ut", " ", "and", " ", "umagphi"}], 
