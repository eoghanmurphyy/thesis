Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"m", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "6"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"mass", " ", "of", " ", 
    RowBox[{"PBH", "?"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Ivariable", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"??", 
    RowBox[{
     RowBox[{"?", " ", 
      RowBox[{"Just", " ", "got", " ", "from", " ", "paper"}]}], ",", " ", 
     RowBox[{
     "something", " ", "got", " ", "to", " ", "do", " ", "with", " ", 
      "Coulomb", " ", "something", " ", "or", " ", "other"}]}]}], "*)"}], 
  " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Eta]", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Speed", " ", "up", " ", "parameter"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   FractionBox[
    RowBox[{"Abs", "[", "ur", "]"}], 
    RowBox[{"AInside", "[", "rbar", "]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"P", "[", "rbar_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"\[Rho]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         SqrtBox[
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"2", 
            FractionBox[
             RowBox[{"M", " ", 
              SuperscriptBox["r", "2"]}], 
             SuperscriptBox["RStar", "3"]]}]}]], "-", 
         SqrtBox[
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"2", 
            FractionBox["M", "RStar"]}]}]]}], 
        RowBox[{
         RowBox[{"3", 
          SqrtBox[
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"2", 
             FractionBox["M", "RStar"]}]}]]}], " ", "-", " ", 
         SqrtBox[
          RowBox[{"1", " ", "-", " ", 
           RowBox[{"2", 
            FractionBox[
             RowBox[{"M", " ", 
              SuperscriptBox["r", "2"]}], 
             SuperscriptBox["RStar", "3"]]}]}]]}]], ")"}]}], " ", "/.", 
     RowBox[{"r", "->", 
      RowBox[{"rofRbarInside", "[", "rbar", "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Derived", " ", "from", " ", "TOV", " ", "as", " ", "I", " ", "done", " ", 
    "last", " ", "year"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dpdtdragr", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   FractionBox[
    RowBox[{
     RowBox[{"-", "4"}], "\[Pi]", " ", 
     RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], 
     RowBox[{"(", 
      RowBox[{"\[Rho]", " ", "+", " ", 
       RowBox[{"P", "[", "rbar", "]"}]}], ")"}], 
     SuperscriptBox["m", "2"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"2", " ", 
         SuperscriptBox[
          RowBox[{"u", "[", 
           RowBox[{"rbar", ",", " ", "ur"}], "]"}], "2"]}]}], ")"}], "2"], " ",
      "Ivariable", " ", "ur"}], 
    SuperscriptBox[
     RowBox[{"u", "[", 
      RowBox[{"rbar", ",", " ", "ur"}], "]"}], "3"]]}], ";"}]}], "Input",
