     RowBox[{"In", " ", "radians"}], ",", " ", 
     RowBox[{
     "measured", " ", "from", " ", "center", " ", "of", " ", "star", " ", 
      "to", " ", "the", " ", "position", " ", "of", " ", "particle"}], ",", 
     " ", 
     RowBox[{"in", " ", "unit", " ", "circle", " ", "fashion"}], ",", " ", 
     RowBox[{
      RowBox[{"pi", "/", "2"}], " ", "corresponds", " ", "to", " ", "grazing",
       " ", "the", " ", "star", " ", "as", " ", "it", " ", "enters", " ", 
      "and", " ", "0", " ", "corresponds", " ", "to", " ", "a", " ", "radial",
       " ", "drop"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
