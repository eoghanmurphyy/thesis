Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"IVariable", "[", "\[CapitalMu]ach_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"1", "+", " ", "\[CapitalMu]ach"}], 
            RowBox[{"1", " ", "-", " ", "\[CapitalMu]ach"}]], "]"}]}], " ", "-",
          " ", "\[CapitalMu]ach"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", "<", " ", "1"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["1", 
             SuperscriptBox["\[CapitalMu]ach", "2"]]}], "]"}]}], "  ", "+", 
         " ", "10"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", ">", " ", "1"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Approximate", " ", 
     RowBox[{
      RowBox[{"Log", "[", "\[CapitalLambda]", "]"}], " ", "~", " ", "10"}], " ",
      "following", " ", "other", " ", 
     RowBox[{"authors", " ", "[", "9", "]"}], " ", "on", " ", "2404"}], "]"}],
    "*)"}]}]}], "Input",
