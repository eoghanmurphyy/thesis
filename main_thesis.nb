 CellChangeTimes->{{3.980417361129909*^9, 
  3.9804173686441803`*^9}},ExpressionUUID->"3742578b-7ab3-4064-bd9b-\
658aee016464"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vinf", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "3"}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.980417096758354*^9, 3.9804171019450607`*^9}},
 CellLabel->
  "In[897]:=",ExpressionUUID->"a38faf4c-d76b-4470-95be-deb12d46599a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"InitialEnergyAtInfinity", "[", "vinf_", "]"}], " ", ":=", " ", 
    FractionBox["1", 
     SqrtBox[
      RowBox[{"1", " ", "-", " ", 
       SuperscriptBox["vinf", "2"]}]]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"eq47", " ", "2404", " ", "paper"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9804160850197678`*^9, 3.980416098649988*^9}},
 CellLabel->
  "In[898]:=",ExpressionUUID->"e612bdc4-861a-4b86-8b55-324028654924"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "general", " ", "formula", " ", "for", " ", "the", " ", "magnitude", " ", 
     "of", " ", "the", " ", "velocity"}], ",", " ", 
    RowBox[{
    "for", " ", "a", " ", "general", " ", "spherically", " ", "symmetric", " ",
      "Isotropic", " ", "metric"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"umagVel", "[", 
     RowBox[{"ur_", ",", " ", "uphi_", ",", " ", "rbar_"}], "]"}], " ", ":=", 
    " ", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["ur", "2"], " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["uphi", "rbar"], ")"}], "2"]}]]}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"umagE", "[", 
      RowBox[{"Energy_", ",", " ", "rbar_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"A", "[", "rbar", "]"}], 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox["Energy", 
           RowBox[{"\[Alpha]", "[", "rbar", "]"}]], ")"}], "2"], " ", "-", 
        " ", "1"}]]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"eq", " ", "48", " ", "in", " ", "paper"}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.980415761538435*^9, 3.9804158755202312`*^9}, {
  3.9804159272169247`*^9, 3.980415932674501*^9}, {3.980415969031563*^9, 
  3.980415973297673*^9}, {3.980416194586721*^9, 3.9804162406179028`*^9}, {
