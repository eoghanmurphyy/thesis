Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"LogPlot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"umagphi", "[", 
       RowBox[{
        RowBox[{"rbarNumIn", "[", "t", "]"}], ",", 
        RowBox[{"urNumIn", "[", "t", "]"}], ",", 
        RowBox[{"uphiNumIn", "[", "t", "]"}]}], "]"}], "/.", " ", "solIn"}], 
     "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "tFinish"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"AxesLabel", "->", 
