Cell[TextData[{
 "Initially though that it was stopping because the velocities were zero and \
that it was at the centre, which turned out to be naive, checked the value or \
rbarNumIn and this showed that it was not at zero, and it is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["u", "3"], TraditionalForm]],ExpressionUUID->
  "023ef39f-a711-4168-83bc-dc0f04e69512"],
 " term once again causing this artificial, fictitious behaviour as a result \
of the coordinate choices I assume.\nIn reflection, it cannot be a \
singularity here and it a result of numerical stiffness build up in the \
integration "
}], "Text",
 CellChangeTimes->{{3.979743979634658*^9, 3.979744065412425*^9}, {
  3.97979805525603*^9, 
  3.9797980853547783`*^9}},ExpressionUUID->"d891f8d1-51b8-48c5-acc9-\
c1be3dbeec67"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Approaching the problem differently, using ",
 StyleBox["Keplerian",
  IgnoreSpellCheck->True],
 " orbits on the outside of the star and then GR on the inside to reduce the \
stiffness of the problem causing the error in the solver."
}], "Subsubsection",
 CellChangeTimes->{{3.979808250472919*^9, 
  3.9798082843297377`*^9}},ExpressionUUID->"b6603694-3cc2-4db1-aa87-\
571acf8d2183"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"From", " ", "paper"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Energies", " ", "Per", " ", "units", " ", "mass"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"EnergyOutside", "[", 
      RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=",
      " ", 
     RowBox[{"-", 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"EnergyInside", "[", 
      RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=",
      " ", 
     RowBox[{"-", 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Angular", " ", "momentum", " ", "per", " ", "unit", " ", "mass"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"AngularMomentum", "[", "uphi_", "]"}], " ", ":=", " ", 
    "uphi"}]}]}]], "Input",
 CellChangeTimes->{{3.9798082910082893`*^9, 3.979808296290172*^9}, {
  3.979808355598556*^9, 3.9798083818705177`*^9}, {3.97980842127808*^9, 
  3.9798085273010902`*^9}},
 CellLabel->
  "In[164]:=",ExpressionUUID->"097629f1-b20a-4d99-880f-184655931395"],

Cell[TextData[{
 "Taking the approach of the paper toward initial conditions, choosing my ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "\[Infinity]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3eff6553-a754-46bc-9d3f-3d6677c45f9e"],
 " to set the initial Energy = -ut = gamma = ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    SqrtBox[
     RowBox[{"1", " ", "-", " ", 
      SuperscriptBox[
       SubscriptBox["v", "\[Infinity]"], "2"]}]]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "eea38665-3011-4104-8ee4-da665d9fe4eb"]
}], "Text",
 CellChangeTimes->{{3.9798097191184893`*^9, 
  3.979809823181335*^9}},ExpressionUUID->"c5e100b3-c887-458e-9d32-\
806f9058260d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"InitialEnergy", "[", "vinf_", "]"}], " ", ":=", " ", 
   FractionBox["1", 
    SqrtBox[
     RowBox[{"1", " ", "-", " ", 
      SuperscriptBox["vinf", "2"]}]]]}], ";"}]], "Input",
 CellChangeTimes->{{3.979809840975781*^9, 
  3.979809903223235*^9}},ExpressionUUID->"138a589e-e429-4602-950a-\
033bd1a07017"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Limit", "[", 
   RowBox[{
    RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], ",", " ", 
    RowBox[{"rbar", "->", " ", "1"}]}], "]"}], " ", "//", " ", "N"}]], "Input",\

 CellChangeTimes->{{3.979810668128471*^9, 3.979810684909651*^9}, {
  3.979810887784515*^9, 3.979810905163312*^9}},
 CellLabel->
  "In[179]:=",ExpressionUUID->"71a1b608-f680-4060-b8cd-d26a0dad6e89"],

Cell[BoxData["0.5804626471018649`"], "Output",
 CellChangeTimes->{
  3.9798106853295307`*^9, {3.97981088858148*^9, 3.979810905453177*^9}},
 CellLabel->
  "Out[179]=",ExpressionUUID->"7d62ace0-a101-4ebc-8f5e-51d571a3c3a9"]
}, Open  ]],

