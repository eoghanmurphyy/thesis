Cell[CellGroupData[{

Cell["Setting up Everything:", "Subsection",
 CellChangeTimes->{{3.978329933193924*^9, 3.978329943730052*^9}, {
  3.9795554552579403`*^9, 
  3.979555458849951*^9}},ExpressionUUID->"63cdd7c1-1b8d-4f48-8ed8-\
1eb6a8b00b3a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"M", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RStar", " ", "=", " ", "5"}], ";"}]}], "Input",
 CellChangeTimes->{{3.978329952795225*^9, 3.97832996470603*^9}, {
  3.9783314229347754`*^9, 3.9783314272944937`*^9}, {3.979555464546053*^9, 
  3.979555475769952*^9}, {3.98043117855846*^9, 3.980431178947686*^9}},
 CellLabel->
  "In[2156]:=",ExpressionUUID->"dc85d34e-59d5-4237-a3f3-6b1850cfb961"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mfunc", "[", "r_", "]"}], " ", "=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M", " ", 
         FractionBox[
          SuperscriptBox["r", "3"], 
          SuperscriptBox["RStar", "3"]]}], ",", " ", 
        RowBox[{"r", " ", "<=", " ", "RStar"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"M", ",", " ", 
        RowBox[{"r", ">", "RStar"}]}], "}"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"grrTOV", "[", "r_", "]"}], " ", "=", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox[
        RowBox[{"2", 
         RowBox[{"Mfunc", "[", "r", "]"}]}], "r"]}], ")"}], 
     RowBox[{"-", "1"}]]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Kappa]", " ", "=", " ", 
    SqrtBox[
     RowBox[{"2", 
      FractionBox["M", 
       SuperscriptBox["RStar", "3"]]}]]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Integral", " ", "constant", " ", "I", " ", "used", " ", "by", " ", 
    "hand"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Const", " ", "=", " ", 
    RowBox[{
     RowBox[{"rBarSchw", "[", "RStar", "]"}], 
     SqrtBox[
      FractionBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", 
          FractionBox[
           RowBox[{"2", "M"}], "RStar"]}]]}], 
       RowBox[{"1", "-", 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}]]}]]]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Can", " ", "use", " ", "schw", " ", "to", " ", "convert", " ", "RStar", " ",
     "as", " ", "the", " ", "value", " ", "should", " ", "be", " ", "the", " ",
     "same", " ", "inside", " ", "and", " ", "outside"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rBarofrInside", "[", "r_", "]"}], "=", 
   RowBox[{"Const", " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}], 
      RowBox[{"1", "+", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}]]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rofRbarInside", "[", "R_", "]"}], "=", 
   RowBox[{
    FractionBox["1", "\[Kappa]"], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Tanh", "[", 
        RowBox[{"Log", "[", 
         FractionBox["R", "Const"], "]"}], "]"}], "2"]}]]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9783301118015347`*^9, 3.978330182920364*^9}, {
  3.9783302193359118`*^9, 3.978330320711*^9}, {3.978330396647119*^9, 
  3.9783304724143457`*^9}, {3.978330637788574*^9, 3.978330649268416*^9}, {
