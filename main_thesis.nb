Cell["\<\
Fixing the rho0 constant by letting the total mass integral equal to 1\
\>", "Text",
 CellChangeTimes->{{3.98075959945807*^9, 
  3.980759612857791*^9}},ExpressionUUID->"2d245823-995f-4fbd-95d1-\
77bf997b44e5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rho", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"rho0", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox["r", "R"]}], ")"}], "6"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"massIntegral", " ", "=", "  ", 
   RowBox[{"4", " ", "Pi", " ", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"rho", "[", "r", "]"}], " ", 
       SuperscriptBox["r", "2"]}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "0", ",", " ", "R"}], "}"}]}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.980759622490066*^9, 3.9807596245941343`*^9}, 
   3.980759773120947*^9},
 CellLabel->
  "In[133]:=",ExpressionUUID->"5b602d20-8818-44f0-860f-853f263c5496"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rhoCentre", "[", "R_", "]"}], " ", ":=", " ", 
   FractionBox["63", 
    RowBox[{"Pi", " ", 
     SuperscriptBox["R", "3"]}]]}], " ", 
  RowBox[{"(*", 
   RowBox[{"From", " ", "the", " ", "above"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rho0", " ", "=", " ", 
   RowBox[{"rhoCentre", "[", "RStar", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.980759649577128*^9, 3.980759696481625*^9}, {
  3.9807597758725758`*^9, 3.9807597807605953`*^9}},
