b8883cd24145"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"rbar0", " ", "=", " ", 
   RowBox[{"rBarSchw", "[", "R0", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
