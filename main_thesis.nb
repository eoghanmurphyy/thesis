Cell[BoxData[{
 RowBox[{"orbit2D", "=", 
  RowBox[{"ParametricPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"rbarNumIn", "[", "t", "]"}], " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"phiNumIn", "[", "t", "]"}], "]"}]}], ",", 
      RowBox[{
       RowBox[{"rbarNumIn", "[", "t", "]"}], " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"phiNumIn", "[", "t", "]"}], "]"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "t0", ",", 
      RowBox[{".999", " ", "tFinish"}]}], "}"}], ",", 
    RowBox[{"AspectRatio", "->", "1"}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"PlotStyle", "->", "Thick"}]}], "]"}]}], "\n", 
