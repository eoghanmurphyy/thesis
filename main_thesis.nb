Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ut", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", 
    " ", 
    FractionBox[
     SqrtBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["ur", 
          RowBox[{"A", "[", "rbar", "]"}]], ")"}], "2"], " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["uphi", 
          RowBox[{"rbar", " ", 
           RowBox[{"A", "[", "rbar", "]"}]}]], ")"}], "2"]}]], 
     RowBox[{"\[Alpha]", "[", "rbar", "]"}]]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"drBardt", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"], 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "ur"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dphidtOutside", "[", 
     RowBox[{"rbar_", ",", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["rbar", "2"], "*", 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"], "*", 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", "uphi"}], "]"}]}]], "uphi"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt2DOutside", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", "=", 
   " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]", "[", "rbar", "]"}]}], " ", 
     RowBox[{"Ut", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
      "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "rbar", 
        "]"}], 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["uphi", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox["rbar", "3"], " ", "*", 
         SuperscriptBox[
          RowBox[{"A", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "rbar",
          "]"}], 
        RowBox[{
         SuperscriptBox["rbar", "2"], "*", 
         SuperscriptBox[
          RowBox[{"A", "[", "rbar", "]"}], "3"]}]]}], ")"}]}]}]}], 
  ";"}]}], "Input",
