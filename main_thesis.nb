Cell[CellGroupData[{

Cell["Defining new density and mass functions from new paper 2405", \
"Subsection",
 CellChangeTimes->{{3.9807597890247583`*^9, 
  3.980759803632635*^9}},ExpressionUUID->"46b04e52-e9a1-4708-9713-\
b8d73fa20fee"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rho", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"rho0", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"1", " ", "-", " ", 
             FractionBox["r", "RStar"]}], ")"}], "6"]}], ",", " ", 
         RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"rho0", ",", " ", 
         RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
      "\[IndentingNewLine]", "}"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MassFunc", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"252", 
          RowBox[{"(", 
           RowBox[{
            FractionBox[
             SuperscriptBox["r", "9"], 
             RowBox[{"9", 
              SuperscriptBox["RStar", "9"]}]], "-", 
            FractionBox[
             RowBox[{"3", 
              SuperscriptBox["r", "8"]}], 
             RowBox[{"4", 
              SuperscriptBox["RStar", "8"]}]], "+", 
            FractionBox[
             RowBox[{"15", 
              SuperscriptBox["r", "7"]}], 
             RowBox[{"7", 
              SuperscriptBox["RStar", "7"]}]], "-", 
            FractionBox[
             RowBox[{"10", 
              SuperscriptBox["r", "6"]}], 
             RowBox[{"3", 
              SuperscriptBox["RStar", "6"]}]], "+", 
            FractionBox[
             RowBox[{"3", 
              SuperscriptBox["r", "5"]}], 
             SuperscriptBox["RStar", "5"]], "-", 
            FractionBox[
             RowBox[{"3", 
              SuperscriptBox["r", "4"]}], 
             RowBox[{"2", 
              SuperscriptBox["RStar", "4"]}]], "+", 
            FractionBox[
             SuperscriptBox["r", "3"], 
             RowBox[{"3", 
              SuperscriptBox["RStar", "3"]}]]}], ")"}]}], " ", ",", " ", 
         RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"M", ",", " ", 
         RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
      "\[IndentingNewLine]", "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "In", " ", "2405.08113", " ", "this", " ", "function", " ", "is", " ", 
     "divided", " ", "by", " ", "the", " ", "solar", " ", "mass"}], ",", " ", 
    
    RowBox[{
     RowBox[{"here", " ", "I", " ", "use", " ", "M"}], "=", "1"}]}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MassFunc", "[", 
     RowBox[{"RStar", " ", "+", " ", "1"}], "]"}], " ", "//", " ", "N"}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "equals", " ", "1", " ", "at", " ", "RStar", " ", "and", " ", "is", " ", 
    "consistent"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9807577923623877`*^9, 3.98075785617692*^9}, {
   3.9807579037758617`*^9, 3.980758119918268*^9}, {3.980759150141821*^9, 
   3.980759229085232*^9}, {3.98075970148167*^9, 3.9807597184254913`*^9}, {
   3.980759983167514*^9, 3.980760030871025*^9}, 3.980760548251651*^9, {
   3.980760610330676*^9, 3.98076062375484*^9}, {3.9807606770346537`*^9, 
   3.980760724658237*^9}, {3.980762059247533*^9, 3.9807620598878193`*^9}, {
   3.980762157230887*^9, 3.980762163950886*^9}},
 CellLabel->
  "In[140]:=",ExpressionUUID->"6807bacf-7b4d-4913-b619-75336105eb80"]
}, Open  ]],

Cell[CellGroupData[{

Cell["New TOV Solution for the metric", "Subsection",
 CellChangeTimes->{{3.980759833065682*^9, 
  3.980759839256179*^9}},ExpressionUUID->"e582958d-dac6-487a-9e68-\
b4681244c6e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"TOV", " ", "Equation"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"TOVEqn", "[", 
    RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"MassFunc", "[", "r", "]"}], 
      SuperscriptBox["r", "2"]]}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"rho", "[", "r", "]"}], " ", "+", " ", "Pressure"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      FractionBox[
       RowBox[{"4", " ", "Pi", " ", 
        RowBox[{"(", "Pressure", ")"}], " ", 
        SuperscriptBox["r", "3"]}], 
       RowBox[{"MassFunc", "[", "r", "]"}]]}], ")"}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox[
        RowBox[{"2", " ", 
         RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
     RowBox[{"-", "1"}]]}]}]}]], "Input",
 CellChangeTimes->{{3.9807601294062366`*^9, 3.98076013474163*^9}, {
  3.980760167277755*^9, 3.980760297804946*^9}, {3.98076131275782*^9, 
  3.980761317285252*^9}, {3.980761630595008*^9, 3.980761651114334*^9}},
 CellLabel->
  "In[143]:=",ExpressionUUID->"12df92a2-2e1f-449f-87a5-f63bd0a458e4"],

Cell["\<\
Cannot integrate from outward in because of the singularity at r=0 so we \
start and guess and check the pressure at the centre\
\>", "Text",
 CellChangeTimes->{{3.9807611650801*^9, 
  3.980761187893772*^9}},ExpressionUUID->"ca65b358-b5d2-47df-b1f9-\
a7d49e57e923"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rmin", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "6"}]]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "integrates", " ", "for", " ", "a", " ", 
    "given", " ", "Pc"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pressureSolution", "[", 
    RowBox[{"Pc_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"(*", 
    RowBox[{
    "Only", " ", "evaluates", " ", "the", " ", "function", " ", "if", " ", 
     "Pc", " ", "is", " ", "numeric"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Pressure", "'"}], "[", "r", "]"}], " ", "==", " ", 
        RowBox[{"TOVEqn", "[", 
         RowBox[{"r", ",", " ", 
          RowBox[{"Pressure", "[", "r", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Pressure", "[", "rmin", "]"}], " ", "==", " ", "Pc"}]}], 
      "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", "Pressure", ",",
      "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "rmin", ",", " ", "RStar"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"MaxSteps", "->", "Infinity"}]}], "\[IndentingNewLine]", "]"}]}],
   ";"}]}], "Input",
 CellChangeTimes->{{3.980761191230756*^9, 3.9807611984861517`*^9}, {
  3.9807612617574863`*^9, 3.98076139206083*^9}, {3.980761732033964*^9, 
  3.980761769297784*^9}},
 CellLabel->
  "In[153]:=",ExpressionUUID->"404238f2-0b25-414e-8dee-8556b9a1809d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sol", "=", 
    RowBox[{"pressureSolution", "[", "0.007052800", "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Purely", " ", "guessing", " ", "and", " ", "checking", " ", "work", " ", 
    "and", " ", "this", " ", "seems", " ", "to", " ", "work", " ", "for", " ",
     "Pc"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Pressurefunction", "=", 
   RowBox[{"Pressure", "/.", " ", 
    RowBox[{"sol", "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"Pressurefunction", "[", "8", "]"}]}], "Input",
 CellChangeTimes->{{3.98076340769403*^9, 3.980763427084346*^9}, {
  3.980763481027849*^9, 3.98076370912982*^9}, {3.980763770473578*^9, 
  3.9807638088896513`*^9}, {3.980763925576507*^9, 3.9807639264563437`*^9}, {
  3.980764061847419*^9, 3.980764074407289*^9}},
 CellLabel->
  "In[354]:=",ExpressionUUID->"2a41b1c4-5f94-456b-bc68-2ef77f7b80fb"],

