Cell[CellGroupData[{

Cell["Solving the ODEs", "Section",
 CellChangeTimes->{{3.978425622791493*^9, 
  3.978425624888094*^9}},ExpressionUUID->"199a3d31-7817-422a-ae35-\
3382bc7c86ca"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", "=", "2000"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt2DOutside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt2DInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"uphi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"duphidtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"phi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"dphidtOutside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"dphidtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], "==", " ", "rbar0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], "==", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"phi", "[", "0", "]"}], "==", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"uphi", "[", "0", "]"}], "==", "AngularMomentumUphi0"}], ",",
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"WhenEvent", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"rbar", "[", "t", "]"}], " ", "<=", " ", 
           SuperscriptBox["10", 
            RowBox[{"-", "3"}]]}], " ", ",", " ", "\"\<StopIntegration\>\""}],
          "]"}]}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"rbar", ",", "ur", ",", "phi", ",", "uphi"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"t", ",", "t0", ",", "tEnd"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"MaxSteps", "->", "20000"}]}], "\[IndentingNewLine]", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9784256510226727`*^9, 3.978425725338666*^9}, 
