Cell[BoxData[
 TemplateBox[{
  "N", "meprec", 
   "\"Internal precision limit $MaxExtraPrecision = \\!\\(\\*RowBox[{\\\"50.`\
\\\"}]\\) reached while evaluating \\!\\(\\*RowBox[{RowBox[{FractionBox[\\\"1\
\\\", \\\"2\\\"], \\\" \\\", RowBox[{\\\"(\\\", RowBox[{RowBox[{\\\"-\\\", \\\
