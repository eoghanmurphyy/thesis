 RowBox[{
  RowBox[{"rbarStar", " ", "=", " ", 
   RowBox[{"rBarSchw", "[", "RStar", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"RStarVal", " ", "==", " ", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"rofRbarInside", "[", "%", "]"}], " ", "/.", " ", 
     RowBox[{"M", " ", "->", " ", "M"}]}], " ", "/.", " ", 
    RowBox[{"RStar", " ", "->", " ", "RStar"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"and", " ", "it", " ", "matches"}], ",", " ", 
    RowBox[{
    "%", " ", "takes", " ", "previous", " ", "lines", " ", "answer"}]}], 
   "*)"}]}]}], "Input",
