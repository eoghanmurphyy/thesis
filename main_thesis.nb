     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox["3", "2"], 
        SqrtBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"2", 
            FractionBox["M", "RStar"]}]}], ")"}]]}], "-", 
       RowBox[{
        FractionBox["1", "2"], 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox[
            RowBox[{"M", " ", 
             SuperscriptBox["r", "2"]}], 
            SuperscriptBox["RStar", "3"]]}]}]]}]}], ")"}], "/.", 
     RowBox[{"r", "->", 
      RowBox[{"rofRbarInside", "[", "rbar", "]"}]}]}]}], ";"}], " ", 
  RowBox[{"(*", "Lapse", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
