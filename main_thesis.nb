Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalMu]", "[", 
   RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
  " ", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{"umagphi", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
        RowBox[{"a", " ", 
         RowBox[{"\[Alpha]", "[", "rbar", "]"}], " ", 
         RowBox[{"Ut", "[", 
          RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], ",", 
       " ", 
       RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{"umagphi", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
        RowBox[{"a", " ", 
         RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], " ", 
         RowBox[{"UtInside", "[", 
          RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], ",", 
       " ", 
       RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.980682776589178*^9, 3.980682777085677*^9}},
 CellLabel->
  "In[854]:=",ExpressionUUID->"afb982bd-02a7-4b86-8653-8293ac486e2b"]
