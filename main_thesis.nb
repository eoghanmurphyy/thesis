Cell[CellGroupData[{

Cell["\<\
Performing radial drop, from the point of view of an observer at infinity \
(using normal t coordinate)\
\>", "Subsection",
 CellChangeTimes->{{3.978259830728229*^9, 3.978259843656719*^9}, {
  3.978269852253587*^9, 3.978269852701602*^9}, {3.979554685170045*^9, 
  3.979554717159871*^9}},ExpressionUUID->"b36d9ecf-6a55-4586-935c-\
8e2ef06b2bd2"],

Cell["\<\
Equations below derived from the geodesic equation and checked using the \
paper 2404\
\>", "Text",
 CellChangeTimes->{{3.9795547308319798`*^9, 
  3.979554746815835*^9}},ExpressionUUID->"370e569b-3bcb-4a1f-8471-\
9b1b70f3ac7b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Ut", "[", 
    RowBox[{"rbar_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Alpha]", "[", "rbar", "]"}]], 
    SqrtBox[
     RowBox[{"1", "+", 
      FractionBox[
       SuperscriptBox["ur", "2"], 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"]]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"drBardt", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"A", "[", "rbar", "]"}], "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]}]], "ur"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]", "[", "rbar", "]"}]}], " ", 
     RowBox[{"Ut", "[", 
      RowBox[{"rbar", ",", " ", "ur"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
      "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
