Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Block", " ", "function", " ", "says", " ", "use", " ", "this", " ", 
    "value", " ", "of", " ", "M", " ", "then", " ", "forget", " ", "it"}], 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"rSchw", "[", "rbar_", "]"}], " ", "=", " ", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"M", " ", "=", " ", "1"}], "}"}], ",", " ", 
       RowBox[{"rbar", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", " ", "+", " ", 
           RowBox[{"M", "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}]}], 
      "]"}]}], ";"}], " ", "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rBarSchw", "[", "r_", "]"}], " ", "=", " ", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"M", " ", "=", " ", "1"}], "}"}], ",", " ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "M"}], " ", "+", " ", "r", " ", "+", " ", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"r", "^", "2"}], " ", "-", " ", 
            RowBox[{"2", " ", "M", " ", "r"}]}], "]"}]}], ")"}]}]}], "]"}]}], 
    ";"}]}]}]], "Input",
