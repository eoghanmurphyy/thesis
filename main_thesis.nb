Cell["Plot showing the in fall to the edge of the star ", "Text",
 CellChangeTimes->{{3.9795552032279673`*^9, 
  3.979555220915728*^9}},ExpressionUUID->"f3bf65d4-662f-4dca-a8ed-\
6e2d004b6dd0"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Checking the analytic integral and NDSolve agree on the same \[Tau](",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bafa5886-c518-40ed-9146-5d4ce6653b95"],
 ")"
}], "Subsection",
 CellChangeTimes->{{3.978270533803668*^9, 3.978270597777411*^9}, {
  3.979555253155415*^9, 
  3.9795552875950117`*^9}},ExpressionUUID->"5687ba60-1bfc-4fd4-b250-\
03d45eff84a9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"tauNDSolve", "[", "tf_", "]"}], " ", ":=", " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{"\[Alpha]", "[", 
         RowBox[{"rbarNum", "[", "t", "]"}], "]"}], "2"], "E0"], ",", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "t0", ",", " ", "tf"}], "}"}]}], "]"}]}], ";"}],
   " ", 
  RowBox[{"(*", 
   RowBox[{
   "Numerically", " ", "solving", " ", "one", " ", "of", " ", "the", " ", 
    "ODEs", " ", "above", " ", "for", " ", "tau"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.978270632130148*^9, 3.978270706425108*^9}, {
  3.979555289883136*^9, 3.979555304643355*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"26089fa5-30fe-41f3-9a25-3c1a4cae2dd2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"tauIsotropic", "[", 
      RowBox[{"rbar0", ",", " ", "r"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "rbar0", ",", " ", "rbarStar"}], "}"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Plot", " ", "from", " ", "starting", " ", "r0", " ", "down", " ", 
        "to", " ", "R"}], ",", " ", 
       RowBox[{"as", " ", "r", " ", "decreases"}]}], "*)"}], ",", " ", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], "\[IndentingNewLine]", ",",
    " ", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rbarNum", "[", "tf", "]"}], ",", " ", 
       RowBox[{"tauNDSolve", "[", "tf", "]"}]}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"tf", ",", " ", "t0", ",", " ", "tEnd"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Dashing", "[", "0.1", "]"}], ",", " ", "Red"}], "}"}]}]}], 
    "]"}], ",", " ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*OverscriptBox[\(r\), \(_\)]\)\>\"", ",", 
      " ", "\"\<\[Tau](\!\(\*OverscriptBox[\(r\), \(_\)]\))\>\""}], "}"}]}]}],
   "]"}]], "Input",
 CellChangeTimes->{{3.968385818183168*^9, 3.968385831133855*^9}, {
  3.968386800059149*^9, 3.968386842161257*^9}, {3.968401144305681*^9, 
