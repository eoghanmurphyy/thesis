Cell["\<\
Defining the Isotropic metric components for external Schwarzschild spacetime\
\
\>", "Text",
 CellChangeTimes->{{3.978080680202964*^9, 3.978080698553022*^9}, {
  3.978268989555698*^9, 
  3.9782689965556726`*^9}},ExpressionUUID->"5b9b60d0-0c1f-4469-a1af-\
61be65f73c12"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"A", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "^", "2"}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Alpha]", "[", "rbar_", "]"}], " ", "=", " ", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", "=", "1"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"M", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "rbar"}], ")"}]}]}], ")"}]}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.978080703602681*^9, 3.9780808115943537`*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"5d15e3dc-ab5f-454a-a724-8b2bc3b93d2c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"E0", "=", 
   RowBox[{"\[Alpha]", "[", "rbar0", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"0", "<", "E0", "<=", "1"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ut0", "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "rbar0", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Utdrop", "[", "rbar_", "]"}], "=", 
   FractionBox["E0", 
    SuperscriptBox[
     RowBox[{"\[Alpha]", "[", "rbar", "]"}], "2"]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Urdrop", "[", "rbar_", "]"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     RowBox[{"A", "[", "rbar", "]"}]], 
    SqrtBox[
     RowBox[{
      FractionBox[
       SuperscriptBox["E0", "2"], 
       SuperscriptBox[
        RowBox[{"\[Alpha]", "[", "rbar", "]"}], "2"]], "-", "1"}]]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.968383101060911*^9, 3.9683831220780077`*^9}, {
