Cell[BoxData[
 RowBox[{
  RowBox[{"tauIsotropic", "[", 
   RowBox[{"rStart_", ",", " ", "rFinish_"}], "]"}], " ", ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Urdrop", "[", "rBar", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"rBar", ",", "rStart", ",", "rFinish"}], "}"}], ",", 
    RowBox[{"WorkingPrecision", "->", "40"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.978269427225082*^9, 3.97826943066509*^9}, {
  3.979554936781938*^9, 3.979554936845869*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"a5cb89de-050c-4ceb-b61f-7758bcc40da0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"NumericQ", "@", 
  RowBox[{"tauIsotropic", "[", 
   RowBox[{"rbar0", ",", " ", "rbarStar"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Check proper time equality: \>\"", ",", 
    RowBox[{
     RowBox[{"Abs", "[", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{"tauSchw", "[", 
         RowBox[{"20", ",", "4"}], "]"}], "/", 
        RowBox[{"tauIsotropic", "[", 
         RowBox[{"rbar0", ",", "rbarStar"}], "]"}]}]}], "]"}], "<", 
     SuperscriptBox["10", 
      RowBox[{"-", "16"}]]}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Coordinate", " ", "proper", " ", "times", " ", "agree", " ", "which", " ",
     "means", " ", "I", " ", "am", " ", "correct", " ", "so", " ", "far"}], 
