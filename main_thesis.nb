Cell[CellGroupData[{

Cell["Setting up Everything:", "Subsection",
 CellChangeTimes->{{3.978329933193924*^9, 3.978329943730052*^9}, {
  3.9795554552579403`*^9, 
  3.979555458849951*^9}},ExpressionUUID->"63cdd7c1-1b8d-4f48-8ed8-\
1eb6a8b00b3a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mfunc", "[", "r_", "]"}], " ", "=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M", " ", 
         FractionBox[
          SuperscriptBox["r", "3"], 
          SuperscriptBox["RStar", "3"]]}], ",", " ", 
        RowBox[{"r", " ", "<=", " ", "RStar"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"M", ",", " ", 
        RowBox[{"r", ">", "RStar"}]}], "}"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Kappa]", " ", "=", " ", 
    SqrtBox[
     RowBox[{"2", 
      FractionBox["M", 
       SuperscriptBox["RStar", "3"]]}]]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Integral", " ", "constant", " ", "I", " ", "used", " ", "by", " ", 
    "hand"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Const", " ", "=", " ", 
    RowBox[{
     RowBox[{"rBarSchw", "[", "RStar", "]"}], 
     SqrtBox[
      FractionBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", 
          FractionBox[
           RowBox[{"2", "M"}], "RStar"]}]]}], 
       RowBox[{"1", "-", 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}]]}]]]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Can", " ", "use", " ", "schw", " ", "to", " ", "convert", " ", "RStar", " ",
     "as", " ", "the", " ", "value", " ", "should", " ", "be", " ", "the", " ",
     "same", " ", "inside", " ", "and", " ", "outside"}], "*)"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "is", " ", "the", " ", "constant", " ", "to", " ", "match", " ",
     "up", " ", "the", " ", "metrics"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9783301118015347`*^9, 3.978330182920364*^9}, {
  3.9783302193359118`*^9, 3.978330320711*^9}, {3.978330396647119*^9, 
  3.9783304724143457`*^9}, {3.978330637788574*^9, 3.978330649268416*^9}, {
  3.9783306935323772`*^9, 3.9783307658920507`*^9}, {3.978330991234181*^9, 
  3.978331001017686*^9}, {3.978331277912362*^9, 3.978331311255105*^9}, {
  3.978331379335352*^9, 3.978331390374861*^9}, {3.978331820731887*^9, 
  3.978331839027294*^9}, {3.979555484465968*^9, 3.979555505633912*^9}, {
  3.980678923949773*^9, 3.9806789243815603`*^9}, {3.98067897216496*^9, 
  3.9806789807889833`*^9}, {3.980759971351565*^9, 3.980759971855315*^9}},
 CellLabel->
  "In[131]:=",ExpressionUUID->"a7bb6ec9-bcf8-4319-b94e-24ee73e8dc48"],

Cell[CellGroupData[{

Cell["\<\
Schwarzschild and Isotropic interior coordinate conversion formulas\
\>", "Subsubsection",
 CellChangeTimes->{{3.9806789303493757`*^9, 3.980678935965378*^9}, {
  3.980679131228282*^9, 
  3.980679156483783*^9}},ExpressionUUID->"d70d6f46-1ad1-4b61-a533-\
157307a4a03e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rBarofrInside", "[", "r_", "]"}], "=", 
   RowBox[{"Const", " ", 
    SqrtBox[
     FractionBox[
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}], 
      RowBox[{"1", "+", 
       SqrtBox[
        RowBox[{"1", "-", 
         RowBox[{"2", 
          FractionBox[
           RowBox[{"Mfunc", "[", "r", "]"}], "r"]}]}]]}]]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rofRbarInside", "[", "R_", "]"}], "=", 
   RowBox[{
    FractionBox["1", "\[Kappa]"], 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Tanh", "[", 
        RowBox[{"Log", "[", 
         FractionBox["R", "Const"], "]"}], "]"}], "2"]}]]}]}], 
  ";"}]}], "Input",
 CellLabel->
  "In[134]:=",ExpressionUUID->"3f4512f3-fa42-44ba-aed5-66bbc45b5f1b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Lapse and shift functions of the \[Rho]=constant TOV metric:", \
"Subsubsection",
 CellChangeTimes->{{3.9783316231888103`*^9, 3.9783316301168423`*^9}, {
  3.979555648944131*^9, 
  3.97955565773006*^9}},ExpressionUUID->"4b4454f3-7bb1-4ccb-8644-\
93536edeaedd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Alpha]Inside", "[", "rbar_", "]"}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox["3", "2"], 
        SqrtBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"2", 
            FractionBox["M", "RStar"]}]}], ")"}]]}], "-", 
       RowBox[{
        FractionBox["1", "2"], 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox[
            RowBox[{"M", " ", 
             SuperscriptBox["r", "2"]}], 
            SuperscriptBox["RStar", "3"]]}]}]]}]}], ")"}], "/.", 
     RowBox[{"r", "->", 
      RowBox[{"rofRbarInside", "[", "rbar", "]"}]}]}]}], ";"}], " ", 
  RowBox[{"(*", "Lapse", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AInside", "[", "rbar_", "]"}], "=", 
    FractionBox[
     RowBox[{"rofRbarInside", "[", "rbar", "]"}], "rbar"]}], ";"}], 
  RowBox[{"(*", "Shift", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.968510507921006*^9, 3.968510547883458*^9}, {
  3.9685105922792187`*^9, 3.968510621455763*^9}, {3.968573085595805*^9, 
  3.968573140792346*^9}, {3.968574515628276*^9, 3.96857455594086*^9}, {
