Cell[CellGroupData[{

Cell["New ODE with drag added", "Subsubsection",
 CellChangeTimes->{{3.978353866771802*^9, 3.978353883651927*^9}, {
  3.9795565436571083`*^9, 3.979556555248949*^9}, {3.9795569180058126`*^9, 
  3.979556918518189*^9}},ExpressionUUID->"5cf0a841-f0bb-45ca-9eaf-\
70c664fd61a9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"durdtInsideDrag", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}], " ", 
     RowBox[{"UtInside", "[", 
      RowBox[{"rbar", ",", " ", "ur"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]Inside", "]"}], "[",
       "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
        "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    
    RowBox[{
     FractionBox["1", "m"], 
     RowBox[{"(", 
      RowBox[{"dpdtdragr", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.978353916195648*^9, 3.978353954131928*^9}, {
   3.9784202145464363`*^9, 3.97842021480033*^9}, {3.978424224516705*^9, 
   3.978424225284174*^9}, {3.978424487739657*^9, 3.978424488394153*^9}, 
   3.9791954782821293`*^9, 3.979556857470834*^9},
 CellLabel->
  "In[2193]:=",ExpressionUUID->"f52792dc-7aa6-4073-8fdc-65217b7f5218"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Debugging the solver not working.... Was due to the very high speed up factor \
used, causing the velocity to be discontinuous and the solver not knowing \
what to do.
Also didn\[CloseCurlyQuote]t work before I implemented machine precision as \
mentioned by Sarp.\
\>", "Subsubsection",
 CellChangeTimes->{{3.978419913143791*^9, 3.97841995025422*^9}, {
  3.979556581056897*^9, 3.9795566141443243`*^9}, {3.979557143875906*^9, 
  3.9795571632278843`*^9}},ExpressionUUID->"e0ccc12c-8e56-4f9e-bb79-\
93bc131081ff"],

Cell["\<\
Checking Limits to see why solver was not working, as mentioned was the speed \
up factor for the interior solution was not needed and only caused a \
discontinuity at the edge of the star where the two velocity equations had to \
match up. The solver was abandoning ship here. But, with limit analysis I \
fixed it.\
\>", "Text",
 CellChangeTimes->{{3.979556936013918*^9, 3.9795569561339073`*^9}, {
  3.979557010789238*^9, 
  3.979557065068748*^9}},ExpressionUUID->"41fd9bec-5143-4e18-aeda-\
bafb5a2dc27b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Limit", "[", 
     RowBox[{
      RowBox[{"durdt", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rbar", "->", "rbarStar"}], ",", " ", 
        RowBox[{"ur", " ", "->", " ", 
         RowBox[{"-", ".9"}]}]}], "}"}]}], "]"}], "]"}], " ", "//", " ", 
   "N"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Limit", "[", 
     RowBox[{
      RowBox[{"durdtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rbar", "->", "rbarStar"}], ",", " ", 
        RowBox[{"ur", " ", "->", " ", 
         RowBox[{"-", ".9"}]}]}], "}"}]}], "]"}], "]"}], " ", "//", " ", 
   "N"}], ";"}]}], "Input",
 CellChangeTimes->{{3.978419941421507*^9, 3.9784199669572783`*^9}, {
  3.979556970261409*^9, 3.9795569707337017`*^9}},
 CellLabel->
