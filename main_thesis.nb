Cell[BoxData[
 RowBox[{
  RowBox[{"tauIsotropic", "[", 
   RowBox[{"rStart_", ",", " ", "rFinish_"}], "]"}], " ", ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Urdrop", "[", "rBar", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"rBar", ",", "rStart", ",", "rFinish"}], "}"}], ",", 
    RowBox[{"WorkingPrecision", "->", "40"}]}], "]"}]}]], "Input",
