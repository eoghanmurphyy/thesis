Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"0", " ", "==", " ", 
   RowBox[{"Limit", "[", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{"rBarofrInside", "[", "r", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "0", ",", " ", "1"}], "}"}]}], " ", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "Variable", " ", "we", " ", "are", " ", "expanding", 
           " ", "\"\<r\>\""}], ",", " ", 
          RowBox[{"expand", " ", "about", " ", "\"\<0\>\""}], ",", " ", 
          RowBox[{
          "keep", " ", "terms", " ", "up", " ", "to", " ", "order", 
           " ", "\"\<1\>\""}]}], "*)"}], "]"}], ",", "\[IndentingNewLine]", 
       "\t", 
       RowBox[{"0", " ", "<", " ", "r", " ", "<", " ", "RStar"}]}], 
      "\[IndentingNewLine]", "\t", "]"}], ",", "\[IndentingNewLine]", "\t", 
     RowBox[{"r", "->", "0"}]}], "\[IndentingNewLine]", "\t", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"0", " ", "==", " ", 
