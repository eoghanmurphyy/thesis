Cell[CellGroupData[{

Cell["\<\
Solving ODEs of whole system for 1D radial drop with no external forces \
acting on the particle\
\>", "Section",
 CellChangeTimes->{{3.9783333353033447`*^9, 3.9783333529113483`*^9}, {
  3.979555741423225*^9, 3.979555741687522*^9}, {3.9795561306922007`*^9, 
  3.9795561700999823`*^9}, {3.9795563751223307`*^9, 
  3.979556376058524*^9}},ExpressionUUID->"cb34c2f0-d38e-4263-9b54-\
cef5840c6a6b"],

Cell["\<\
Two coupled first order ODEs, solved using two initial conditions, which are \
as follows:
- We set the initial velocity of the particle to zero at t=0.
- We set the distance the particle drops from outside the star.
- Numerically integrate and solve these as done below.\
\>", "Text",
 CellChangeTimes->{{3.979556173435897*^9, 
  3.979556253123331*^9}},ExpressionUUID->"4dc999a3-e4e7-4454-a380-\
76c6fefdcee7"],

Cell[CellGroupData[{

Cell["Constructing ODEs to be solved from paper", "Subsection",
 CellChangeTimes->{{3.978333176616634*^9, 3.978333182776482*^9}, {
  3.979555736223275*^9, 
  3.9795557382955923`*^9}},ExpressionUUID->"5d84efaa-9f0a-43c0-8e58-\
1f2d3a6ba8b2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"UtInside", "[", 
    RowBox[{"rbar_", ",", "ur_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]], 
    SqrtBox[
     RowBox[{"1", "+", 
      FractionBox[
       SuperscriptBox["ur", "2"], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "2"]]}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"drBardtInside", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"AInside", "[", "rbar", "]"}], "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]}]], "ur"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdtInside", "[", 
    RowBox[{"rbar_", ",", " ", "ur_"}], "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}], " ", 
     RowBox[{"UtInside", "[", 
      RowBox[{"rbar", ",", " ", "ur"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]Inside", "]"}], "[",
       "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
        "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "3"]], ")"}]}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9783331897527323`*^9, 3.9783332140172443`*^9}, {
  3.978333265480901*^9, 3.978333286944511*^9}},
 CellLabel->
  "In[2175]:=",ExpressionUUID->"a5b202ed-b514-496d-a7b5-1cd1f75c70ea"]
}, Open  ]],

