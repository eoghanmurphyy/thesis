Cell[CellGroupData[{

Cell["Performing the inside integration", "Subsubsection",
 CellChangeTimes->{{3.980421920647196*^9, 
  3.980421925692644*^9}},ExpressionUUID->"9eb24d35-dc47-4b4c-9c42-\
f3b18eaa6493"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", "=", "10000"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", "rbarStar"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"drBardt", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"drBardtInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
