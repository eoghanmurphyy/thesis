          " ", "\"\<1\>\""}]}], "*)"}], "]"}], ",", "\[IndentingNewLine]", 
      "\t", 
      RowBox[{
       RowBox[{"rbar", " ", ">", " ", "0"}], " ", 
       RowBox[{"(*", "??", "*)"}]}]}], "\[IndentingNewLine]", "\t", "]"}], ",",
