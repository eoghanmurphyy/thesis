Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tEnd", " ", "=", " ", "2500"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rStop", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "4"}]]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", " ", "=", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], " ", "==", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], " ", "==", " ", 
         RowBox[{"Piecewise", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", 
               "rbarStar"}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}]}], "]"}], ",", " ", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], " ", "<", " ", "rbarStar"}]}],
              "}"}]}], "}"}], "]"}]}], ",", " ", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], " ", "==", " ", "rbar0"}], ",", " ", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], " ", "==", " ", "0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Center", " ", "velocity", " ", "switch"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"WhenEvent", "[", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"rbar", "[", "t", "]"}], " ", "<=", " ", "rStop"}], ",", 
          " ", 
          RowBox[{
           RowBox[{"ur", "[", "t", "]"}], " ", "->", " ", 
           RowBox[{"-", 
            RowBox[{"ur", "[", "t", "]"}]}]}]}], "]"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"rbar", ",", " ", "ur"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "t0", ",", " ", "tEnd"}], "}"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Mathematica", " ", "used", " ", "to", " ", "solving", " ", "ODEs", " ", 
     "forward", " ", "in", " ", "time", " ", "or", " ", "from", " ", "left", " ",
      "to", " ", "right"}], ",", " ", 
    RowBox[{
     RowBox[{"so", " ", "impose", " ", "at", " ", "the", " ", "ur"}], " ", "=",
      " ", 
     RowBox[{
     "0", " ", "turning", " ", "point", " ", "outside", " ", "the", " ", 
      "star", " ", "that", " ", "the", " ", "odes", " ", "change", " ", 
      "accordingly", " ", "and", " ", "the", " ", "sign", " ", "flips", " ", 
      "to", " ", "give", " ", "it", " ", "no", " ", "ambiguity", " ", "and", " ",
       "to", " ", "stop", " ", "it", " ", "from", " ", "breaking"}]}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Inputted", " ", "less", " ", "stringent", " ", "criteria", " ", "on", " ",
     "rbar", " ", "in", " ", "the", " ", "WhenEvent", " ", 
    RowBox[{"(", "<=", ")"}], " ", "function", " ", "to", " ", "allow", " ", 
    "the", " ", "system", " ", "to", " ", "not", " ", "breakdown", " ", "and",
     " ", "abandon", " ", "ship", " ", "when", " ", "it", " ", 
    RowBox[{"didn", "'"}], "t", " ", "directly", " ", "satisfy", " ", "the", " ",
     "strict", " ", "equality", " ", "I", " ", "imposed"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rbarNumIn", " ", "=", " ", 
   RowBox[{"rbar", " ", "/.", " ", "solIn"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"urNumIn", " ", "=", " ", 
   RowBox[{"ur", " ", "/.", " ", "solIn"}]}], ";"}]}], "Input",
