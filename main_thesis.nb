   RowBox[{"rStart_", ",", " ", "rFinish_"}], "]"}], " ", ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Urdrop", "[", "rBar", "]"}]}], ",", 
    RowBox[{"{", 
