Cell["\<\
Now to solve for exp(\[Alpha]) metric component using the perfect fluid stuff\
\
\>", "Text",
 CellChangeTimes->{{3.980764181102366*^9, 
  3.980764209781618*^9}},ExpressionUUID->"c0bb1497-65ad-4401-8ee6-\
cff289a27708"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"grrTOV", "[", "r_", "]"}], " ", "=", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox[
        RowBox[{"2", 
         RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
     RowBox[{"-", "1"}]]}], ";"}], " ", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"alphaprime", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["1", "r"], 
   RowBox[{"(", 
    RowBox[{"grrTOV", "[", "r", "]"}], ")"}], 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"2", " ", 
       RowBox[{"MassFunc", "[", "r", "]"}]}], "r"], " ", "+", " ", 
     RowBox[{"8", " ", "Pi", " ", 
      RowBox[{"Pressurefunction", "[", "r", "]"}], " ", 
      SuperscriptBox["r", "2"]}]}], ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.9807600453988533`*^9, 3.980760046711835*^9}, {
  3.980764474644239*^9, 3.9807645366194468`*^9}},
 CellLabel->
  "In[358]:=",ExpressionUUID->"7e828342-f8ef-4b77-bec7-6e49a9ffd1c3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Alpha]", "[", 
   RowBox[{"rSchw", "[", "rbarStar", "]"}], "]"}], " ", "//", " ", 
  "N"}]], "Input",
 CellChangeTimes->{{3.980764656851988*^9, 3.9807647020584507`*^9}},
 CellLabel->
  "In[361]:=",ExpressionUUID->"3a6ffac1-cff6-4183-b76d-f7ea04060cb4"],

Cell[BoxData["0.8823529411764706`"], "Output",
 CellChangeTimes->{{3.980764699692404*^9, 3.980764702453013*^9}},
 CellLabel->
  "Out[361]=",ExpressionUUID->"9710f812-4559-4d50-8488-797a5a4309c7"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"alphasolution", " ", ":=", "\[IndentingNewLine]", 
   RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"alpha", "'"}], "[", "r", "]"}], " ", "==", " ", 
        RowBox[{"alphaprime", "[", "r", "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"alpha", "[", "RStar", "]"}], " ", "==", " ", 
         RowBox[{"\[Alpha]", "[", 
          RowBox[{"rSchw", "[", "rbarStar", "]"}], "]"}]}], " ", "//", " ", 
        "N"}]}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     "alpha", ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"r", ",", " ", "rmin", ",", " ", "RStar"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"MaxSteps", "->", "Infinity"}]}], "\[IndentingNewLine]", "]"}]}],
   ";"}]], "Input",
 CellChangeTimes->{{3.980764562595544*^9, 3.980764650026782*^9}, {
  3.980764729396267*^9, 3.9807647394185057`*^9}, {3.980764788314015*^9, 
  3.980764791401712*^9}},ExpressionUUID->"ba3e9180-289e-46b8-8a17-\
a4a7b7cd28f4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"alphaNumIn", " ", "=", " ", 
    RowBox[{"alpha", "  ", "/.", " ", "alphasolution"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gttTOV", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{"alphaNumIn", "[", "r", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.980764842274296*^9, 3.980764864056882*^9}, {
  3.98076493184041*^9, 3.980764998800125*^9}},
 CellLabel->
  "In[368]:=",ExpressionUUID->"4f16516a-a484-45f2-bd5e-0afcd2840e45"],

Cell[TextData[{
 "Now need to go to isotropic coords to get isotropic metric, so I need ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "90ccc5c1-371e-46f5-bca7-f5e4c5f6525e"],
 "(r)...."
}], "Text",
 CellChangeTimes->{{3.980765029583065*^9, 
  3.9807650597036057`*^9}},ExpressionUUID->"70b84f3c-6b0e-445a-aee1-\
59ebe3202725"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Setting up new 2D ODEs with drag of course...", "Section",
 CellChangeTimes->{{3.9795574662013397`*^9, 
  3.979557480881427*^9}},ExpressionUUID->"60532d69-0bc8-452c-b8d3-\
687df1374ea6"],

Cell[CellGroupData[{

Cell["Setting up constants and functions used", "Subsection",
 CellChangeTimes->{{3.980679446272872*^9, 3.980679450032609*^9}, {
  3.980679504848711*^9, 
  3.980679507456327*^9}},ExpressionUUID->"c56f6f32-64ee-448a-8c37-\
d032802603cc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"m", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "6"}]]}], ";"}], " ", 
  RowBox[{"(*", 
