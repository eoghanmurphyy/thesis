  3.973158240291341*^9, 3.973158258330627*^9}, {3.973158298299138*^9, 
  3.973158361420114*^9}, {3.973158411823929*^9, 3.973158417066166*^9}, {
  3.97833163800502*^9, 3.9783316756127453`*^9}, {3.978333228296906*^9, 
  3.9783332286165457`*^9}, {3.979555661448534*^9, 3.979555668023937*^9}},
 CellLabel->"In[71]:=",ExpressionUUID->"9488e013-9108-4095-bf4d-d4999a26eab5"]
}, Open  ]],

