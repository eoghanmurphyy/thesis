  RowBox[{"rbarStar", " ", "=", " ", 
   RowBox[{"rBarSchw", "[", "RStar", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"RStarVal", " ", "==", " ", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"rofRbarInside", "[", "%", "]"}], " ", "/.", " ", 
     RowBox[{"M", " ", "->", " ", "M"}]}], " ", "/.", " ", 
    RowBox[{"RStar", " ", "->", " ", "RStar"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"and", " ", "it", " ", "matches"}], ",", " ", 
    RowBox[{
    "%", " ", "takes", " ", "previous", " ", "lines", " ", "answer"}]}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9783308224517717`*^9, 3.978330844914974*^9}, {
  3.978330955210075*^9, 3.978330983697631*^9}, {3.978331018657672*^9, 
