Cell["Computing Limit by series expansion.....", "Text",
 CellChangeTimes->{{3.978331894882657*^9, 3.9783319052504787`*^9}, {
  3.979555626248177*^9, 
  3.979555639504119*^9}},ExpressionUUID->"4fb985f3-9c0a-40d6-8849-\
f7d1d60bbc4d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"0", " ", "==", " ", 
   RowBox[{"Limit", "[", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{"rBarofrInside", "[", "r", "]"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"r", ",", " ", "0", ",", " ", "1"}], "}"}]}], " ", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{
          "Variable", " ", "we", " ", "are", " ", "expanding", 
           " ", "\"\<r\>\""}], ",", " ", 
          RowBox[{"expand", " ", "about", " ", "\"\<0\>\""}], ",", " ", 
          RowBox[{
          "keep", " ", "terms", " ", "up", " ", "to", " ", "order", 
           " ", "\"\<1\>\""}]}], "*)"}], "]"}], ",", "\[IndentingNewLine]", 
       "\t", 
       RowBox[{"0", " ", "<", " ", "r", " ", "<", " ", "RStar"}]}], 
      "\[IndentingNewLine]", "\t", "]"}], ",", "\[IndentingNewLine]", "\t", 
     RowBox[{"r", "->", "0"}]}], "\[IndentingNewLine]", "\t", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"0", " ", "==", " ", 
  RowBox[{"Limit", "[", "\[IndentingNewLine]", "\t", 
   RowBox[{
    RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"rofRbarInside", "[", "rbar", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"rbar", ",", " ", "0", ",", " ", "1"}], "}"}]}], " ", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Variable", " ", "we", " ", "are", " ", "expanding", 
          " ", "\"\<r\>\""}], ",", " ", 
         RowBox[{"expand", " ", "about", " ", "\"\<0\>\""}], ",", " ", 
         RowBox[{
         "keep", " ", "terms", " ", "up", " ", "to", " ", "order", 
          " ", "\"\<1\>\""}]}], "*)"}], "]"}], ",", "\[IndentingNewLine]", 
      "\t", 
      RowBox[{
       RowBox[{"rbar", " ", ">", " ", "0"}], " ", 
       RowBox[{"(*", "??", "*)"}]}]}], "\[IndentingNewLine]", "\t", "]"}], ",",
     "\[IndentingNewLine]", "\t", 
    RowBox[{"rbar", "->", "0"}]}], "\[IndentingNewLine]", "\t", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.978331910876224*^9, 3.978332021417762*^9}, {
