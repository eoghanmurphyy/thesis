Cell[TextData[{
 "Solver does not work when inside the star at the point seen in the graph \
above, as the unavoidable singularity in the drag equation blows up here when \
",
 StyleBox["ur",
  IgnoreSpellCheck->True],
 " goes to 0 inside."
}], "Text",
