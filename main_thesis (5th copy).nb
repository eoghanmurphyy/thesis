Cell[CellGroupData[{

Cell["\<\
Defining the derivative of alpha which is causing wholesale problems\
\>", "Subsubsection",
 CellChangeTimes->{{3.982308486466215*^9, 
  3.982308497650181*^9}},ExpressionUUID->"c0085bb3-5ebe-4d1b-b182-\
3144c20331d1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dPhidrMetric", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"MassFunc", "[", 
       RowBox[{"rofrbarFull", "[", "rbar", "]"}], "]"}], 
      SuperscriptBox[
       RowBox[{"rofrbarFull", "[", "rbar", "]"}], "2"]], 
     RowBox[{"(", 
      RowBox[{"1", " ", "+", " ", 
       FractionBox[
        RowBox[{"4", " ", "Pi", " ", 
         RowBox[{"(", 
          RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}], ")"}], " ", 
         SuperscriptBox[
          RowBox[{"rofrbarFull", "[", "rbar", "]"}], "3"]}], 
        RowBox[{"MassFunc", "[", 
         RowBox[{"rofrbarFull", "[", "rbar", "]"}], "]"}]]}], ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox[
         RowBox[{"2", " ", 
          RowBox[{"MassFunc", "[", 
           RowBox[{"rofrbarFull", "[", "rbar", "]"}], "]"}]}], 
         RowBox[{"rofrbarFull", "[", "rbar", "]"}]]}], ")"}], 
      RowBox[{"-", "1"}]]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DER\[Alpha]Inside", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"dPhidrMetric", "[", "rbar", "]"}], " ", 
    RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DER\[Alpha]Full", "[", "rbar_", "]"}], " ", ":=", " ", 
  RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"DER\[Alpha]Inside", "[", "rbar", "]"}], ",", " ", 
       RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
        "rbar", "]"}], ",", " ", 
       RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
    "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.982308541378194*^9, 3.982308643329699*^9}, {
  3.98230879818456*^9, 3.982308839840893*^9}, {3.982308921999395*^9, 
