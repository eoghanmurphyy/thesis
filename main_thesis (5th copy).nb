  RowBox[{"(*", 
   RowBox[{"This", " ", "is", " ", "my", " ", "dmdt", " ", "equation"}], 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"mdot", "[", 
      RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
