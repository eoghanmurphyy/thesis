               RowBox[{"UtInside", "[", 
                RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
             ")"}], "2"]}]], ")"}], 
        FractionBox["q", "2"]], "ur"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"dpdtaccretionphi", "[", 
       RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
