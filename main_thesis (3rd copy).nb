   RowBox[{"rbar_", ",", " ", "r_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["r", "rbar"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
    FractionBox["1", "2"]]}]}]], "Input",
 CellChangeTimes->{{3.982220687335125*^9, 3.982220702006654*^9}},
 CellLabel->
  "In[193]:=",ExpressionUUID->"556c51bc-7c0e-48a4-bbe8-f4b2a462cfcd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"rofrbar", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"drbardr", "[", 
     RowBox[{
      RowBox[{"rofrbar", "[", "r", "]"}], ",", " ", "r"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BC", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rofrbar", "[", "rbarStar", "]"}], " ", "==", " ", "RStar"}], 
    "}"}]}], ";"}]}], "Input",
