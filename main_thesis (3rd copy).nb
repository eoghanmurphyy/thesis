Cell[CellGroupData[{

Cell["Rates of change of velocities", "Subsubsection",
 CellChangeTimes->{{3.9822988937987413`*^9, 
  3.982298900110568*^9}},ExpressionUUID->"e0e235e0-d776-4851-8c81-\
c1a8cd5b1531"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"drBardtInside", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "2"], 
       RowBox[{"UtInside", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "ur"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dphidtInside", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["rbar", "2"], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "2"], 
       RowBox[{"UtInside", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "uphi"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"duphidtInside", "[", 
     RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{
     FractionBox["\[Eta]", "m"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dpdtdragphi", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], " ", "+", " ", 
       RowBox[{"dpdtaccretionphi", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt2DInside", "[", 
    RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}], " ", 
     RowBox[{"UtInside", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]Inside", "]"}], "[",
       "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
        "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    
    RowBox[{
     FractionBox[
      SuperscriptBox["uphi", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox["rbar", "3"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
         "rbar", "]"}], 
        RowBox[{
         SuperscriptBox["rbar", "2"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "3"]}]]}], ")"}]}], " ", "+",
     "  ", 
    RowBox[{
     FractionBox["\[Eta]", "m"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dpdtdragr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], "+", " ", 
       RowBox[{"dpdtaccretionr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}]}], ")"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9822991262851753`*^9, 3.982299127478025*^9}, {
  3.982299258355927*^9, 3.982299259484717*^9}},
 CellLabel->
  "In[255]:=",ExpressionUUID->"56bdc2ee-d76d-4d9e-a50c-05af4ceb5752"]
