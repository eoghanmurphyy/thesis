Cell[TextData[{
 "Now using the interpolation trick to obtain ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", 
    OverscriptBox["r", "_"]}], TraditionalForm]],ExpressionUUID->
  "1edab06a-7f8b-425d-99ba-242f116f9c58"],
 "):"
}], "Text",
 CellChangeTimes->{{3.982125636064583*^9, 
  3.9821256503703814`*^9}},ExpressionUUID->"c897a830-890f-4a9c-b34c-\
eb19cc233dcc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Generating", " ", "the", " ", "numerical", " ", "data", " ", 
    RowBox[{"points", ":"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Table", "[", " ", 
    RowBox[{"expression", ",", " ", 
     RowBox[{"{", 
      RowBox[{
      "variable", ",", " ", "start", ",", " ", "end", ",", " ", "step"}], 
      "}"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"data", " ", "=", " ", 
    RowBox[{"Prepend", "[", 
     RowBox[{
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"rbarofrInside", "[", "r", "]"}], ",", " ", "r"}], "}"}], ",",
         " ", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Here", " ", "Mathematica", " ", "stores", " ", 
           RowBox[{"rbar", "[", "r", "]"}], " ", "and", " ", "r", " ", "as", " ",
            "a", " ", "2", " ", "element", " ", "list"}], " ", "-", " ", 
          RowBox[{
          "first", " ", "entry", " ", "is", " ", "the", " ", "independent", " ",
            "variable", " ", "and", " ", "the", " ", "one", " ", "after", " ",
            "is", " ", "the", " ", "dependent", " ", "variable"}]}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"r", ",", " ", "rmin", ",", " ", "RStar", ",", " ", 
          FractionBox[
           RowBox[{"RStar", " ", "-", " ", "rmin"}], "100000"]}], "}"}]}], 
       " ", 
       RowBox[{"(*", 
        RowBox[{"500", " ", "points"}], "*)"}], "\[IndentingNewLine]", "]"}], 
      ",", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.982125698040905*^9, 3.982125763249017*^9}, {
  3.9821258310392637`*^9, 3.9821259483264914`*^9}, {3.982126154516618*^9, 
  3.982126171508658*^9}, {3.982126530185457*^9, 3.982126537161551*^9}, {
  3.9823073744677553`*^9, 3.982307376147428*^9}, {3.982307856167369*^9, 
  3.9823078579437447`*^9}, {3.982392143002308*^9, 3.982392146363154*^9}, {
  3.98239219825007*^9, 3.9823921988818617`*^9}, {3.982392266193563*^9, 
  3.982392275737377*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"74a09ea2-0ab1-4de8-9013-c7ab391218ec"],

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"(*", 
   RowBox[{
   "Evaluates", " ", "ok", " ", "at", " ", "zero", " ", "as", " ", "sapr", " ",
     "mentioned", " ", "but", " ", "integral", " ", 
    RowBox[{"doesn", "'"}], "t", " ", "like", " ", "it", " ", "one", " ", 
    "bit"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.982125950494925*^9, 3.982125966510107*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"d6c3b0fe-886c-4aef-a032-f82335edee9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Inverse", " ", "Interpolation"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"rofrbarInside", " ", "=", " ", 
    RowBox[{"Interpolation", "[", "data", "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Builds", " ", "a", " ", "function", " ", "from", " ", "the", " ", "data",
      " ", "passing", " ", "through", " ", "all", " ", "points", " ", 
     "unlike", " ", "Fit", " ", "which", " ", "approximately", " ", "matches",
      " ", "the", " ", "data", " ", "to", " ", "a", " ", "function", " ", "I",
      " ", "give", " ", "it", " ", "with", " ", "parameters"}], ",", "  ", 
    RowBox[{
    "FindFit", " ", "finds", " ", "the", " ", "parameters", " ", "for", " ", 
     "me", " ", "given", " ", "I", " ", "guess", " ", "a", " ", "suitable", " ",
      "function"}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9821259732469397`*^9, 3.982126030638027*^9}, {
  3.9821262064686623`*^9, 3.98212623222003*^9}, {3.9821263055473022`*^9, 
  3.982126352219092*^9}, {3.9821317891522923`*^9, 3.9821317899126863`*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"430cbe52-6750-4ff1-be88-d140599d765e"],

