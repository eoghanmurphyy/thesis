18602978d726"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dPhidrMetric", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"(", 
   FractionBox[
    RowBox[{
     RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
     RowBox[{"4", " ", "Pi", " ", 
      RowBox[{"Pressure", "[", "r", "]"}], " ", 
      SuperscriptBox["r", "3"]}]}], 
    RowBox[{"r", 
     RowBox[{"(", 
      RowBox[{"r", "-", 
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}]], "Input",
 CellChangeTimes->{{3.982393502718885*^9, 3.9823935097345247`*^9}, {
  3.982399278079626*^9, 3.982399279215176*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"515f1ef7-7469-42e0-aee7-ee3412433acc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"alpha", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"Exp", "[", 
   RowBox[{"PhiMetric", "[", "r", "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DERalphaIns", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"dPhidrMetric", "[", "r", "]"}], " ", 
   RowBox[{"alpha", "[", "r", "]"}]}]}]}], "Input",
