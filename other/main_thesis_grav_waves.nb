Cell[BoxData[{
 RowBox[{
  RowBox[{"asosprimenearRStar", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", 
     SqrtBox[
      RowBox[{"asos", "[", "r", "]"}]]}]], 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"Pdoubleprime", "[", "r", "]"}], 
      RowBox[{"drhodr", "[", "r", "]"}]], " ", "-", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"dPdr", "[", 
        RowBox[{"r", ",", " ", 
         RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"drhodr", "[", "r", "]"}], ")"}], "2"]], 
      RowBox[{
       RowBox[{"drhodr", "'"}], "[", "r", "]"}]}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
