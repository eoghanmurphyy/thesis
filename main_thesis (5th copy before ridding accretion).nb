         RowBox[{"rho", "[", "r", "]"}], " ", "+", " ", "Pressure"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", 
         FractionBox[
          RowBox[{"4", " ", "Pi", " ", 
           RowBox[{"(", "Pressure", ")"}], " ", 
           SuperscriptBox["r", "3"]}], 
          RowBox[{"MassFunc", "[", "r", "]"}]]}], ")"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", " ", "-", " ", 
          FractionBox[
           RowBox[{"2", " ", 
            RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
        RowBox[{"-", "1"}]]}], "]"}]}]}], ";"}]}]], "Input",
