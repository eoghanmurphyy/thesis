Cell[CellGroupData[{

Cell["Rates of change of velocities", "Subsubsection",
 CellChangeTimes->{{3.9822988937987413`*^9, 
  3.982298900110568*^9}},ExpressionUUID->"e0e235e0-d776-4851-8c81-\
c1a8cd5b1531"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"drBardtInside", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "2"], 
       RowBox[{"UtInside", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "ur"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dphidtInside", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["rbar", "2"], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "2"], 
       RowBox[{"UtInside", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "uphi"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"duphidtInside", "[", 
     RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{
     FractionBox["\[Eta]", "m"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dpdtdragphi", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], " ", "+", " ", 
       RowBox[{"dpdtaccretionphi", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt2DInside", "[", 
    RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}], " ", 
     RowBox[{"UtInside", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]Inside", "]"}], "[",
       "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
        "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    
    RowBox[{
     FractionBox[
      SuperscriptBox["uphi", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox["rbar", "3"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
         "rbar", "]"}], 
        RowBox[{
         SuperscriptBox["rbar", "2"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "3"]}]]}], ")"}]}], " ", "+",
     "  ", 
    RowBox[{
     FractionBox["\[Eta]", "m"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dpdtdragr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], "+", " ", 
       RowBox[{"dpdtaccretionr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}]}], ")"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9822991262851753`*^9, 3.982299127478025*^9}, {
  3.982299258355927*^9, 3.982299259484717*^9}},
 CellLabel->"In[95]:=",ExpressionUUID->"56bdc2ee-d76d-4d9e-a50c-05af4ceb5752"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Defining Energy and Angular momentum per unit mass functions along with other \
orbital parameters\
\>", "Section",
 CellChangeTimes->{{3.98041330662858*^9, 3.9804133112081738`*^9}, {
  3.9806797688460484`*^9, 
  3.980679791293557*^9}},ExpressionUUID->"51e0d69c-b380-4d1f-9de9-\
7e98db5a5139"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"EnergyPerUnitMass", "[", 
    RowBox[{"ptilde_", ",", " ", "eccen_"}], "]"}], " ", ":=", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"ptilde", " ", "-", "2"}], ")"}], "2"], " ", "-", " ", 
      RowBox[{"4", " ", "*", 
       SuperscriptBox["eccen", "2"]}]}], 
     RowBox[{"ptilde", "*", 
      RowBox[{"(", 
       RowBox[{"ptilde", " ", "-", " ", "3", " ", "-", " ", 
        SuperscriptBox["eccen", "2"]}], ")"}]}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"LPerUnitMass", "[", 
    RowBox[{"ptilde_", ",", " ", "M_", ",", " ", "eccen_"}], "]"}], " ", ":=",
    " ", 
   FractionBox[
    RowBox[{"ptilde", "*", "M"}], 
    SqrtBox[
     RowBox[{"ptilde", " ", "-", " ", "3", " ", "-", " ", 
      SuperscriptBox["eccen", "2"]}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ptildefunc", "[", 
    RowBox[{"p_", ",", " ", "Mass_"}], "]"}], " ", ":=", " ", 
   FractionBox["p", "Mass"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rapoapsis", "[", 
     RowBox[{"eccen_", ",", " ", "ptilde_", ",", " ", "Mass_"}], "]"}], " ", ":=",
     " ", 
    FractionBox[
     RowBox[{
      RowBox[{"(", "ptilde", ")"}], "*", "Mass"}], 
     RowBox[{"1", " ", "-", " ", "eccen"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "In", " ", "Schwarzschild", " ", "areal", " ", "r", " ", "coordinates"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rperiapsis", "[", 
    RowBox[{"eccen_", ",", " ", "ptilde_"}], "]"}], " ", ":=", " ", 
   FractionBox["ptilde", 
    RowBox[{"1", "+", "eccen"}]]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9804133126715603`*^9, 3.980413420824196*^9}, {
   3.980413505300097*^9, 3.980413624003992*^9}, {3.980413790075656*^9, 
   3.980413805693198*^9}, {3.980428531832149*^9, 3.9804285692626743`*^9}, {
