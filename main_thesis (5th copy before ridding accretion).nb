      RowBox[{"rofrbar", "[", "r", "]"}], ",", " ", "r"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BC", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rofrbar", "[", "rbarStar", "]"}], " ", "==", " ", "RStar"}], 
    "}"}]}], ";"}]}], "Input",
