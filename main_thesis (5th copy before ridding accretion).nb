Cell[CellGroupData[{

Cell["\<\
Gets very messy from here downwards: doing it the Taylor expansion way\
\>", "Subsubsection",
 CellChangeTimes->{{3.98214322179744*^9, 3.982143233197159*^9}, {
  3.982208794960548*^9, 
  3.982208802303178*^9}},ExpressionUUID->"2bed9dc5-480c-4f3f-95fa-\
ea5b96ce94e9"],

Cell["Limit at RStar diverges -> Taylor expland", "Text",
 CellChangeTimes->{{3.9821325104444838`*^9, 3.982132533202694*^9}, {
  3.982299975183461*^9, 
  3.98229998529342*^9}},ExpressionUUID->"27668e9a-c049-4ac9-8b12-\
41fee34e0ce9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Pdoubleprime", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"dPdr", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"Pressure", "[", "x", "]"}]}], "]"}], ",", " ", "x"}], "]"}], 
   " ", "/.", " ", 
   RowBox[{"x", "->", "r", "  ", 
    RowBox[{"(*", 
     RowBox[{"Must", " ", "use", " ", "D", " ", 
      RowBox[{"as", " ", "'"}], " ", "only", " ", "differentiates", " ", 
      RowBox[{"wrt", ".", " ", "the"}], " ", "first", " ", "argument"}], 
     "*)"}]}]}]}]], "Input",
 CellChangeTimes->{{3.982133314509489*^9, 3.98213336595647*^9}, {
   3.982133937327779*^9, 3.9821339585195017`*^9}, 3.982134059126745*^9, {
   3.982134099310668*^9, 3.982134117798394*^9}},
 CellLabel->"In[52]:=",ExpressionUUID->"3f4d4978-489d-458c-ae33-8f3956de7f25"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"asosprimenearRStar", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", 
     SqrtBox[
      RowBox[{"asos", "[", "r", "]"}]]}]], 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      RowBox[{"Pdoubleprime", "[", "r", "]"}], 
      RowBox[{"drhodr", "[", "r", "]"}]], " ", "-", " ", 
     RowBox[{
      FractionBox[
       RowBox[{"dPdr", "[", 
        RowBox[{"r", ",", " ", 
         RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"drhodr", "[", "r", "]"}], ")"}], "2"]], 
      RowBox[{
       RowBox[{"drhodr", "'"}], "[", "r", "]"}]}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"asosprimenearRStar", "[", "7.974", "]"}], " ", "//", " ", "N"}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.982133391276637*^9, 3.982133545196021*^9}, {
   3.982133808856876*^9, 3.982133817648992*^9}, {3.982133966759605*^9, 
   3.982134030830803*^9}, 3.982134180525749*^9, {3.982134471332143*^9, 
   3.982134485891388*^9}, {3.982135761569252*^9, 3.982135762378352*^9}, 
   3.982135801169031*^9, {3.9821361135192013`*^9, 3.982136134182212*^9}, {
   3.98213641885999*^9, 3.9821364292440157`*^9}, {3.982143093391047*^9, 
   3.9821430938467197`*^9}, 3.982208740160068*^9},
 CellLabel->"In[53]:=",ExpressionUUID->"e29ed64b-50bd-4e49-b2df-6c4ddd49c01a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"epsilon", " ", "=", " ", "0.026"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"from", " ", "RStar"}], " ", "-", " ", 
    RowBox[{
    "7.974", " ", "which", " ", "is", " ", "oscillating", " ", "only", " ", 
     "in", " ", "the", " ", "1", "e"}], "-", 
    RowBox[{
    "4", " ", "range", " ", "for", " ", "alphaprime", " ", "which", " ", "is",
      " ", "very", " ", "small"}]}], "*)"}]}]], "Input",
