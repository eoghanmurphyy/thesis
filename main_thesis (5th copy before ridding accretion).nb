 CellLabel->"In[34]:=",ExpressionUUID->"63cbd587-f77e-48de-b25f-cc829f5b4baf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol2", " ", "=", " ", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
