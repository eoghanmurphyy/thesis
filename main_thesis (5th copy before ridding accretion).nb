Cell[CellGroupData[{

Cell["Density and Pressure in isotropic coordinates", "Subsubsection",
 CellChangeTimes->{{3.98214419447678*^9, 
  3.982144207292704*^9}},ExpressionUUID->"34e47b57-59dc-4842-b455-\
590b2172bc05"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rho0", " ", "=", " ", 
   RowBox[{
    RowBox[{"rhoCentre", "[", "RStar", "]"}], " ", "//", "N"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.982209003901071*^9, 3.982209036550136*^9}, {
  3.982209889582061*^9, 3.982209891022757*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"8c53e0f3-78d4-445b-826b-df27ee405567"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rho", "[", "rbar_", "]"}], " ", ":=", 
    RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
