Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"durdt2DInside", "[", 
    RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}], " ", 
     RowBox[{"UtInside", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]Inside", "]"}], "[",
       "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
        "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    
    RowBox[{
     FractionBox[
      SuperscriptBox["uphi", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox["rbar", "3"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "AInside", "]"}], "[", 
         "rbar", "]"}], 
        RowBox[{
         SuperscriptBox["rbar", "2"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "3"]}]]}], ")"}]}], " ", "+",
     "  ", 
    RowBox[{
     FractionBox["\[Eta]", "m"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dpdtdragr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], "+", " ", 
       RowBox[{"dpdtaccretionr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}]}], ")"}]}]}]}], ";"}]], "Input",ExpressionUUID->"32cf922c-1cd0-\
449c-83cc-e93c0bd7e5ba"],

