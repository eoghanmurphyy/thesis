     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"-", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"MassFunc", "[", "r", "]"}], 
