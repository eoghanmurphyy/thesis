    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"P", "[", "RStar", "]"}], " ", "==", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"Phi", "[", "RStar", "]"}], " ", "==", " ", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], "]"}]}]}]}], "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
