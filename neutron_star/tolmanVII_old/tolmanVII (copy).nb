            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}]}], ")"}]}], "+", 
        RowBox[{"r", " ", 
         RowBox[{"MassFunction", "[", "r", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{"rd", "^", "4"}]}], "-", 
           RowBox[{"6", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"3", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}]}], "+", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}], " ", 
               RowBox[{"Mp", "[", "r", "]"}]}]}], ")"}]}], "+", 
           RowBox[{
            RowBox[{"rd", "^", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"63", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}], "+", 
              RowBox[{"Mp", "[", "r", "]"}], "-", 
              RowBox[{"3", " ", "r", " ", 
               RowBox[{"Mpp", "[", "r", "]"}]}]}], ")"}]}]}], ")"}]}], "+", 
        RowBox[{
         RowBox[{"r", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}], " ", 
            RowBox[{"Mp", "[", "r", "]"}]}], "-", 
