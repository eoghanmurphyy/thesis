Cell[CellGroupData[{

Cell["Defining the ODE", "Subsection",
 CellChangeTimes->{3.982824230159925*^9},
 CellLabel->"In[34]:=",ExpressionUUID->"90c55aba-24f5-48bf-bd20-e83c2469f160"],

Cell[BoxData[
 RowBox[{
  RowBox[{"drbardr", "[", 
   RowBox[{"rbar_", ",", " ", "r_"}], "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox["rbar", "r"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
    RowBox[{"-", 
     FractionBox["1", "2"]}]]}]}]], "Input",
 CellChangeTimes->{{3.982124161189411*^9, 3.98212418850879*^9}, {
   3.982124241267745*^9, 3.9821242702282133`*^9}, {3.982124302635882*^9, 
   3.982124346387186*^9}, 3.982124382595275*^9, {3.982124431866364*^9, 
   3.982124441298533*^9}, {3.982817882861746*^9, 3.982817901131568*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"900f9f42-63ae-4986-8fe1-f5296d4b4d66"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Numerically Integrating the above equation", "Subsection",
 CellChangeTimes->{{3.9821243981068573`*^9, 3.982124406532078*^9}, 
   3.982817893835395*^9},ExpressionUUID->"3e42a8c5-626c-4aa0-98c9-\
2985b26a659e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"rbarofr", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"drbardr", "[", 
     RowBox[{
      RowBox[{"rbarofr", "[", "r", "]"}], ",", " ", "r"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BC", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rbarofr", "[", "RStar", "]"}], " ", "==", " ", "rbarStar"}], 
    "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9821244079560432`*^9, 3.9821245139540443`*^9}, {
   3.982124592345339*^9, 3.9821246242649517`*^9}, {3.982124799991644*^9, 
   3.9821248022163687`*^9}, {3.982124857431315*^9, 3.982124873838958*^9}, {
   3.982125338067565*^9, 3.982125342979814*^9}, 3.982819549904872*^9, 
   3.9828201481810503`*^9, 3.982820305443802*^9, 3.982820578777367*^9},
 CellLabel->"In[29]:=",ExpressionUUID->"01eb8131-4c78-46d5-bcf6-44cb7479790f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol2", " ", "=", " ", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eq", ",", "\[IndentingNewLine]", "BC"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "rbarofr", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "RStar", ",", " ", "rmin"}], "}"}]}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"WorkingPrecision", "->", "40"}], ",", "\[IndentingNewLine]", 
       RowBox[{"AccuracyGoal", "->", "20"}], ",", " ", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "I", " ", "want", " ", "the", " ", "answer", " ", "correct", " ", 
          "up", " ", "to", " ", 
          RowBox[{"10", "^", 
           RowBox[{"-", "8"}]}]}], " ", "->", " ", 
         RowBox[{"8", " ", "correct", " ", "decimals"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"PrecisionGoal", "->", "20"}]}], "*)"}], " ", 
     RowBox[{"(*", 
