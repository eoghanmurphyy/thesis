  FractionBox[
   SqrtBox[
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["ur", "2"], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["uphi", "rbar"], ")"}], "2"]}], ")"}]], 
   RowBox[{"A", "[", "rbar", "]"}]]}]}], "Input",
