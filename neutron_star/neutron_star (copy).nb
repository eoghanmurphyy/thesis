Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"TOV", " ", "differential", " ", "equation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPdr", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"rho", "[", "r", "]"}], " ", "+", " ", "Pressure"}], ")"}]}], 
     
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
        RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
         SuperscriptBox["r", "3"]}]}], 
       RowBox[{"r", 
        RowBox[{"(", 
         RowBox[{"r", "-", 
          RowBox[{"2", 
           RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.9807601294062366`*^9, 3.98076013474163*^9}, {
   3.980760167277755*^9, 3.980760297804946*^9}, {3.98076131275782*^9, 
