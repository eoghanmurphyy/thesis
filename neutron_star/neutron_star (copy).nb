91a0a0f5e9c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MassFunc", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"4", " ", "Pi", " ", "rho0", " ", 
        SuperscriptBox["RStar", "3"], " ", 
        RowBox[{"(", " ", 
         RowBox[{
          RowBox[{
           FractionBox["1", "3"], 
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox["r", "RStar"], ")"}], "3"]}], " ", "-", " ", 
          RowBox[{
           FractionBox["alphaaa", "5"], 
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox["r", "RStar"], ")"}], "5"]}], " ", "+", " ", 
          RowBox[{
           RowBox[{"(", 
            FractionBox[
             RowBox[{"alphaaa", "-", "1"}], "7"], ")"}], 
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox["r", "RStar"], ")"}], "7"]}]}], ")"}]}], ",", " ", 
       RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"M", ",", " ", 
       RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
    "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.982736930831874*^9, 3.9827370736477203`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"b4b759dd-a8a4-4ce2-9be2-e52352f5567a"]
}, Open  ]],

