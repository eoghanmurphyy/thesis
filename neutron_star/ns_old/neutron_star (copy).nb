Cell[CellGroupData[{

Cell["Average, physical energy loss per orbit N/A", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 3.982908628893798*^9}, {
  3.982988522570265*^9, 
  3.9829885238956738`*^9}},ExpressionUUID->"bd502297-98ef-4586-bd58-\
e3b61dd5363e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", "3"}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", "5"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"73", "/", "24"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"37", "/", "96"}], ")"}], " ", 
      RowBox[{"e", "^", "4"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}},
 CellLabel->
  "In[195]:=",ExpressionUUID->"b6090826-4043-4826-b3d2-751d8863158b"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t)\
\>", "Text",
 CellChangeTimes->{{3.982908944388515*^9, 
  3.982908980562503*^9}},ExpressionUUID->"525a2003-c3bd-463b-b19f-\
13126fde25ae"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Angular momentum loss during orbits", "Section",
 CellChangeTimes->{{3.9829080587145233`*^9, 3.982908071585734*^9}, {
  3.982908598693872*^9, 3.9829086053179703`*^9}, {3.982908873003482*^9, 
  3.982908877363311*^9}},ExpressionUUID->"554499fa-d0e6-4ba4-869a-\
bf1d66353ea6"],

Cell[CellGroupData[{

Cell["\<\
Instantaneous angular momentum loss (coordinate system dependent)\
\>", "Subsection",
 CellChangeTimes->{{3.98290861036561*^9, 3.982908637213344*^9}, {
  3.982908904907382*^9, 
  3.982908909299267*^9}},ExpressionUUID->"e87e1c13-79c0-4fb1-8210-\
1784f82d5ad8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"dLdtOutside", "[", 
   RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
   "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"FRRphi", "[", 
      RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
      "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dLdtInside", "[", 
   RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
   "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"FRRphiIns", "[", 
      RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
