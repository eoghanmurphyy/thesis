Cell[BoxData[
 RowBox[{
  RowBox[{"hxOutside", "[", 
   RowBox[{
   "d_", ",", " ", "m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", 
    "uphi_", ",", " ", "phi_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], ",", " ", "rd", ",", 
      " ", "phid"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rd", " ", "=", " ", 
      RowBox[{"drBardt", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", " ", "=", " ", 
      RowBox[{"dphidtOutside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], "m"}], "d"], ")"}], 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{"M", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"2", " ", "phi"}], "]"}]}], "r"], " ", "-", " ", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"rd", " ", 
