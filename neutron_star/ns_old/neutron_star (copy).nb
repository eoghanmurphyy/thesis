 CellLabel->"In[48]:=",ExpressionUUID->"f9757533-d2f2-4d48-9cc6-626b537312eb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DERalpha", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"drbardr", "[", "r", "]"}], "  ", 
   RowBox[{"DER\[Alpha]Outsiderbar", "[", "r", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Chain", " ", "rule"}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.98239376174957*^9, 3.982393776652556*^9}, {
