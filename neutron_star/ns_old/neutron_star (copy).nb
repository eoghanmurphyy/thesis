Cell[BoxData[
 RowBox[{
  RowBox[{"hplusOutside", "[", 
   RowBox[{
   "d_", ",", " ", "m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", 
    "uphi_", ",", " ", "phi_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], ",", " ", "rd", ",", 
      " ", "phid"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
