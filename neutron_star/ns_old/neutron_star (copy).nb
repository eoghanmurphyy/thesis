        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"r", " ", "phid"}], ")"}], "2"], 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "phi"}], "]"}]}]}], ")"}]}]}]}], "\[IndentingNewLine]",
