     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], "m"}], "d"], ")"}], 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{"M", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "phi"}], "]"}]}], "r"], " ", "-", " ", 
        RowBox[{
         SuperscriptBox["rd", "2"], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "phi"}], "]"}]}], " ", "+", " ", 
