Cell[CellGroupData[{

Cell["Average, physical angular momentum loss per orbit N/A", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 3.982908628893798*^9}, {
  3.9829089136749773`*^9, 3.982908917635139*^9}, {3.982988527479395*^9, 
  3.982988528583199*^9}},ExpressionUUID->"d69e7639-3ccb-44c7-8276-\
54a47aa56311"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
   "Formula", " ", "might", " ", "need", " ", "to", " ", "be", " ", 
    "adjusted", " ", "for", " ", "me", " ", "as", " ", "they", " ", "use", " ",
     "the", " ", "angle", " ", "phi"}], " ", "=", " ", 
   RowBox[{
   "0", " ", "for", " ", "when", " ", "it", " ", "crosses", " ", "the", " ", 
    "star", " ", "surface", " ", "which", " ", "is", " ", "not", " ", "true", 
    " ", "for", " ", "me"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9829091670181303`*^9, 3.982909195169149*^9}},
 CellLabel->
  "In[200]:=",ExpressionUUID->"b0b9c8ec-76d0-4f1b-9805-19935559137d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dLdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", 
        RowBox[{"(", 
         RowBox[{"5", "/", "2"}], ")"}]}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", "2", ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "/", "8"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}, {
  3.982908921003359*^9, 3.98290892892343*^9}, {3.982909074962366*^9, 
  3.98290911543382*^9}},
 CellLabel->
  "In[201]:=",ExpressionUUID->"3a310e56-8f43-453b-a17e-b116bc76f2fe"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t).\
\>", "Text",
