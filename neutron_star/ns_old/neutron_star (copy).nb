Cell[BoxData[
 RowBox[{
  RowBox[{"asosPiecewise", "[", 
   RowBox[{"rbar_", "?", "NumericQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], "}"}], ",", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "@", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"dPdr", "[", 
             RowBox[{"r", ",", 
              RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], "/", 
            RowBox[{"drhodr", "[", "r", "]"}]}], "]"}]}], ",", 
         RowBox[{"rbar", "<", 
          RowBox[{".9999999999", "rbarStar"}]}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         SuperscriptBox["10", 
          RowBox[{"-", "6"}]], ",", " ", 
