Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"C1Imp", " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{"2", "ScriptC"}]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"1", " ", "+", " ", 
       FractionBox[
        RowBox[{"8", " ", "Pi", " ", 
         SuperscriptBox["RStar", "2"], " ", "rho0", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"10", " ", "-", " ", 
            RowBox[{"3", " ", "alpha"}]}], ")"}], "2"], 
         RowBox[{"(", 
          RowBox[{"15", " ", "-", " ", 
           RowBox[{"16", " ", "Pi", " ", 
            SuperscriptBox["RStar", "2"], " ", "rho0"}]}], ")"}]}], 
        RowBox[{"3", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"105", " ", "+", " ", 
            RowBox[{"16", " ", "Pi", " ", 
             SuperscriptBox["RStar", "2"], " ", "rho0", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"3", " ", "alpha"}], "-", "10"}], ")"}]}]}], ")"}], 
          "2"]}]]}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"C2Imp", " ", "=", " ", 
   RowBox[{
    RowBox[{"ArcTan", "[", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"(", 
         RowBox[{"10", " ", "-", " ", 
          RowBox[{"3", "alpha"}]}], ")"}], "RStar", " ", 
        RowBox[{"Sqrt", "[", 
