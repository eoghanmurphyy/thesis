          RowBox[{"(", 
           RowBox[{"15", " ", "-", " ", 
            RowBox[{"16", " ", "Pi", " ", "rho0", " ", 
             SuperscriptBox["RStar", "2"]}]}], ")"}]}], "]"}]}], 
       RowBox[{
        RowBox[{"48", " ", "Pi", " ", 
         RowBox[{"(", 
          RowBox[{"10", " ", "-", " ", 
           RowBox[{"3", " ", "alpha"}]}], ")"}], "rho0", " ", 
         SuperscriptBox["RStar", "2"]}], "-", "315"}]]}], "]"}], " ", "+", 
    " ", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"Log", "[", 
      RowBox[{
       FractionBox["1", "6"], " ", "+", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         FractionBox["5", 
          RowBox[{"8", " ", "Pi", " ", "rho0", " ", 
           SuperscriptBox["RStar", "2"]}]], " ", "-", " ", 
         FractionBox["2", "3"]}], "]"}]}], "]"}]}]}]}], ";"}]}], "Input",
