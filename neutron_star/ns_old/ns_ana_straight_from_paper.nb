Cell[CellGroupData[{

Cell["Pressure", "Subsection",
 CellChangeTimes->{{3.982738139606449*^9, 
  3.9827381406540337`*^9}},ExpressionUUID->"be278118-46fb-41f1-a447-\
2c55242094d8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Pressure", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"Sqrt", "[", 
     FractionBox[
      RowBox[{
       RowBox[{"grrTol", "[", "r", "]"}], " ", "rho0"}], 
      RowBox[{"10", " ", "Pi"}]], "]"}], 
    RowBox[{"(", 
     FractionBox[
      RowBox[{"Tan", "[", 
       RowBox[{"PhiImp", "[", "r", "]"}], "]"}], "RStar"], ")"}]}], " ", "+", 
   " ", 
   RowBox[{
    FractionBox["1", "15"], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"3", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["r", "RStar"], ")"}], "2"]}], " ", "-", " ", "5"}], 
     ")"}], "rho0"}]}]}]], "Input",
 CellChangeTimes->{{3.982738143702479*^9, 3.982738233725666*^9}, {
  3.982740350869775*^9, 3.9827403795496073`*^9}},
 CellLabel->"In[51]:=",ExpressionUUID->"860e9460-fddf-4227-bed8-8feecbefb215"],

