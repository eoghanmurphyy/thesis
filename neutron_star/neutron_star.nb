      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], "m"}], "d"], ")"}], 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{"M", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"2", " ", "phi"}], "]"}]}], "r"], " ", "-", " ", 
