Cell[BoxData[{
 RowBox[{
  RowBox[{"DER\[Alpha]Outsiderbardummy", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
    "rbar", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DER\[Alpha]Outsiderbar", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"1", "-", 
        FractionBox["1", 
         RowBox[{"2", " ", "rbar"}]]}], 
       RowBox[{"2", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "+", 
           FractionBox["1", 
            RowBox[{"2", " ", "rbar"}]]}], ")"}], "2"], " ", 
        SuperscriptBox["rbar", "2"]}]], "+", 
      FractionBox["1", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          FractionBox["1", 
           RowBox[{"2", " ", "rbar"}]]}], ")"}], " ", 
        SuperscriptBox["rbar", "2"]}]]}], " ", ")"}], "/.", " ", 
    RowBox[{"rbar", " ", "->", " ", 
     RowBox[{"rbarofrOutside", "[", "r", "]"}]}]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "More", " ", "accurate", " ", "subbing", " ", "in", " ", "after", " ", 
    "for", " ", "rbar", " ", 
    RowBox[{"maybe", "?"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"drbardr", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox[
    RowBox[{"rbarofrOutside", "[", "r", "]"}], "r"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
    RowBox[{"-", 
     FractionBox["1", "2"]}]]}]}]}], "Input",
