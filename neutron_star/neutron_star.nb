Cell[CellGroupData[{

Cell["Average, physical energy loss per orbit", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 
  3.982908628893798*^9}},ExpressionUUID->"bd502297-98ef-4586-bd58-\
e3b61dd5363e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", "3"}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", "5"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"73", "/", "24"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"37", "/", "96"}], ")"}], " ", 
      RowBox[{"e", "^", "4"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}},
 CellLabel->
  "In[192]:=",ExpressionUUID->"b6090826-4043-4826-b3d2-751d8863158b"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t)\
\>", "Text",
 CellChangeTimes->{{3.982908944388515*^9, 
  3.982908980562503*^9}},ExpressionUUID->"525a2003-c3bd-463b-b19f-\
13126fde25ae"]
}, Open  ]]
}, Open  ]],

