Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FRRr", "[", 
    RowBox[{"m_", ",", " ", "rbar_", ",", "ur_", ",", " ", "uphi_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], "}"}], ",", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"8", " ", 
          RowBox[{"m", "^", "2"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"15", " ", 
          RowBox[{"r", "^", "4"}]}], ")"}]}], "*", 
       RowBox[{"drBardt", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"8", " ", 
          RowBox[{"M", "^", "2"}]}], "+", 
         RowBox[{"r", " ", "M", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"6", " ", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "^",
               "2"}]}], "+", 
            RowBox[{"36", " ", 
             RowBox[{"r", "^", "2"}], " ", 
