Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"duphidtInside", "[", 
     RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{
     FractionBox["\[Eta]", "m"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dpdtaccretionphi", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], " ", "+", " ", 
       RowBox[{"dpdtdragphi", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], " ", "+", " ", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"AInside", "[", "rbar", "]"}], "2"], " ", 
        SuperscriptBox["rbar", "2"], " ", 
        RowBox[{"FRRphiIns", "[", 
         RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
         "]"}]}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt2DInside", "[", 
    RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}]}], " ", 
     RowBox[{"UtInside", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{"DER\[Alpha]Inside", "[", "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{"DERAInside", "[", "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AInside", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    
    RowBox[{
     FractionBox[
      SuperscriptBox["uphi", "2"], 
      RowBox[{"UtInside", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox["rbar", "3"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
       FractionBox[
        RowBox[{"DERAInside", "[", "rbar", "]"}], 
        RowBox[{
         SuperscriptBox["rbar", "2"], 
         SuperscriptBox[
          RowBox[{"AInside", "[", "rbar", "]"}], "3"]}]]}], ")"}]}], "+", " ", 
    RowBox[{
     FractionBox["\[Eta]", "m"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dpdtaccretionr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], " ", "+", " ", 
       RowBox[{"dpdtdragr", "[", 
        RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
        "]"}], " ", "+", " ", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"AInside", "[", "rbar", "]"}], "2"], " ", 
        RowBox[{"FRRrIns", "[", 
         RowBox[{"m", ",", " ", "rbar", ",", " ", "ur", ",", " ", "uphi"}], 
         "]"}]}]}], ")"}]}]}]}], ";"}]}], "Input",
