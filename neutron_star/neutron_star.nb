Cell[CellGroupData[{

Cell["Average, physical angular momentum loss per orbit N/A", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 3.982908628893798*^9}, {
  3.9829089136749773`*^9, 3.982908917635139*^9}, {3.982988527479395*^9, 
  3.982988528583199*^9}},ExpressionUUID->"d69e7639-3ccb-44c7-8276-\
54a47aa56311"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
   "Formula", " ", "might", " ", "need", " ", "to", " ", "be", " ", 
    "adjusted", " ", "for", " ", "me", " ", "as", " ", "they", " ", "use", " ",
     "the", " ", "angle", " ", "phi"}], " ", "=", " ", 
   RowBox[{
   "0", " ", "for", " ", "when", " ", "it", " ", "crosses", " ", "the", " ", 
    "star", " ", "surface", " ", "which", " ", "is", " ", "not", " ", "true", 
    " ", "for", " ", "me"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9829091670181303`*^9, 3.982909195169149*^9}},
 CellLabel->
  "In[195]:=",ExpressionUUID->"b0b9c8ec-76d0-4f1b-9805-19935559137d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dLdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", 
        RowBox[{"(", 
         RowBox[{"5", "/", "2"}], ")"}]}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", "2", ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "/", "8"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}, {
  3.982908921003359*^9, 3.98290892892343*^9}, {3.982909074962366*^9, 
  3.98290911543382*^9}},
 CellLabel->
  "In[196]:=",ExpressionUUID->"3a310e56-8f43-453b-a17e-b116bc76f2fe"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t).\
\>", "Text",
 CellChangeTimes->{{3.982908944388515*^9, 3.982908980562503*^9}, 
   3.982912208842395*^9},ExpressionUUID->"60aca2ee-0723-478e-a14b-\
7900ea50da74"],

Cell["Use E and L to find a(t) and e(t)??", "Text",
 CellChangeTimes->{{3.982912212044097*^9, 
  3.9829122232337646`*^9}},ExpressionUUID->"a5095316-25bf-4f7a-b640-\
5e6159e37d36"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Capturing the PBH from infinity", "Section",
 CellChangeTimes->{{3.9804146308308077`*^9, 
  3.980414645960281*^9}},ExpressionUUID->"0347622d-80d4-49cd-826a-\
de8bd6b16a20"],

Cell["\<\
Assuming PBH comes from infinity and just hits in and enters the star\
\>", "Text",
 CellChangeTimes->{{3.9804150369994*^9, 
  3.980415056490988*^9}},ExpressionUUID->"2faa0dd1-fe38-41ed-b6fb-\
cb5a962c6923"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Approaching the problem differently, using ", "Text"],
 StyleBox["Keplerian", "Text",
  IgnoreSpellCheck->True],
 StyleBox[" orbits on the outside of the star and then GR on the inside to \
reduce the stiffness of the problem causing the error in the solver.", 
  "Text"]
}], "Subsubsection",
 CellChangeTimes->{{3.979808250472919*^9, 3.9798082843297377`*^9}, {
  3.980414653959667*^9, 3.980414654081059*^9}, {3.980415675997685*^9, 
  3.9804156766256523`*^9}},ExpressionUUID->"18cfa003-f33d-4430-a172-\
01e5b199cc01"],

Cell[TextData[{
 "Setting v_inf to something physical is essential, most dark matter comes \
from the galactic halo, where things move at roughly 200km/s so with setting \
c = 1, vinf should be ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "3"}]], TraditionalForm]],ExpressionUUID->
  "aa95191e-6213-4c15-a42c-ee977713d46a"],
 " which implies the Energy at infinity should be approximately equal to 1 \
and very little energy loss is needed to bound the orbit."
}], "Text",
 CellChangeTimes->{{3.9804169280841722`*^9, 3.980416975800755*^9}, {
  3.980417052878079*^9, 
  3.980417091913995*^9}},ExpressionUUID->"2c24cd66-7c39-44dd-91b2-\
b7b7083af95c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Defining Initial Data Functions", "Subsection",
 CellChangeTimes->{{3.980417361129909*^9, 
  3.9804173686441803`*^9}},ExpressionUUID->"af7ae14f-f000-4e0a-bfdd-\
27a65fa26187"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vinf", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "3"}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.980417096758354*^9, 3.9804171019450607`*^9}},
 CellLabel->
  "In[267]:=",ExpressionUUID->"69bc867e-9790-4dc3-a4a5-ac38b191c203"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rbar0", " ", "=", " ", "15.67"}], ";"}]], "Input",
 CellChangeTimes->{
  3.983000988891747*^9, {3.983001075491272*^9, 3.983001086122854*^9}},
 CellLabel->
  "In[268]:=",ExpressionUUID->"2b467cf8-4b92-4dcf-a879-10c0515fb9a8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"InitialEnergyAtInfinity", "[", "vinf_", "]"}], " ", ":=", " ", 
    FractionBox["1", 
     SqrtBox[
      RowBox[{"1", " ", "-", " ", 
       SuperscriptBox["vinf", "2"]}]]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"eq47", " ", "2404", " ", "paper"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9804160850197678`*^9, 3.980416098649988*^9}},
 CellLabel->
  "In[269]:=",ExpressionUUID->"63ebe30c-579c-4f32-bb1b-ed05cdafeb87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "general", " ", "formula", " ", "for", " ", "the", " ", "magnitude", " ", 
     "of", " ", "the", " ", "velocity"}], ",", " ", 
    RowBox[{
    "for", " ", "a", " ", "general", " ", "spherically", " ", "symmetric", " ",
      "Isotropic", " ", "metric"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"umagVel", "[", 
     RowBox[{"ur_", ",", " ", "uphi_", ",", " ", "rbar_"}], "]"}], " ", ":=", 
    " ", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["ur", "2"], " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["uphi", "rbar"], ")"}], "2"]}]]}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"umagE", "[", 
      RowBox[{"Energy_", ",", " ", "rbar_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"A", "[", "rbar", "]"}], 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox["Energy", 
           RowBox[{"\[Alpha]", "[", "rbar", "]"}]], ")"}], "2"], " ", "-", 
        " ", "1"}]]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"eq", " ", "48", " ", "in", " ", "paper"}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.980415761538435*^9, 3.9804158755202312`*^9}, {
  3.9804159272169247`*^9, 3.980415932674501*^9}, {3.980415969031563*^9, 
  3.980415973297673*^9}, {3.980416194586721*^9, 3.9804162406179028`*^9}, {
  3.980418347236079*^9, 3.980418358959013*^9}, {3.9804201609992113`*^9, 
  3.980420171909109*^9}},
 CellLabel->
  "In[270]:=",ExpressionUUID->"f266005b-0387-46aa-a43d-143018304cf6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Defining", " ", "the", " ", "Impact", " ", "angle"}], ",", " ", 
    RowBox[{
    "which", " ", "is", " ", "the", " ", "angle", " ", "between", " ", "the", 
     " ", "radial", " ", "vector", " ", "and", " ", "the", " ", 
     RowBox[{"PBH", "'"}], "s", " ", "velocity", " ", "vector"}]}], "*)"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{
   "It", " ", "is", " ", "the", " ", "angle", " ", "the", " ", "PBH", " ", 
    "enters", " ", "the", " ", "star"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"urInit", "[", 
      RowBox[{"psi_", ",", " ", "Einit_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"umagE", "[", 
        RowBox[{"Einit", " ", ",", " ", "rbar0"}], "]"}]}], 
      RowBox[{"Cos", "[", "psi", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"uphiInit", "[", 
      RowBox[{"psi_", ",", " ", "rbarStar_", ",", " ", "Einit_"}], "]"}], " ",
      ":=", " ", 
     RowBox[{"rbarStar", " ", 
      RowBox[{"umagE", "[", "Einit", " ", "]"}], 
      RowBox[{"Sin", "[", "psi", "]"}]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Is", " ", "defining", " ", "angular", " ", "momentum"}], ",", 
     " ", 
     RowBox[{"L", " ", "is", " ", "equal", " ", "to", " ", "this"}]}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.98041633503653*^9, 3.980416355465521*^9}, {
  3.98041639081736*^9, 3.980416540208694*^9}, {3.980416606116276*^9, 
  3.9804166267383633`*^9}, {3.980416666749844*^9, 3.980416673625964*^9}, {
  3.980417116639278*^9, 3.9804171875471582`*^9}, {3.980417225602989*^9, 
  3.980417287800577*^9}, {3.9804176328755302`*^9, 3.98041763616606*^9}, {
  3.980418073144514*^9, 3.980418193394154*^9}, {3.980418470589699*^9, 
  3.980418473698866*^9}, {3.980418515413982*^9, 3.980418541360607*^9}, {
  3.980418658653262*^9, 3.980418733921682*^9}, {3.980420231879798*^9, 
  3.9804202353180428`*^9}, {3.983000995627982*^9, 3.983000996707877*^9}},
 CellLabel->
  "In[272]:=",ExpressionUUID->"9a40e735-fe0f-46c7-8a4d-1940b7a05735"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Setting the Initial conditions", "Subsection",
 CellChangeTimes->{{3.980417374617618*^9, 
  3.980417378785927*^9}},ExpressionUUID->"e55cbdfd-0221-4e2a-ba09-\
a5900980c5cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"we", " ", "start", " ", "at", " ", "rbarStar"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"phi0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Einf", " ", "=", " ", 
    RowBox[{"InitialEnergyAtInfinity", "[", "vinf", "]"}]}], "\[IndentingNewLine]",
    " ", 
   RowBox[{
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"umagE", "[", 
      RowBox[{"Einf", ",", " ", "rbar0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ImpactAngle", " ", "=", " ", 
     FractionBox["Pi", "2"]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"In", " ", "radians"}], ",", " ", 
     RowBox[{
     "measured", " ", "from", " ", "center", " ", "of", " ", "star", " ", 
      "to", " ", "the", " ", "position", " ", "of", " ", "particle"}], ",", 
     " ", 
     RowBox[{"in", " ", "unit", " ", "circle", " ", "fashion"}], ",", " ", 
     RowBox[{
      RowBox[{"pi", "/", "2"}], " ", "corresponds", " ", "to", " ", "grazing",
