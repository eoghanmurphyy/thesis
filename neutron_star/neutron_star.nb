Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtInside", "[", 
   RowBox[{"m_", ",", "rbar_", ",", "ur_", ",", "uphi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], ",", "rd", ",", 
      "phid"}], "}"}], ",", 
    RowBox[{
     RowBox[{"rd", "=", 
      RowBox[{"drBardtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", "=", 
      RowBox[{"dphidtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"8", " ", 
         RowBox[{"m", "^", "2"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"15", " ", 
         RowBox[{"r", "^", "4"}]}], ")"}]}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"MassFunction", "[", "r", "]"}], "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"8", " ", 
            RowBox[{"rd", "^", "2"}]}], "+", 
           RowBox[{"6", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}]}], ")"}]}], "+", 
        RowBox[{"r", " ", 
         RowBox[{"MassFunction", "[", "r", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{"rd", "^", "4"}]}], "-", 
           RowBox[{"6", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"3", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}]}], "+", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}], " ", 
               RowBox[{"Mp", "[", "r", "]"}]}]}], ")"}]}], "+", 
           RowBox[{
            RowBox[{"rd", "^", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"63", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}], "+", 
              RowBox[{"Mp", "[", "r", "]"}], "-", 
              RowBox[{"3", " ", "r", " ", 
               RowBox[{"Mpp", "[", "r", "]"}]}]}], ")"}]}]}], ")"}]}], "+", 
        RowBox[{
         RowBox[{"r", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}], " ", 
            RowBox[{"Mp", "[", "r", "]"}]}], "-", 
           RowBox[{
            RowBox[{"rd", "^", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"Mp", "[", "r", "]"}], ")"}], "^", "2"}], "+", 
              RowBox[{"3", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"13", " ", 
                  RowBox[{"Mp", "[", "r", "]"}]}], "-", 
                 RowBox[{"3", " ", "r", " ", 
                  RowBox[{"Mpp", "[", "r", "]"}]}]}], ")"}]}]}], ")"}]}], "-", 
           RowBox[{
            RowBox[{"rd", "^", "4"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", 
               RowBox[{"Mp", "[", "r", "]"}]}], "+", 
              RowBox[{"r", " ", 
               RowBox[{"Mpp", "[", "r", "]"}]}], "-", 
              RowBox[{
               RowBox[{"r", "^", "2"}], " ", 
               RowBox[{"Mppp", "[", "r", "]"}]}]}], ")"}]}]}], ")"}]}]}], 
       ")"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9829080741491127`*^9, 3.982908074149129*^9}, {
   3.98290816171437*^9, 3.98290816416226*^9}, 3.9829081961136208`*^9, 
