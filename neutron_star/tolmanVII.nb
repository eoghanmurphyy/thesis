Cell[CellGroupData[{

Cell["Making the derivative of alpha continuous", "Subsection",
 CellChangeTimes->{{3.982818100593948*^9, 
  3.982818108849741*^9}},ExpressionUUID->"9e1b0d23-834d-4fe5-ba9d-\
fc74609ec02b"],

Cell[CellGroupData[{

Cell["Interior derivative in terms of r", "Subsubsection",
 CellChangeTimes->{{3.982818175953421*^9, 
  3.982818182321394*^9}},ExpressionUUID->"14f48462-582a-490e-930f-\
9a9b67470781"],

Cell["Doing things in r first as this is more analytic", "Text",
 CellChangeTimes->{{3.982818131907432*^9, 
  3.982818140641671*^9}},ExpressionUUID->"4b5defeb-a99d-43ad-a7c5-\
49edd56a6197"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dPhidrMetric", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"(", 
   FractionBox[
    RowBox[{
     RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
     RowBox[{"4", " ", "Pi", " ", 
      RowBox[{"Pressure", "[", "r", "]"}], " ", 
      SuperscriptBox["r", "3"]}]}], 
    RowBox[{"r", 
     RowBox[{"(", 
      RowBox[{"r", "-", 
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}]], "Input",
 CellChangeTimes->{{3.982393502718885*^9, 3.9823935097345247`*^9}, {
  3.982399278079626*^9, 3.982399279215176*^9}},
 CellLabel->"In[44]:=",ExpressionUUID->"2a99599b-4506-41b9-beab-77b830de53a7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"alpha", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"Exp", "[", 
   RowBox[{"PhiMetric", "[", "r", "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DERalphaIns", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"dPhidrMetric", "[", "r", "]"}], " ", 
   RowBox[{"alpha", "[", "r", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Analytic", " ", "times", " ", "numerical", " ", "integral"}], 
    "*)"}]}]}]}], "Input",
