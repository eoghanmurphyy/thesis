Cell[CellGroupData[{

Cell["Instantaneous energy loss (coordinate system dependent)", "Subsection",
 CellChangeTimes->{{3.98290861036561*^9, 
  3.982908637213344*^9}},ExpressionUUID->"6cc41c2f-fa9b-44c6-aeae-\
5e71daad613e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtInside", "[", 
   RowBox[{"m_", ",", "rbar_", ",", "ur_", ",", "uphi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], ",", "rd", ",", 
      "phid"}], "}"}], ",", 
    RowBox[{
     RowBox[{"rd", "=", 
      RowBox[{"drBardtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", "=", 
      RowBox[{"dphidtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"8", " ", 
         RowBox[{"m", "^", "2"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"15", " ", 
         RowBox[{"r", "^", "4"}]}], ")"}]}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"MassFunction", "[", "r", "]"}], "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"8", " ", 
            RowBox[{"rd", "^", "2"}]}], "+", 
           RowBox[{"6", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}]}], ")"}]}], "+", 
        RowBox[{"r", " ", 
         RowBox[{"MassFunction", "[", "r", "]"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{"rd", "^", "4"}]}], "-", 
           RowBox[{"6", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"3", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}]}], "+", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}], " ", 
               RowBox[{"Mp", "[", "r", "]"}]}]}], ")"}]}], "+", 
           RowBox[{
            RowBox[{"rd", "^", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"63", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}], "+", 
              RowBox[{"Mp", "[", "r", "]"}], "-", 
              RowBox[{"3", " ", "r", " ", 
               RowBox[{"Mpp", "[", "r", "]"}]}]}], ")"}]}]}], ")"}]}], "+", 
        RowBox[{
         RowBox[{"r", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}], " ", 
            RowBox[{"Mp", "[", "r", "]"}]}], "-", 
           RowBox[{
            RowBox[{"rd", "^", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"Mp", "[", "r", "]"}], ")"}], "^", "2"}], "+", 
              RowBox[{"3", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"13", " ", 
                  RowBox[{"Mp", "[", "r", "]"}]}], "-", 
                 RowBox[{"3", " ", "r", " ", 
                  RowBox[{"Mpp", "[", "r", "]"}]}]}], ")"}]}]}], ")"}]}], "-", 
           RowBox[{
            RowBox[{"rd", "^", "4"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", 
               RowBox[{"Mp", "[", "r", "]"}]}], "+", 
