Cell[CellGroupData[{

Cell["Average, physical energy loss per orbit", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 
  3.982908628893798*^9}},ExpressionUUID->"60dc6769-c475-4a95-be7f-\
2db35faa3fc1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", "3"}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", "5"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"73", "/", "24"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"37", "/", "96"}], ")"}], " ", 
      RowBox[{"e", "^", "4"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}},
 CellLabel->
  "In[196]:=",ExpressionUUID->"0a51fc46-734c-4f27-b7d2-f4c833f7bde2"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t)\
\>", "Text",
