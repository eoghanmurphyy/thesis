 CellChangeTimes->{{3.9829080587145233`*^9, 3.982908071585734*^9}, {
  3.982908598693872*^9, 3.9829086053179703`*^9}, {3.982908873003482*^9, 
  3.982908877363311*^9}},ExpressionUUID->"41282a85-a561-4c77-8941-\
f84f70db3efc"],

Cell[CellGroupData[{

Cell["\<\
Instantaneous angular momentum loss (coordinate system dependent)\
\>", "Subsection",
 CellChangeTimes->{{3.98290861036561*^9, 3.982908637213344*^9}, {
  3.982908904907382*^9, 
  3.982908909299267*^9}},ExpressionUUID->"5d85e8f3-2bcb-4b87-a0f0-\
cbca5dfb5f45"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dLdt", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_", ",", " ", "phi_"}], "]"}], ":=",
   " ", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     RowBox[{"4", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["m", "2"], " ", 
        SuperscriptBox["M", 
         FractionBox["5", "2"]]}], ")"}]}], 
     RowBox[{"5", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["a", 
         FractionBox["7", "2"]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["e", "2"]}], ")"}], 
         FractionBox["7", "2"]]}], ")"}]}]]}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"e", " ", 
       RowBox[{"Cos", "[", "phi", "]"}]}]}], ")"}], "3"], " ", 
   RowBox[{"(", 
    RowBox[{"8", " ", "-", " ", 
     RowBox[{"3", 
      SuperscriptBox["e", "2"]}], " ", "+", " ", 
     RowBox[{"20", "e", " ", 
      RowBox[{"Cos", "[", "phi", "]"}]}], " ", "+", " ", 
     RowBox[{"15", 
      SuperscriptBox["e", "2"], 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "phi"}], "]"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9829080741491127`*^9, 3.982908074149129*^9}, {
   3.98290816171437*^9, 3.98290816416226*^9}, 3.9829081961136208`*^9, 
   3.982908233153319*^9, 3.9829082663530807`*^9, {3.982908932123487*^9, 
   3.982908933363347*^9}, {3.982909375080247*^9, 3.982909512279233*^9}},
 CellLabel->
  "In[197]:=",ExpressionUUID->"733269d3-73b9-4f43-8e0d-4358765ddf34"],

