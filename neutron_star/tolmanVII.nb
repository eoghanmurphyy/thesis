Cell[BoxData[
 RowBox[{
  RowBox[{"sol2", " ", "=", " ", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eq", ",", "\[IndentingNewLine]", "BC"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "rbarofr", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "RStar", ",", " ", "rmin"}], "}"}]}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"WorkingPrecision", "->", "40"}], ",", "\[IndentingNewLine]", 
       RowBox[{"AccuracyGoal", "->", "20"}], ",", " ", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "I", " ", "want", " ", "the", " ", "answer", " ", "correct", " ", 
          "up", " ", "to", " ", 
          RowBox[{"10", "^", 
           RowBox[{"-", "8"}]}]}], " ", "->", " ", 
         RowBox[{"8", " ", "correct", " ", "decimals"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"PrecisionGoal", "->", "20"}]}], "*)"}], " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "I", " ", "want", " ", "8", " ", "correct", " ", "digits", " ", 
        "relative", " ", "to", " ", "the", " ", "size", " ", "of", " ", "the",
         " ", 
        RowBox[{"number", ".", " ", "E", ".", "g"}], " ", "if", " ", "answer",
         " ", "is", " ", "1.234567899"}], ",", " ", 
       RowBox[{
        RowBox[{
        "then", " ", "precision", " ", "goal", " ", "gives", " ", "me", " ", 
         "say", " ", "1.23456789"}], " ", "-", " ", 
        RowBox[{
        "the", " ", "amount", " ", "of", " ", "digits", " ", "is", " ", "8", " ",
          "and", " ", "accuracy", " ", "goal", " ", "makes", " ", "these", " ",
          "8", " ", "digits", " ", 
         RowBox[{"exact", "."}]}]}]}], "*)"}], "\[IndentingNewLine]", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}]], "Input",
