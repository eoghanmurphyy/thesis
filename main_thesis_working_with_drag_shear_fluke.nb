Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"IVariableInterpolated", "[", "\[CapitalMu]ach_", "]"}], " ", ":=",
    " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"1", "+", " ", "\[CapitalMu]ach"}], 
            RowBox[{"1", " ", "-", " ", "\[CapitalMu]ach"}]], "]"}]}], " ", "-",
          " ", "\[CapitalMu]ach"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", "<", " ", "0.9999"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"anaylticline", "[", "\[CapitalMu]ach", "]"}], ",", " ", 
        RowBox[{
        "0.9999", " ", "<", " ", "\[CapitalMu]ach", "  ", "<", " ", 
         "1.0001"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["1", 
             SuperscriptBox["\[CapitalMu]ach", "2"]]}], "]"}]}], "  ", "+", 
         " ", "10"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", ">", " ", "1.0001"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9806813197521677`*^9, 3.980681355455866*^9}, {
