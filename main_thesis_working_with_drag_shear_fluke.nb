Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dpdtdragphi", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"umagphi", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "3"]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "4"}], "\[Pi]", " ", 
       RowBox[{"\[Alpha]Full", "[", "rbar", "]"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rho", "[", "rbar", "]"}], " ", "+", " ", 
         RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], ")"}], "*", 
       
       SuperscriptBox["m", "2"], "*", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"2", " ", 
           SuperscriptBox[
            RowBox[{"umagphi", "[", 
             RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
            "2"]}]}], ")"}], "2"], " ", "*", 
       RowBox[{"IVariableInterpolated", "[", 
        RowBox[{"Mach", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "]"}], 
       " ", "*", "uphi"}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dpdtdragr", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
   " ", 
