           FractionBox[
            RowBox[{"umagphi", "[", 
             RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
            RowBox[{
             RowBox[{"\[Alpha]Full", "[", "rbar", "]"}], " ", 
             RowBox[{"UtInside", "[", 
              RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
           ")"}], "2"]}]], ")"}], 
      FractionBox["q", "2"]], "ur"}]}], ";", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Removing", " ", "the", " ", "a", " ", "here", " ", "as", " ", "it", " ",
       "cancels", " ", "in", " ", "this", " ", "regime", " ", "with", " ", 
      "q"}], "=", 
     RowBox[{
      RowBox[{"2", " ", "and", " ", "\[CapitalGamma]"}], " ", "=", " ", 
      "2"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dpdtaccretionphi", "[", 
     RowBox[{"m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], 
     "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"(", 
        RowBox[{"4", " ", "Pi", " ", 
         RowBox[{"\[Alpha]Full", "[", "rbar", "]"}], " ", 
         RowBox[{"(", "1.49", ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"rho", "[", "rbar", "]"}], " ", "+", " ", 
           RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], ")"}], 
         SuperscriptBox["m", "2"]}], ")"}], ")"}]}], 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox["1", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"umagphi", "[", 
             RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
            RowBox[{
             RowBox[{"\[Alpha]Full", "[", "rbar", "]"}], " ", 
             RowBox[{"UtInside", "[", 
              RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
           ")"}], "2"]}]], ")"}], 
      FractionBox["q", "2"]], "uphi"}]}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9822996431768637`*^9, 3.9822996664005527`*^9}, {
  3.9822997188803368`*^9, 3.9822997589597807`*^9}, {3.982304471746207*^9, 
