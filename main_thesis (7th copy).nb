       RowBox[{"(", 
        FractionBox["uphi", 
         RowBox[{"rbar", " ", 
          RowBox[{"AFull", "[", "rbar", "]"}]}]], ")"}], "2"]}]], 
    RowBox[{"\[Alpha]Full", "[", "rbar", "]"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"umagphi", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
   FractionBox[
    SqrtBox[
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["ur", "2"], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["uphi", "rbar"], ")"}], "2"]}], ")"}]], 
    RowBox[{"AFull", "[", "rbar", "]"}]]}], 
  RowBox[{"(*", 
   RowBox[{"paper", " ", "eqn", " ", "ut", " ", "and", " ", "umagphi"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
