Cell[CellGroupData[{

Cell["Rates of change of velocities", "Subsubsection",
 CellChangeTimes->{{3.98229881060014*^9, 
  3.9822988183975*^9}},ExpressionUUID->"ece96e93-c603-4e4f-9b97-b21aedddf033"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"drBardt", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"AFull", "[", "rbar", "]"}], "2"], 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "ur"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dphidt", "[", 
    RowBox[{"rbar_", ",", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["rbar", "2"], "*", 
      SuperscriptBox[
       RowBox[{"AFull", "[", "rbar", "]"}], "2"], "*", 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", "uphi"}], "]"}]}]], "uphi"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"duphidt", "[", 
   RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
  " ", "0"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], "  ", ":=", 
   " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]Full", "[", "rbar", "]"}]}], " ", 
     RowBox[{"Ut", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{"DER\[Alpha]Full", "[", "rbar", "]"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{"DERAFull", "[", "rbar", "]"}], 
       SuperscriptBox[
        RowBox[{"AFull", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["uphi", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox["rbar", "3"], 
         SuperscriptBox[
          RowBox[{"AFull", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
       FractionBox[
        RowBox[{"DERAFull", "[", "rbar", "]"}], 
        RowBox[{
         SuperscriptBox["rbar", "2"], 
         SuperscriptBox[
          RowBox[{"AFull", "[", "rbar", "]"}], "3"]}]]}], ")"}]}]}]}], " ", 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9784248275415373`*^9, 3.978425028800013*^9}, {
