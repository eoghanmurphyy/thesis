Cell["Defining Mach number business\[AliasDelimiter]", "Text",
 CellChangeTimes->{{3.980682765845396*^9, 
  3.9806827711907578`*^9}},ExpressionUUID->"2059a9eb-59a9-4d9a-9bd6-\
27274c5950e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalMu]", "[", 
   RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
  " ", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{"umagphi", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
        RowBox[{"a", " ", 
         RowBox[{"\[Alpha]", "[", "rbar", "]"}], " ", 
         RowBox[{"Ut", "[", 
          RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], ",", 
       " ", 
       RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{"umagphi", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
        RowBox[{"a", " ", 
         RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], " ", 
         RowBox[{"UtInside", "[", 
          RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], ",", 
       " ", 
       RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.980682776589178*^9, 3.980682777085677*^9}},
 CellLabel->
  "In[143]:=",ExpressionUUID->"afb982bd-02a7-4b86-8653-8293ac486e2b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Defining Energy and Angular momentum per unit mass functions along with other \
orbital parameters\
\>", "Subsubsection",
 CellChangeTimes->{{3.98041330662858*^9, 3.9804133112081738`*^9}, {
  3.9806797688460484`*^9, 
  3.980679791293557*^9}},ExpressionUUID->"51e0d69c-b380-4d1f-9de9-\
7e98db5a5139"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"EnergyPerUnitMass", "[", 
    RowBox[{"ptilde_", ",", " ", "eccen_"}], "]"}], " ", ":=", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"ptilde", " ", "-", "2"}], ")"}], "2"], " ", "-", " ", 
      RowBox[{"4", " ", "*", 
       SuperscriptBox["eccen", "2"]}]}], 
     RowBox[{"ptilde", "*", 
      RowBox[{"(", 
       RowBox[{"ptilde", " ", "-", " ", "3", " ", "-", " ", 
        SuperscriptBox["eccen", "2"]}], ")"}]}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"LPerUnitMass", "[", 
    RowBox[{"ptilde_", ",", " ", "M_", ",", " ", "eccen_"}], "]"}], " ", ":=",
    " ", 
   FractionBox[
    RowBox[{"ptilde", "*", "M"}], 
    SqrtBox[
     RowBox[{"ptilde", " ", "-", " ", "3", " ", "-", " ", 
      SuperscriptBox["eccen", "2"]}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ptildefunc", "[", 
    RowBox[{"p_", ",", " ", "Mass_"}], "]"}], " ", ":=", " ", 
   FractionBox["p", "Mass"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rapoapsis", "[", 
     RowBox[{"eccen_", ",", " ", "ptilde_", ",", " ", "Mass_"}], "]"}], " ", ":=",
     " ", 
    FractionBox[
     RowBox[{
      RowBox[{"(", "ptilde", ")"}], "*", "Mass"}], 
     RowBox[{"1", " ", "-", " ", "eccen"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "In", " ", "Schwarzschild", " ", "areal", " ", "r", " ", "coordinates"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rperiapsis", "[", 
    RowBox[{"eccen_", ",", " ", "ptilde_"}], "]"}], " ", ":=", " ", 
   FractionBox["ptilde", 
    RowBox[{"1", "+", "eccen"}]]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9804133126715603`*^9, 3.980413420824196*^9}, {
   3.980413505300097*^9, 3.980413624003992*^9}, {3.980413790075656*^9, 
   3.980413805693198*^9}, {3.980428531832149*^9, 3.9804285692626743`*^9}, {
   3.98042869146882*^9, 3.98042870275418*^9}, {3.980428747034544*^9, 
   3.980428747238887*^9}, 3.980428910735964*^9, {3.980429218239962*^9, 
   3.980429218591713*^9}, {3.980429767165423*^9, 3.980429768476245*^9}, {
   3.98047979809356*^9, 3.980479799779428*^9}, {3.98048005818428*^9, 
   3.980480092300942*^9}},
 CellLabel->
  "In[144]:=",ExpressionUUID->"6839dc14-c133-43bd-824a-13f8ad4b5467"]
}, Open  ]]
}, Open  ]],

