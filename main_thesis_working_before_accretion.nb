1eb6a8b00b3a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Mfunc", "[", "r_", "]"}], " ", "=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"M", " ", 
         FractionBox[
          SuperscriptBox["r", "3"], 
          SuperscriptBox["RStar", "3"]]}], ",", " ", 
        RowBox[{"r", " ", "<=", " ", "RStar"}]}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"M", ",", " ", 
        RowBox[{"r", ">", "RStar"}]}], "}"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"grrTOV", "[", "r_", "]"}], " ", "=", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox[
        RowBox[{"2", 
         RowBox[{"Mfunc", "[", "r", "]"}]}], "r"]}], ")"}], 
     RowBox[{"-", "1"}]]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Kappa]", " ", "=", " ", 
    SqrtBox[
     RowBox[{"2", 
      FractionBox["M", 
       SuperscriptBox["RStar", "3"]]}]]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Integral", " ", "constant", " ", "I", " ", "used", " ", "by", " ", 
    "hand"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Const", " ", "=", " ", 
    RowBox[{
     RowBox[{"rBarSchw", "[", "RStar", "]"}], 
     SqrtBox[
      FractionBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", 
          FractionBox[
           RowBox[{"2", "M"}], "RStar"]}]]}], 
       RowBox[{"1", "-", 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}]]}]]]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Can", " ", "use", " ", "schw", " ", "to", " ", "convert", " ", "RStar", " ",
     "as", " ", "the", " ", "value", " ", "should", " ", "be", " ", "the", " ",
     "same", " ", "inside", " ", "and", " ", "outside"}], "*)"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "is", " ", "the", " ", "constant", " ", "to", " ", "match", " ",
     "up", " ", "the", " ", "metrics"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9783301118015347`*^9, 3.978330182920364*^9}, {
  3.9783302193359118`*^9, 3.978330320711*^9}, {3.978330396647119*^9, 
  3.9783304724143457`*^9}, {3.978330637788574*^9, 3.978330649268416*^9}, {
