Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fMachLow", "[", "m_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"Log", "[", 
      FractionBox[
       RowBox[{"1", "+", " ", "m"}], 
       RowBox[{"1", " ", "-", " ", "m"}]], "]"}]}], " ", "-", " ", "m"}]}], 
  " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
