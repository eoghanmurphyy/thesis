Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"EnergyPerUnitMass", "[", 
    RowBox[{"ptilde_", ",", " ", "eccen_"}], "]"}], " ", ":=", " ", 
   SqrtBox[
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"ptilde", " ", "-", "2"}], ")"}], "2"], " ", "-", " ", 
      RowBox[{"4", " ", "*", 
       SuperscriptBox["eccen", "2"]}]}], 
     RowBox[{"ptilde", "*", 
      RowBox[{"(", 
       RowBox[{"ptilde", " ", "-", " ", "3", " ", "-", " ", 
        SuperscriptBox["eccen", "2"]}], ")"}]}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"LPerUnitMass", "[", 
    RowBox[{"ptilde_", ",", " ", "M_", ",", " ", "eccen_"}], "]"}], " ", ":=",
    " ", 
   FractionBox[
    RowBox[{"ptilde", "*", "M"}], 
    SqrtBox[
     RowBox[{"ptilde", " ", "-", " ", "3", " ", "-", " ", 
      SuperscriptBox["eccen", "2"]}]]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ptildefunc", "[", 
    RowBox[{"p_", ",", " ", "Mass_"}], "]"}], " ", ":=", " ", 
   FractionBox["p", "Mass"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rapoapsis", "[", 
     RowBox[{"eccen_", ",", " ", "ptilde_", ",", " ", "Mass_"}], "]"}], " ", ":=",
     " ", 
    FractionBox[
     RowBox[{
      RowBox[{"(", "ptilde", ")"}], "*", "Mass"}], 
     RowBox[{"1", " ", "-", " ", "eccen"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "In", " ", "Schwarzschild", " ", "areal", " ", "r", " ", "coordinates"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rperiapsis", "[", 
    RowBox[{"eccen_", ",", " ", "ptilde_"}], "]"}], " ", ":=", " ", 
   FractionBox["ptilde", 
    RowBox[{"1", "+", "eccen"}]]}], ";"}]}], "Input",
