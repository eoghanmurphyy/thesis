Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Areal", " ", "radius", " ", "as", " ", "a", " ", "function", " ", "of", " ",
     "isotropic", " ", "radius"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"rFromRbar", "[", "rbar_", "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"A", "[", "rbar", "]"}], "*", "rbar"}], ",", 
          RowBox[{"rbar", ">=", "rbarStar"}]}], "}"}], ",", 
        RowBox[{"(*", "exterior", "*)"}], 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"AInside", "[", "rbar", "]"}], "*", "rbar"}], ",", 
          RowBox[{"rbar", "<", "rbarStar"}]}], "}"}]}], "    ", 
       RowBox[{"(*", "interior", "*)"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Areal", " ", "radius", " ", "along", " ", "the", " ", "orbit"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"arealr", "[", "t_", "]"}], ":=", 
     RowBox[{"rFromRbar", "[", 
      RowBox[{"rbarNumIn", "[", "t", "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.979742229262013*^9, 3.979742295009645*^9}, {
