Cell["\<\
eccentric orbit and dig thru literature for u cubed and input speed factor.\
\>", "Text",
 CellChangeTimes->{{3.9798141196122513`*^9, 
  3.979814164545793*^9}},ExpressionUUID->"d39695d9-a755-4fd3-9904-\
b052fb8bb837"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"LogPlot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"umagphi", "[", 
       RowBox[{
        RowBox[{"rbarNumIn", "[", "t", "]"}], ",", 
        RowBox[{"urNumIn", "[", "t", "]"}], ",", 
        RowBox[{"uphiNumIn", "[", "t", "]"}]}], "]"}], "/.", " ", "solIn"}], 
     "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "tFinish"}], "}"}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<t\>\"", ",", "\"\<u magnitude\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "->", "\"\<u magnitude vs time\>\""}]}], "]"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Show", " ", "me", " ", "the", " ", "value", " ", "of", " ", "u", " ", 
    "at", " ", "tfinish"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"umagphi", "[", 
    RowBox[{
     RowBox[{"rbarNumIn", "[", "tFinish", "]"}], ",", 
     RowBox[{"urNumIn", "[", "tFinish", "]"}], ",", 
     RowBox[{"uphiNumIn", "[", "tFinish", "]"}]}], "]"}], "/.", " ", 
   "solIn"}], ";"}], "\n"}], "Input",
