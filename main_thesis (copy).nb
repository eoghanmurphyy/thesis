Cell[CellGroupData[{

Cell["Capturing the PBH from infinity", "Section",
 CellChangeTimes->{{3.9804146308308077`*^9, 
  3.980414645960281*^9}},ExpressionUUID->"97671731-2eec-4b8f-b41d-\
55dba966f53a"],

Cell["\<\
Assuming PBH comes from infinity and just hits in and enters the star\
\>", "Text",
 CellChangeTimes->{{3.9804150369994*^9, 
  3.980415056490988*^9}},ExpressionUUID->"f1abbc9b-aebf-4462-bd14-\
c681eb195398"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Approaching the problem differently, using ", "Text"],
 StyleBox["Keplerian", "Text",
  IgnoreSpellCheck->True],
 StyleBox[" orbits on the outside of the star and then GR on the inside to \
reduce the stiffness of the problem causing the error in the solver.", 
  "Text"]
}], "Subsubsection",
 CellChangeTimes->{{3.979808250472919*^9, 3.9798082843297377`*^9}, {
  3.980414653959667*^9, 3.980414654081059*^9}, {3.980415675997685*^9, 
  3.9804156766256523`*^9}},ExpressionUUID->"b6603694-3cc2-4db1-aa87-\
571acf8d2183"],

Cell[TextData[{
 "Setting v_inf to something physical is essential, most dark matter comes \
from the galactic halo, where things move at roughly 200km/s so with setting \
c = 1, vinf should be ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "3"}]], TraditionalForm]],ExpressionUUID->
  "ffa5a446-0a3e-400b-8b04-8e0dafe4b1ed"],
 " which implies the Energy at infinity should be approximately equal to 1 \
and very little energy loss is needed to bound the orbit."
}], "Text",
 CellChangeTimes->{{3.9804169280841722`*^9, 3.980416975800755*^9}, {
  3.980417052878079*^9, 
  3.980417091913995*^9}},ExpressionUUID->"e5549518-9822-4339-8825-\
de98752a6517"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Defining Initial Data Functions", "Subsubsection",
 CellChangeTimes->{{3.980417361129909*^9, 
  3.9804173686441803`*^9}},ExpressionUUID->"3742578b-7ab3-4064-bd9b-\
658aee016464"],

Cell[BoxData[
 RowBox[{
  RowBox[{"vinf", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "3"}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.980417096758354*^9, 3.9804171019450607`*^9}},
 CellLabel->
  "In[441]:=",ExpressionUUID->"a38faf4c-d76b-4470-95be-deb12d46599a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"InitialEnergyAtInfinity", "[", "vinf_", "]"}], " ", ":=", " ", 
    FractionBox["1", 
     SqrtBox[
      RowBox[{"1", " ", "-", " ", 
       SuperscriptBox["vinf", "2"]}]]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"eq47", " ", "2404", " ", "paper"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9804160850197678`*^9, 3.980416098649988*^9}},
 CellLabel->
  "In[442]:=",ExpressionUUID->"e612bdc4-861a-4b86-8b55-324028654924"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "general", " ", "formula", " ", "for", " ", "the", " ", "magnitude", " ", 
     "of", " ", "the", " ", "velocity"}], ",", " ", 
    RowBox[{
    "for", " ", "a", " ", "general", " ", "spherically", " ", "symmetric", " ",
      "Isotropic", " ", "metric"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"umagVel", "[", 
     RowBox[{"ur_", ",", " ", "uphi_", ",", " ", "rbar_"}], "]"}], " ", ":=", 
    " ", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["ur", "2"], " ", "+", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["uphi", "rbar"], ")"}], "2"]}]]}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"umagE", "[", 
      RowBox[{"Energy_", ",", " ", "rbar_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"A", "[", "rbar", "]"}], 
      SqrtBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox["Energy", 
           RowBox[{"\[Alpha]", "[", "rbar", "]"}]], ")"}], "2"], " ", "-", 
        " ", "1"}]]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"eq", " ", "48", " ", "in", " ", "paper"}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.980415761538435*^9, 3.9804158755202312`*^9}, {
  3.9804159272169247`*^9, 3.980415932674501*^9}, {3.980415969031563*^9, 
  3.980415973297673*^9}, {3.980416194586721*^9, 3.9804162406179028`*^9}, {
  3.980418347236079*^9, 3.980418358959013*^9}, {3.9804201609992113`*^9, 
  3.980420171909109*^9}},
 CellLabel->
  "In[443]:=",ExpressionUUID->"2b9557c4-49b2-4338-b6d6-3d6feea0dfdb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Defining", " ", "the", " ", "Impact", " ", "angle"}], ",", " ", 
    RowBox[{
    "which", " ", "is", " ", "the", " ", "angle", " ", "between", " ", "the", 
     " ", "radial", " ", "vector", " ", "and", " ", "the", " ", 
     RowBox[{"PBH", "'"}], "s", " ", "velocity", " ", "vector"}]}], "*)"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{
   "It", " ", "is", " ", "the", " ", "angle", " ", "the", " ", "PBH", " ", 
    "enters", " ", "the", " ", "star"}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"urInit", "[", 
      RowBox[{"psi_", ",", " ", "Einit_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"umagE", "[", 
        RowBox[{"Einit", " ", ",", " ", "rbarStar"}], "]"}]}], 
      RowBox[{"Cos", "[", "psi", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"uphiInit", "[", 
      RowBox[{"psi_", ",", " ", "rbarStar_", ",", " ", "Einit_"}], "]"}], " ",
      ":=", " ", 
     RowBox[{"rbarStar", " ", 
      RowBox[{"umagE", "[", "Einit", " ", "]"}], 
      RowBox[{"Sin", "[", "psi", "]"}]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Is", " ", "defining", " ", "angular", " ", "momentum"}], ",", 
     " ", 
     RowBox[{"L", " ", "is", " ", "equal", " ", "to", " ", "this"}]}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.98041633503653*^9, 3.980416355465521*^9}, {
  3.98041639081736*^9, 3.980416540208694*^9}, {3.980416606116276*^9, 
  3.9804166267383633`*^9}, {3.980416666749844*^9, 3.980416673625964*^9}, {
  3.980417116639278*^9, 3.9804171875471582`*^9}, {3.980417225602989*^9, 
  3.980417287800577*^9}, {3.9804176328755302`*^9, 3.98041763616606*^9}, {
  3.980418073144514*^9, 3.980418193394154*^9}, {3.980418470589699*^9, 
  3.980418473698866*^9}, {3.980418515413982*^9, 3.980418541360607*^9}, {
  3.980418658653262*^9, 3.980418733921682*^9}, {3.980420231879798*^9, 
  3.9804202353180428`*^9}},
 CellLabel->
  "In[445]:=",ExpressionUUID->"f1cc6208-1587-4fc9-8015-8c76c9024271"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Setting the Initial conditions", "Subsubsection",
 CellChangeTimes->{{3.980417374617618*^9, 
  3.980417378785927*^9}},ExpressionUUID->"6e8326df-a96d-42a0-b32b-\
7609f73866d1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"we", " ", "start", " ", "at", " ", "rbarStar"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"phi0", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Einf", " ", "=", " ", 
     RowBox[{"InitialEnergyAtInfinity", "[", "vinf", "]"}]}], ";"}], "\[IndentingNewLine]",
    " ", 
   RowBox[{
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"umagE", "[", 
      RowBox[{"Einf", ",", " ", "rbarStar"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ImpactAngle", " ", "=", " ", 
     FractionBox["Pi", "4"]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"In", " ", "radians"}], ",", " ", 
     RowBox[{
     "measured", " ", "from", " ", "center", " ", "of", " ", "star", " ", 
      "to", " ", "the", " ", "position", " ", "of", " ", "particle"}], ",", 
     " ", 
     RowBox[{"in", " ", "unit", " ", "circle", " ", "fashion"}], ",", " ", 
     RowBox[{
      RowBox[{"pi", "/", "2"}], " ", "corresponds", " ", "to", " ", "grazing",
       " ", "the", " ", "star", " ", "as", " ", "it", " ", "enters", " ", 
      "and", " ", "0", " ", "corresponds", " ", "to", " ", "a", " ", "radial",
       " ", "drop"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ur0", " ", "=", " ", 
     RowBox[{
      RowBox[{"-", "u"}], "*", 
      RowBox[{"Cos", "[", "ImpactAngle", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"uphi0", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", "rbarStar", ")"}], 
      RowBox[{"(", "u", ")"}], " ", 
      RowBox[{"Sin", "[", "ImpactAngle", "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9804173808295593`*^9, 3.9804174607879868`*^9}, {
  3.980417560868024*^9, 3.98041773116045*^9}, {3.980417823546092*^9, 
  3.980417829039783*^9}, {3.980418080556061*^9, 3.980418082132769*^9}, {
