           SuperscriptBox["10", 
            RowBox[{"-", "3"}]]}], " ", ",", " ", "\"\<StopIntegration\>\""}],
          "]"}]}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"rbar", ",", "ur", ",", "phi", ",", "uphi", ",", " ", "mass"}],
        "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"t", ",", "t0", ",", "tEnd"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"MaxSteps", "->", "20000"}]}], "\[IndentingNewLine]", "]"}], "[", 
