    RowBox[{"PlotLabel", "->", "\"\<u magnitude vs time\>\""}]}], "]"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Show", " ", "me", " ", "the", " ", "value", " ", "of", " ", "u", " ", 
    "at", " ", "tfinish"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
