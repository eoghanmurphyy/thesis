     FractionBox[
      SuperscriptBox["ur", "2"], 
      RowBox[{"Ut", "[", 
       RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "rbar", 
        "]"}], 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "3"]], ")"}]}], " ", "+", " ", 
    RowBox[{
     FractionBox[
      SuperscriptBox["uphi", "2"], 
      RowBox[{"Ut", "[", 
