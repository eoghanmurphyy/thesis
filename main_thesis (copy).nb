Cell[CellGroupData[{

Cell["Performing the inside integration", "Subsubsection",
 CellChangeTimes->{{3.980421920647196*^9, 
  3.980421925692644*^9}},ExpressionUUID->"9eb24d35-dc47-4b4c-9c42-\
f3b18eaa6493"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", "=", "10000"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", "rbarStar"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"drBardt", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"drBardtInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", "rbarStar"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"durdt2DOutside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
           RowBox[{"durdt2DInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"uphi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", "rbarStar"}], ",",
            "\[IndentingNewLine]", "0", ",", "\[IndentingNewLine]", 
           RowBox[{"duphidtInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"phi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", "rbarStar"}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"dphidtOutside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
           RowBox[{"dphidtInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], "==", "rbarStar"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], "==", "ur0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"uphi", "[", "0", "]"}], "==", "uphi0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"phi", "[", "0", "]"}], "==", "phi0"}], ",", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"WhenEvent", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], " ", "-", " ", "rbarStar"}], 
            " ", ">", "0"}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"ur", "[", "t", "]"}], " ", ">", "0"}]}], ",", 
          "\[IndentingNewLine]", "\"\<StopIntegration\>\""}], 
         "\[IndentingNewLine]", "]"}]}], " ", 
       RowBox[{"(*", 
        RowBox[{
        "Stop", " ", "Integration", " ", "if", " ", "the", " ", "PBH", " ", 
         "exits", " ", "the", " ", "star", " ", "again"}], "*)"}], 
       "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"rbar", ",", "ur", ",", "uphi", ",", "phi"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "t0", ",", "tEnd"}], "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"WorkingPrecision", "->", "40"}], ",", "\[IndentingNewLine]", 
      RowBox[{"MaxSteps", "->", "20000"}], ",", " ", "\[IndentingNewLine]", 
      RowBox[{"Method", "->", 
       RowBox[{"{", "\"\<StiffnessSwitching\>\"", "}"}]}]}], 
     "\[IndentingNewLine]", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n"}], "Input",
