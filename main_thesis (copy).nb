Cell[CellGroupData[{

Cell["Density and Pressure in isotropic coordinates", "Subsubsection",
 CellChangeTimes->{{3.98214419447678*^9, 
  3.982144207292704*^9}},ExpressionUUID->"34e47b57-59dc-4842-b455-\
590b2172bc05"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rho", "[", "rbar_", "]"}], " ", ":=", 
    RowBox[{"rho0", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox[
         RowBox[{"rofrbarInside", "[", "rbar", "]"}], "rbarStar"]}], ")"}], 
      "6"]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"IsotropicCoordsPressure", ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Defined", " ", "above"}], 
   "*)"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.982144211620892*^9, 3.9821442587163687`*^9}, {
  3.98214433573979*^9, 3.98214434869094*^9}, {3.982144539241363*^9, 
  3.982144543928986*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"74595016-7a7c-47ca-a440-7766d3099377"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Setting up 2D ODEs for new density profile:", "Section",
 CellChangeTimes->{{3.9795574662013397`*^9, 3.979557480881427*^9}, {
  3.982143351540092*^9, 
  3.982143363854011*^9}},ExpressionUUID->"60532d69-0bc8-452c-b8d3-\
687df1374ea6"],

Cell["Constants that are going to be used", "Text",
 CellChangeTimes->{{3.980679446272872*^9, 3.980679450032609*^9}, {
  3.980679504848711*^9, 3.980679507456327*^9}, {3.9821433675638323`*^9, 
  3.982143380603819*^9}},ExpressionUUID->"c56f6f32-64ee-448a-8c37-\
d032802603cc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"m", " ", "=", " ", 
    SuperscriptBox["10", 
     RowBox[{"-", "6"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"mass", " ", "of", " ", 
    RowBox[{"PBH", "?"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]GR", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{"1.49", "*", 
    RowBox[{"asosPiecewise", "[", "rbar", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"q", " ", "=", " ", "2"}], ";"}]}], "Input",
 CellChangeTimes->{{3.978353073131167*^9, 3.9783533985445127`*^9}, {
   3.978353428815947*^9, 3.978353671446837*^9}, {3.978353706654491*^9, 
