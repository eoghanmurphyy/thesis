Cell["\<\
Fixing the rho0 by letting the total mass integral equal to 1\
\>", "Subsubsection",
 CellChangeTimes->{{3.982122089205103*^9, 3.98212209197443*^9}, {
  3.9821221352997828`*^9, 
  3.982122135747591*^9}},ExpressionUUID->"c0eb3e25-3476-48e7-86c3-\
71942c0ed68e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rho", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"rho0", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox["r", "R"]}], ")"}], "6"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"massIntegral", " ", "=", "  ", 
    RowBox[{"4", " ", "Pi", " ", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"rho", "[", "r", "]"}], " ", 
        SuperscriptBox["r", "2"]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "0", ",", " ", "R"}], "}"}]}], "]"}]}]}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Set", " ", "equal", " ", "to", " ", "1"}], "*)"}]}]}], "Input",
 CellChangeTimes->{
  3.982123566297958*^9, {3.982123619481306*^9, 3.982123627537088*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"114d3bcc-1320-446e-afae-befe0d9ef5f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rhoCentre", "[", "R_", "]"}], " ", ":=", " ", 
   FractionBox["63", 
    RowBox[{"Pi", " ", 
     SuperscriptBox["R", "3"]}]]}], " ", 
  RowBox[{"(*", 
   RowBox[{"From", " ", "the", " ", "above"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rho0", " ", "=", " ", 
   RowBox[{
    RowBox[{"rhoCentre", "[", "RStar", "]"}], " ", "//", "N"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.982122037692268*^9, 3.982122069980132*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"b4726ffb-0f11-4e7e-aadb-a1355f4f3b21"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MassFunc", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"252", 
         RowBox[{"(", 
          RowBox[{
           FractionBox[
            SuperscriptBox["r", "9"], 
            RowBox[{"9", 
             SuperscriptBox["RStar", "9"]}]], "-", 
           FractionBox[
            RowBox[{"3", 
             SuperscriptBox["r", "8"]}], 
            RowBox[{"4", 
             SuperscriptBox["RStar", "8"]}]], "+", 
           FractionBox[
            RowBox[{"15", 
             SuperscriptBox["r", "7"]}], 
            RowBox[{"7", 
             SuperscriptBox["RStar", "7"]}]], "-", 
           FractionBox[
            RowBox[{"10", 
             SuperscriptBox["r", "6"]}], 
            RowBox[{"3", 
             SuperscriptBox["RStar", "6"]}]], "+", 
           FractionBox[
            RowBox[{"3", 
             SuperscriptBox["r", "5"]}], 
            SuperscriptBox["RStar", "5"]], "-", 
           FractionBox[
            RowBox[{"3", 
             SuperscriptBox["r", "4"]}], 
            RowBox[{"2", 
             SuperscriptBox["RStar", "4"]}]], "+", 
           FractionBox[
            SuperscriptBox["r", "3"], 
            RowBox[{"3", 
             SuperscriptBox["RStar", "3"]}]]}], ")"}]}], " ", ",", " ", 
        RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"M", ",", " ", 
        RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "In", " ", "2405.08113", " ", "this", " ", "function", " ", "is", " ", 
     "divided", " ", "by", " ", "the", " ", "solar", " ", "mass"}], ",", " ", 
    
    RowBox[{
     RowBox[{"here", " ", "I", " ", "use", " ", "M"}], "=", "1"}]}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9783301118015347`*^9, 3.978330182920364*^9}, {
   3.9783302193359118`*^9, 3.978330320711*^9}, {3.978330396647119*^9, 
