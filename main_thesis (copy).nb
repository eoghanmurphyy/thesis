     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        RowBox[{
         SuperscriptBox["rbar", "3"], " ", "*", 
         SuperscriptBox[
          RowBox[{"A", "[", "rbar", "]"}], "2"]}]], " ", "+", " ", 
       FractionBox[
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "A", "]"}], "[", "rbar",
