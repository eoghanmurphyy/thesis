Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rho", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"rho0", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox["r", "R"]}], ")"}], "6"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"massIntegral", " ", "=", "  ", 
    RowBox[{"4", " ", "Pi", " ", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"rho", "[", "r", "]"}], " ", 
        SuperscriptBox["r", "2"]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "0", ",", " ", "R"}], "}"}]}], "]"}]}]}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Set", " ", "equal", " ", "to", " ", "1"}], "*)"}]}]}], "Input",
 CellChangeTimes->{
  3.982123566297958*^9, {3.982123619481306*^9, 3.982123627537088*^9}},
