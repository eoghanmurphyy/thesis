Cell["Sanity Check to see if the two energy formulas match up", \
"Subsubsection",
 CellChangeTimes->{{3.9804178342141027`*^9, 
  3.980417849761235*^9}},ExpressionUUID->"87d8c37d-29c5-4eb8-9e0b-\
54e226ea7629"],

Cell[BoxData[{
 RowBox[{"Einf", " ", "=", " ", 
  RowBox[{
   RowBox[{"InitialEnergyAtInfinity", "[", "vinf", "]"}], " ", "//", 
   "N"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SuperscriptBox[
    RowBox[{"\[Alpha]", "[", "rbarStar", "]"}], "2"], "  ", 
   RowBox[{"Ut", "[", 
    RowBox[{"rbarStar", ",", " ", "ur0", ",", " ", "uphi0"}], "]"}]}], " ", "//",
   "N", " ", 
