  RowBox[{"A", "[", "rbarStar", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AInside", "[", "rbarStar", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9821267763924313`*^9, 3.982126787503397*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"10e9e08b-8a2a-4c55-8162-2a0733e243a1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Sorting out the speed of sound as a function of r: a(r)", "Subsection",
 CellChangeTimes->{{3.9821318046645107`*^9, 
  3.982131844559926*^9}},ExpressionUUID->"f4f3c91a-af19-4bac-a8ad-\
2a96cc3236f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Getting", " ", "the", " ", "derivative", " ", "of", " ", "the", " ", 
    "density"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"rhodummy", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{"rho0", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox["r", "RStar"]}], ")"}], "6"]}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"drhodr", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"rhodummy", "'"}], "[", "r", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.982132105614855*^9, 3.9821321406621037`*^9}, {
  3.982132176117798*^9, 3.9821322046531897`*^9}, {3.9821322499414*^9, 
  3.982132274244596*^9}, {3.9821323114844017`*^9, 3.982132345452272*^9}, {
  3.982132387508275*^9, 3.982132397355885*^9}, {3.9821430100876513`*^9, 
  3.982143010223228*^9}},
 CellLabel->"In[44]:=",ExpressionUUID->"a74ab160-6a96-4a0d-846e-d4b6a44e0844"],

Cell[BoxData[
 RowBox[{
  RowBox[{"asos", "[", "r_", "]"}], " ", ":=", " ", 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{"FullSimplify", "[", 
     FractionBox[
      RowBox[{"dPdr", "[", 
       RowBox[{"r", ",", " ", 
        RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], 
      RowBox[{"drhodr", "[", "r", "]"}]], "]"}], ")"}], 
   FractionBox["1", "2"]]}]], "Input",
 CellChangeTimes->{{3.9821357104256496`*^9, 3.982135711265492*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"17dc7eab-a615-4840-b371-0e32c71008e1"],

Cell[TextData[StyleBox["This is the a(r) function I will use for now:",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.982143292940094*^9, 
  3.982143305660943*^9}},ExpressionUUID->"cf94b5d6-1cdc-4b99-8254-\
e4cb1799e014"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"asosPiecewise", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"asos", "[", "r", "]"}], ",", " ", 
        RowBox[{"r", " ", "<=", " ", 
         RowBox[{"RStar", "*", ".99989789203"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"asos", "[", 
         RowBox[{"RStar", "*", ".99989789203"}], "]"}], ",", " ", 
        RowBox[{"r", " ", ">", 
         RowBox[{"RStar", "*", ".99989789203"}]}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"asos", "[", 
    SuperscriptBox["10", 
     RowBox[{"-", "120"}]], "]"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "zero", " ", "does", " ", "not", " ", "work", " ", "but", " ", "small", " ",
     "r", " ", 
    RowBox[{"does", "!"}]}], "*)"}]}]}], "Code",
