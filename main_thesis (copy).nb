          RowBox[{"rbar", " ", 
           RowBox[{"A", "[", "rbar", "]"}]}]], ")"}], "2"]}]], 
     RowBox[{"\[Alpha]", "[", "rbar", "]"}]]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
