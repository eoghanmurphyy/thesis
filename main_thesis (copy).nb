               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"mass", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"mdot", "[", 
               RowBox[{
                RowBox[{"mass", "[", "t", "]"}], ",", " ", 
                RowBox[{"rbar", "[", "t", "]"}], ",", " ", 
                RowBox[{"ur", "[", "t", "]"}], ",", " ", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], "==", " ", "rbar0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], "==", "0"}], ",", 
