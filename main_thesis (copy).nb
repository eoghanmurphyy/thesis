        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"AInside", "[", "rbar", "]"}], "*", "rbar"}], ",", 
          RowBox[{"rbar", "<", "rbarStar"}]}], "}"}]}], "    ", 
       RowBox[{"(*", "interior", "*)"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Areal", " ", "radius", " ", "along", " ", "the", " ", "orbit"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"arealr", "[", "t_", "]"}], ":=", 
     RowBox[{"rFromRbar", "[", 
      RowBox[{"rbarNumIn", "[", "t", "]"}], "]"}]}], ";"}]}]}]], "Input",
