  3.978425624888094*^9}},ExpressionUUID->"199a3d31-7817-422a-ae35-\
3382bc7c86ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", "=", "2000"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"solIn", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardt", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"drBardtInside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt2DOutside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"durdt2DInside", "[", 
               RowBox[{
                RowBox[{"mass", "[", "t", "]"}], ",", " ", 
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], "<", "rbarStar"}]}], "}"}]}], 
           "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"uphi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"duphidtInside", "[", 
               RowBox[{
                RowBox[{"mass", "[", "t", "]"}], ",", 
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
