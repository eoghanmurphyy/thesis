  RowBox[{
   RowBox[{
    RowBox[{"rhodummy", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{"rho0", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox["r", "RStar"]}], ")"}], "6"]}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
