Cell[BoxData[{
 RowBox[{
  RowBox[{"x1", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x2", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", " ", "=", " ", "3.03"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y2", " ", "=", " ", "6.67"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"anaylticline", "[", "\[CapitalMu]ach_", "]"}], " ", ":=", " ", 
   RowBox[{"y1", " ", "+", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"y2", " ", "-", " ", "y1"}], ")"}], " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", " ", "-", " ", "x1"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"x2", " ", "-", " ", "x1"}], ")"}]}]}]}]}], ";"}]}], "Input",
