        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"phi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         
         RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"dphidtOutside", "[", 
               RowBox[{
                RowBox[{"rbar", "[", "t", "]"}], ",", 
                RowBox[{"ur", "[", "t", "]"}], ",", 
                RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"rbar", "[", "t", "]"}], ">=", "rbarStar"}]}], "}"}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
