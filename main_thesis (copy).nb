          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"ur", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", "rbarStar"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"durdt2DOutside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
           RowBox[{"durdt2DInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"uphi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", "rbarStar"}], ",",
            "\[IndentingNewLine]", "0", ",", "\[IndentingNewLine]", 
           RowBox[{"duphidtInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"phi", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", " ", "rbarStar"}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"dphidtOutside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}], ",", 
           RowBox[{"dphidtInside", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
             RowBox[{"uphi", "[", "t", "]"}]}], "]"}]}], 
          "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rbar", "[", "0", "]"}], "==", "rbarStar"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ur", "[", "0", "]"}], "==", "ur0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"uphi", "[", "0", "]"}], "==", "uphi0"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"phi", "[", "0", "]"}], "==", "phi0"}], ",", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"WhenEvent", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], " ", "-", " ", "rbarStar"}], 
            " ", ">", "0"}], " ", "&&", " ", 
           RowBox[{
            RowBox[{"ur", "[", "t", "]"}], " ", ">", "0"}]}], ",", 
          "\[IndentingNewLine]", "\"\<StopIntegration\>\""}], 
         "\[IndentingNewLine]", "]"}]}], " ", 
       RowBox[{"(*", 
        RowBox[{
        "Stop", " ", "Integration", " ", "if", " ", "the", " ", "PBH", " ", 
