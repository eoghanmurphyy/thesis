Cell[CellGroupData[{

Cell["Outside Star", "Subsubsection",
 CellChangeTimes->{{3.978425344080608*^9, 3.978425346827289*^9}, {
  3.979557790574851*^9, 
  3.979557792742944*^9}},ExpressionUUID->"dbd6d834-67ec-4f63-a486-\
7d264dea3e38"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ut", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    FractionBox[
     SqrtBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["ur", 
          RowBox[{"A", "[", "rbar", "]"}]], ")"}], "2"], " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["uphi", 
          RowBox[{"rbar", " ", 
           RowBox[{"A", "[", "rbar", "]"}]}]], ")"}], "2"]}]], 
     RowBox[{"\[Alpha]", "[", "rbar", "]"}]]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"drBardt", "[", 
     RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"], 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
     "ur"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dphidtOutside", "[", 
     RowBox[{"rbar_", ",", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", " ", 
    
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["rbar", "2"], "*", 
       SuperscriptBox[
        RowBox[{"A", "[", "rbar", "]"}], "2"], "*", 
       RowBox[{"Ut", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", "uphi"}], "]"}]}]], "uphi"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"durdt2DOutside", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
   " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Alpha]", "[", "rbar", "]"}]}], " ", 
     RowBox[{"Ut", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], " ", 
     RowBox[{
