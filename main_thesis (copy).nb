Cell[BoxData[{
 RowBox[{
  RowBox[{"x1", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x2", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", " ", "=", " ", "3.03"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y2", " ", "=", " ", "6.67"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"anaylticline", "[", "\[CapitalMu]ach_", "]"}], " ", ":=", " ", 
   RowBox[{"y1", " ", "+", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"y2", " ", "-", " ", "y1"}], ")"}], " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"x", " ", "-", " ", "x1"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"x2", " ", "-", " ", "x1"}], ")"}]}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9806811143147*^9, 3.980681141609749*^9}, {
  3.980681296608494*^9, 3.980681314784219*^9}},
 CellLabel->
  "In[373]:=",ExpressionUUID->"64393063-df6d-488b-91c2-efc7ca9baf13"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"IVariableInterpolated", "[", "\[CapitalMu]ach_", "]"}], " ", ":=",
    " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"1", "+", " ", "\[CapitalMu]ach"}], 
