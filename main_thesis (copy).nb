    FractionBox[
     SqrtBox[
      RowBox[{"1", " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["ur", 
          RowBox[{"A", "[", "rbar", "]"}]], ")"}], "2"], " ", "+", " ", 
       SuperscriptBox[
        RowBox[{"(", 
