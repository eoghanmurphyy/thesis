Cell["Mach Number business", "Subsubsection",
 CellChangeTimes->{{3.980680279057019*^9, 
  3.980680282704877*^9}},ExpressionUUID->"1b74a3e5-9f8e-43f8-a1b0-\
784562e16e80"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"IVariable", "[", "\[CapitalMu]ach_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"1", "+", " ", "\[CapitalMu]ach"}], 
            RowBox[{"1", " ", "-", " ", "\[CapitalMu]ach"}]], "]"}]}], " ", "-",
          " ", "\[CapitalMu]ach"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", "<", " ", "1"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["1", 
             SuperscriptBox["\[CapitalMu]ach", "2"]]}], "]"}]}], "  ", "+", 
         " ", "10"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", ">", " ", "1"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Approximate", " ", 
     RowBox[{
      RowBox[{"Log", "[", "\[CapitalLambda]", "]"}], " ", "~", " ", "10"}], " ",
      "following", " ", "other", " ", 
     RowBox[{"authors", " ", "[", "9", "]"}], " ", "on", " ", "2404"}], "]"}],
    "*)"}]}]}], "Input",
 CellChangeTimes->{{3.980680283866652*^9, 3.980680457767849*^9}, {
  3.980680721157262*^9, 3.98068073036535*^9}, {3.9806807679813747`*^9, 
  3.980680809332712*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"9dbf3b13-847c-478b-b24b-d48e1a8b2646"],

