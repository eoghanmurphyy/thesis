Cell[BoxData[{
 RowBox[{
  RowBox[{"t0", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tEnd", "=", "10000"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solIn", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"rbar", "'"}], "[", "t", "]"}], "==", "\[IndentingNewLine]", 
         RowBox[{"If", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"rbar", "[", "t", "]"}], " ", ">=", "rbarStar"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"drBardt", "[", 
            RowBox[{
             RowBox[{"rbar", "[", "t", "]"}], ",", 
             RowBox[{"ur", "[", "t", "]"}], ",", 
