Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Inverse", " ", "Interpolation"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"rofrbarInside", " ", "=", " ", 
   RowBox[{"Interpolation", "[", "data", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Builds", " ", "a", " ", "function", " ", "from", " ", "the", " ", 
      "data", " ", "passing", " ", "through", " ", "all", " ", "points", " ", 
      "unlike", " ", "Fit", " ", "which", " ", "approximately", " ", 
      "matches", " ", "the", " ", "data", " ", "to", " ", "a", " ", 
      "function", " ", "I", " ", "give", " ", "it", " ", "with", " ", 
      "parameters"}], ",", "  ", 
     RowBox[{
     "FindFit", " ", "finds", " ", "the", " ", "parameters", " ", "for", " ", 
      "me", " ", "given", " ", "I", " ", "guess", " ", "a", " ", "suitable", " ",
       "function"}]}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9821259732469397`*^9, 3.982126030638027*^9}, {
