Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"rbarofrInside", "[", "r_", "]"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"rbarofr", "[", "r", "]"}], " ", "/.", " ", "sol2"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
