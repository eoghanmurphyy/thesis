Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"IVariable", "[", "\[CapitalMu]ach_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"Log", "[", 
           FractionBox[
            RowBox[{"1", "+", " ", "\[CapitalMu]ach"}], 
            RowBox[{"1", " ", "-", " ", "\[CapitalMu]ach"}]], "]"}]}], " ", "-",
          " ", "\[CapitalMu]ach"}], ",", " ", 
        RowBox[{"\[CapitalMu]ach", " ", "<", " ", "1"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
