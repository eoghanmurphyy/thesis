Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalMu]", "[", 
   RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
  " ", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{"umagphi", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
        RowBox[{
         RowBox[{"asosPiecewise", "[", "rbar", "]"}], " ", 
         RowBox[{"\[Alpha]", "[", "rbar", "]"}], " ", 
         RowBox[{"Ut", "[", 
          RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], ",", 
       " ", 
       RowBox[{"rbar", " ", "<", " ", "rbarStar"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       FractionBox[
        RowBox[{"umagphi", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
        RowBox[{
         RowBox[{"asosPiecewise", "[", "rbar", "]"}], " ", 
         RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], " ", 
         RowBox[{"UtInside", "[", 
          RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], ",", 
       " ", 
       RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
