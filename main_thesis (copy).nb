Cell[CellGroupData[{

Cell["Sorting out the speed of sound as a function of r: a(r)", "Subsection",
 CellChangeTimes->{{3.9821318046645107`*^9, 
  3.982131844559926*^9}},ExpressionUUID->"f4f3c91a-af19-4bac-a8ad-\
2a96cc3236f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Getting", " ", "the", " ", "derivative", " ", "of", " ", "the", " ", 
    "density"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"rhodummy", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{"rho0", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox["r", "RStar"]}], ")"}], "6"]}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"drhodr", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"rhodummy", "'"}], "[", "r", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.982132105614855*^9, 3.9821321406621037`*^9}, {
  3.982132176117798*^9, 3.9821322046531897`*^9}, {3.9821322499414*^9, 
  3.982132274244596*^9}, {3.9821323114844017`*^9, 3.982132345452272*^9}, {
  3.982132387508275*^9, 3.982132397355885*^9}, {3.9821430100876513`*^9, 
  3.982143010223228*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"a74ab160-6a96-4a0d-846e-d4b6a44e0844"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"asos", "[", "r_", "]"}], " ", ":=", " ", 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox[
      RowBox[{"dPdr", "[", 
