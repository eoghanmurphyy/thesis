         RowBox[{"2", " ", 
          SuperscriptBox[
           RowBox[{"umagInside", "[", 
            RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
           "2"]}]}], ")"}], "2"], " ", 
      RowBox[{"IVariableInterpolated", "[", 
       RowBox[{"Mach", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "]"}], " ",
       "*", "ur"}], ")"}], "/", 
    SuperscriptBox[
     RowBox[{"umagInside", "[", 
      RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "3"]}]}], 
  ";"}]}], "Input",
