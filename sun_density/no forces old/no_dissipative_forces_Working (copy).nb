       SuperscriptBox["m", "2"]}], ")"}], ")"}]}], 
   SuperscriptBox[
    RowBox[{"(", 
     FractionBox["1", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"asosPiecewise", "[", "rbar", "]"}], "2"], "+", 
