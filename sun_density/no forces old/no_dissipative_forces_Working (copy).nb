      RowBox[{"{", 
       RowBox[{
        RowBox[{"rho0", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["r", "RStar"]}], ")"}], "6"]}], ",", " ", 
        RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}]], "Input",
