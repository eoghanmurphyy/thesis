           RowBox[{"UtInside", "[", 
            RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}]}]], 
         ")"}], "2"]}]], ")"}], 
    FractionBox["q", "2"]], "uphi"}]}]}], "Input",
