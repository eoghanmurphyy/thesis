    RowBox[{
     FractionBox["1", 
      SuperscriptBox[
       RowBox[{"umagInside", "[", 
        RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "3"]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "4"}], "\[Pi]", " ", 
       RowBox[{"\[Alpha]Inside", "[", "rbar", "]"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rho", "[", "rbar", "]"}], " ", "+", " ", 
         RowBox[{"IsotropicCoordsPressure", "[", "rbar", "]"}]}], ")"}], "*", 
       
       SuperscriptBox["m", "2"], "*", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"2", " ", 
           SuperscriptBox[
            RowBox[{"umagInside", "[", 
             RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], 
            "2"]}]}], ")"}], "2"], " ", "*", 
       RowBox[{"IVariableInterpolated", "[", 
        RowBox[{"Mach", "[", 
         RowBox[{"rbar", ",", " ", "ur", ",", " ", "uphi"}], "]"}], "]"}], 
       " ", "*", "uphi"}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dpdtdragr", "[", 
    RowBox[{"rbar_", ",", " ", "ur_", ",", " ", "uphi_"}], "]"}], " ", ":=", 
   " ", 
