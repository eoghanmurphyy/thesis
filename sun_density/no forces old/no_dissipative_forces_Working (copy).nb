  3.982124406532078*^9}},ExpressionUUID->"c2bbe5a5-0dc1-4f7e-ab60-\
33a0469aaa6c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"rbarofr", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"drbardr", "[", 
     RowBox[{
      RowBox[{"rbarofr", "[", "r", "]"}], ",", " ", "r"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BC", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"rbarofr", "[", "RStar", "]"}], " ", "==", " ", "rbarStar"}], 
    "}"}]}], ";"}]}], "Input",
