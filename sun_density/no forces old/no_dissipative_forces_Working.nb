   RowBox[{"rho0", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox["r", "R"]}], ")"}], "6"]}]}], ";"}], "\[IndentingNewLine]", 
