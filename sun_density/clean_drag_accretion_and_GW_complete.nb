Cell[BoxData[{
 RowBox[{
  RowBox[{"eq1", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"P", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPdr", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq2", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Phi", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BCs", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"P", "[", "RStar", "]"}], " ", "==", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"Phi", "[", "RStar", "]"}], " ", "==", " ", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], "]"}]}]}]}], "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Phi", "[", "RStar", "]"}], " ", "from", " ", "the", " ", 
    "Schwarzschild", " ", "metric"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982122468706362*^9, 3.9821225498339243`*^9}, {
  3.982123843807171*^9, 3.982123907678915*^9}, {3.9823916180786943`*^9, 
  3.982391618438609*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"7b8d8367-53bf-41c1-9952-3066776a590d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"sol1", " ", "=", " ", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "eq1", ",", "\[IndentingNewLine]", "eq2", ",", "\[IndentingNewLine]", 
         "BCs"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"P", ",", " ", "Phi"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "RStar", ",", " ", "rmin"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"WorkingPrecision", "->", "40"}]}], "\[IndentingNewLine]", 
      "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Very", " ", "small", " ", "rmin", " ", "to", " ", "avoid", " ", 
    "singularity", " ", "sarp", " ", "mentioned"}], "*)"}]}]], "Input",
