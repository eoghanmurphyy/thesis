 CellLabel->"In[14]:=",ExpressionUUID->"16fc508b-83cc-44fd-8caa-34e7955c55cc"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Numerically integrating these coupled ODEs", \
"Subsection"]], "Subsubsection",
 CellChangeTimes->{{3.982122414666267*^9, 3.982122461514476*^9}, {
  3.982124096429223*^9, 3.982124100636909*^9}, {3.982817795476213*^9, 
