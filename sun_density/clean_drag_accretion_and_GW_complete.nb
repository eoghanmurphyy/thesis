Cell[CellGroupData[{

Cell["Average, physical angular momentum loss per orbit", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 3.982908628893798*^9}, {
  3.9829089136749773`*^9, 
  3.982908917635139*^9}},ExpressionUUID->"7087689c-b514-4a77-aace-\
14dcd3789714"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
   "Formula", " ", "might", " ", "need", " ", "to", " ", "be", " ", 
    "adjusted", " ", "for", " ", "me", " ", "as", " ", "they", " ", "use", " ",
     "the", " ", "angle", " ", "phi"}], " ", "=", " ", 
   RowBox[{
   "0", " ", "for", " ", "when", " ", "it", " ", "crosses", " ", "the", " ", 
    "star", " ", "surface", " ", "which", " ", "is", " ", "not", " ", "true", 
    " ", "for", " ", "me"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9829091670181303`*^9, 3.982909195169149*^9}},
 CellLabel->
  "In[319]:=",ExpressionUUID->"dc7c96bf-fdb4-4de5-b668-203eef21abca"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dLdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", 
        RowBox[{"(", 
         RowBox[{"5", "/", "2"}], ")"}]}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", "2", ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "/", "8"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}, {
  3.982908921003359*^9, 3.98290892892343*^9}, {3.982909074962366*^9, 
  3.98290911543382*^9}},
 CellLabel->
  "In[320]:=",ExpressionUUID->"9e13cf26-74a7-417f-b2e8-21c010d3c40a"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t).\
\>", "Text",
