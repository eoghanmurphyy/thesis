Cell[CellGroupData[{

Cell["Average, physical energy loss per orbit", "Subsection",
 CellChangeTimes->{{3.982908621407299*^9, 
  3.982908628893798*^9}},ExpressionUUID->"94c1c211-524c-4798-a2bc-\
c6cc8d559d5d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtAvg", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"32", " ", 
       RowBox[{"m", "^", "2"}], " ", 
       RowBox[{"M", "^", "3"}]}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"5", " ", 
      RowBox[{"a", "^", "5"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"e", "^", "2"}]}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"7", "/", "2"}], ")"}]}]}], ")"}]}], "*", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"73", "/", "24"}], ")"}], " ", 
      RowBox[{"e", "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"37", "/", "96"}], ")"}], " ", 
      RowBox[{"e", "^", "4"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982908695319152*^9, 3.982908695319168*^9}},
 CellLabel->
  "In[198]:=",ExpressionUUID->"202da191-49b8-4cd2-8018-209aec590212"],

Cell["\<\
Need formulae for M[t]? Although accretion is very small. a(t) and e(t)\
\>", "Text",
 CellChangeTimes->{{3.982908944388515*^9, 
  3.982908980562503*^9}},ExpressionUUID->"2365c322-7d86-43d4-bf99-\
d51a6decdcf9"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Angular momentum loss during orbits", "Section",
 CellChangeTimes->{{3.9829080587145233`*^9, 3.982908071585734*^9}, {
  3.982908598693872*^9, 3.9829086053179703`*^9}, {3.982908873003482*^9, 
  3.982908877363311*^9}},ExpressionUUID->"509e64d7-26df-40bb-99b1-\
6a16edc86174"],

Cell[CellGroupData[{

Cell["\<\
Instantaneous angular momentum loss (coordinate system dependent)\
\>", "Subsection",
 CellChangeTimes->{{3.98290861036561*^9, 3.982908637213344*^9}, {
  3.982908904907382*^9, 
  3.982908909299267*^9}},ExpressionUUID->"bdd6c9ed-fcff-499c-9f85-\
cbd0cc2a1b80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dLdt", "[", 
   RowBox[{"m_", ",", "M_", ",", "a_", ",", "e_", ",", " ", "phi_"}], "]"}], ":=",
   " ", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     RowBox[{"4", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["m", "2"], " ", 
        SuperscriptBox["M", 
         FractionBox["5", "2"]]}], ")"}]}], 
     RowBox[{"5", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["a", 
         FractionBox["7", "2"]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["e", "2"]}], ")"}], 
         FractionBox["7", "2"]]}], ")"}]}]]}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{"e", " ", 
       RowBox[{"Cos", "[", "phi", "]"}]}]}], ")"}], "3"], " ", 
   RowBox[{"(", 
    RowBox[{"8", " ", "-", " ", 
     RowBox[{"3", 
      SuperscriptBox["e", "2"]}], " ", "+", " ", 
     RowBox[{"20", "e", " ", 
      RowBox[{"Cos", "[", "phi", "]"}]}], " ", "+", " ", 
     RowBox[{"15", 
      SuperscriptBox["e", "2"], 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "phi"}], "]"}]}]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9829080741491127`*^9, 3.982908074149129*^9}, {
   3.98290816171437*^9, 3.98290816416226*^9}, 3.9829081961136208`*^9, 
   3.982908233153319*^9, 3.9829082663530807`*^9, {3.982908932123487*^9, 
   3.982908933363347*^9}, {3.982909375080247*^9, 3.982909512279233*^9}},
 CellLabel->
  "In[199]:=",ExpressionUUID->"8580f40f-d73a-4040-b554-0d9494913fba"],

