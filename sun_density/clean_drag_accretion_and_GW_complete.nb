Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FRRr", "[", 
    RowBox[{
     RowBox[{"m_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"rbar_", "?", "NumericQ"}], ",", 
     RowBox[{"ur_", "?", "NumericQ"}], ",", " ", 
     RowBox[{"uphi_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], "}"}], ",", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"8", " ", 
          RowBox[{"m", "^", "2"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"15", " ", 
