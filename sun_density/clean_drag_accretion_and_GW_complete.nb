 RowBox[{
  RowBox[{"dEdtOutside", "[", 
   RowBox[{"m_", ",", "rbar_", ",", "ur_", ",", "uphi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], ",", "rd", ",", 
      "phid"}], "}"}], ",", 
    RowBox[{
