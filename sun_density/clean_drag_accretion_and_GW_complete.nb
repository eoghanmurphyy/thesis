    RowBox[{"Piecewise", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"dPdr", "[", 
            RowBox[{"r", ",", 
             RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], "/", 
           RowBox[{"drhodr", "[", "r", "]"}]}], "]"}], ",", 
         RowBox[{"rbar", "<", "cutoffIso"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"asosEnd", "[", "rbar", "]"}], ",", 
         RowBox[{"cutoffIso", "<=", "rbar", "<=", "rbarStar"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"asosEnd", "[", "rbarStar", "]"}], ",", " ", 
         RowBox[{"rbar", " ", ">", " ", "rbarStar"}]}], "}"}]}], 
