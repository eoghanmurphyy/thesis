Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"DER\[Alpha]Outside", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"drbardr", "[", "r", "]"}], "  ", 
