Cell[BoxData[
 RowBox[{
  RowBox[{"sol2", " ", "=", " ", 
   RowBox[{
    RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
