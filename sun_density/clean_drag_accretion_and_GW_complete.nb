          RowBox[{
           RowBox[{"8", " ", 
            RowBox[{"rd", "^", "2"}]}], "+", 
           RowBox[{"6", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}]}], ")"}]}], "+", 
        RowBox[{"r", " ", "M", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{"rd", "^", "4"}]}], "-", 
           RowBox[{"6", " ", 
            RowBox[{"(", 
             RowBox[{"3", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}]}], ")"}]}], "+", 
           RowBox[{
            RowBox[{"rd", "^", "2"}], " ", 
            RowBox[{"(", 
             RowBox[{"63", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}], ")"}]}]}], 
          ")"}]}]}], ")"}]}]}]}], "]"}]}]], "Input",
