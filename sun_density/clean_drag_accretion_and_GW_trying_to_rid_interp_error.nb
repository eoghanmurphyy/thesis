    RowBox[{"{", 
     RowBox[{
      RowBox[{"GrayLevel", "[", "0.9", "]"}], ",", 
      RowBox[{"Disk", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", "rbarStar"}], "]"}]}], "}"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"centralBody", ",", " ", "orbit2D", ",", 
