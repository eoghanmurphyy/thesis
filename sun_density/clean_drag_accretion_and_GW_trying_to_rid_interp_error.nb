Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"TOV", " ", "differential", " ", "equation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPdr", "[", 
     RowBox[{
      RowBox[{"r_", "?", "NumericQ"}], ",", " ", "Pressure_"}], "]"}], " ", ":=",
     " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"rho0", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["r", "RStar"]}], ")"}], "6"]}], " ", "+", " ", 
        "Pressure"}], ")"}]}], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{"MassFuncInside", "[", "r", "]"}], " ", "+", " ", 
        RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
         SuperscriptBox["r", "3"]}]}], 
       RowBox[{"r", 
        RowBox[{"(", 
         RowBox[{"r", "-", 
          RowBox[{"2", 
           RowBox[{"MassFuncInside", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}]}],
    ";"}]}]], "Input",
 CellChangeTimes->{{3.9807601294062366`*^9, 3.98076013474163*^9}, {
   3.980760167277755*^9, 3.980760297804946*^9}, {3.98076131275782*^9, 
