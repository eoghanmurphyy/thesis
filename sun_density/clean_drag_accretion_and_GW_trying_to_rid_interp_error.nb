Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Maybe", " ", "issue", " ", "with", " ", "NDSolve", " ", "is", " ", "that",
     " ", "there", " ", "are", " ", "two", " ", "numerically", " ", 
    "integrated", " ", "things", " ", "here", " ", "being", " ", "used", " ", 
    "and", " ", "its", " ", "causing", " ", 
    RowBox[{"issues", "?"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Going", " ", "to", " ", "make", " ", "the", " ", "above", " ", "as", " ", 
    "one", " ", "interpolating", " ", "function"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"data", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rbarofrInside", "[", "r", "]"}], ",", " ", 
        RowBox[{"Pressure", "[", "r", "]"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"r", ",", " ", "0", ",", " ", "RStar", ",", " ", 
        FractionBox["RStar", "1000"]}], "}"}]}], "]"}]}], ";"}]}]], "Input",
