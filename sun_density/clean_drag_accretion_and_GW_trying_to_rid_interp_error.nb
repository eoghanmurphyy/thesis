  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"DERalphaIns", "[", 
          RowBox[{"rofrbarInside", "[", "rbar", "]"}], "]"}], ",", 
         RowBox[{"rbar", "<=", "rbarStar"}]}], "}"}], "}"}], "]"}], ",", 
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
