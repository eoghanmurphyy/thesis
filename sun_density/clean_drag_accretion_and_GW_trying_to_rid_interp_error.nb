Cell[CellGroupData[{

Cell["Making the derivative of alpha continuous", "Subsection",
 CellChangeTimes->{{3.982818100593948*^9, 
  3.982818108849741*^9}},ExpressionUUID->"16d969c8-09ee-437d-a513-\
e48595592485"],

Cell[CellGroupData[{

Cell["Interior derivative in terms of r", "Subsubsection",
 CellChangeTimes->{{3.982818175953421*^9, 
  3.982818182321394*^9}},ExpressionUUID->"5b3e96d5-dd29-47b9-8b80-\
8e964df4fe50"],

Cell["Doing things in r first as this is more analytic", "Text",
 CellChangeTimes->{{3.982818131907432*^9, 
  3.982818140641671*^9}},ExpressionUUID->"34fd6405-baaa-4e46-bf5d-\
ec43a1fbdd10"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dPhidrMetric", "[", 
   RowBox[{"r_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
  RowBox[{"(", 
   FractionBox[
    RowBox[{
     RowBox[{"MassFuncInside", "[", "r", "]"}], " ", "+", " ", 
     RowBox[{"4", " ", "Pi", " ", 
      RowBox[{"Pressure", "[", "r", "]"}], " ", 
      SuperscriptBox["r", "3"]}]}], 
    RowBox[{"r", 
     RowBox[{"(", 
      RowBox[{"r", "-", 
       RowBox[{"2", 
        RowBox[{"MassFuncInside", "[", "r", "]"}]}]}], ")"}]}]], 
   ")"}]}]], "Input",
 CellChangeTimes->{{3.982393502718885*^9, 3.9823935097345247`*^9}, {
  3.982399278079626*^9, 3.982399279215176*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"515f1ef7-7469-42e0-aee7-ee3412433acc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"alpha", "[", 
   RowBox[{"r_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
  RowBox[{"Exp", "[", 
   RowBox[{"PhiMetric", "[", "r", "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DERalphaIns", "[", 
   RowBox[{"r_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"dPhidrMetric", "[", "r", "]"}], " ", 
   RowBox[{"alpha", "[", "r", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Analytic", " ", "times", " ", "numerical", " ", "integral"}], 
    "*)"}]}]}]}], "Input",
 CellChangeTimes->{{3.982393421464878*^9, 3.982393486503831*^9}, {
  3.982393520726775*^9, 3.982393525326456*^9}, {3.982393731557509*^9, 
  3.982393731861285*^9}, {3.9828181498500853`*^9, 3.982818160353858*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"56ff7bf8-857a-4103-8844-e47b229c404c"],

Cell[TextData[StyleBox["Exterior derivative", "Subsubsection"]], "Text",
 CellChangeTimes->{{3.982393538336166*^9, 3.982393542438478*^9}, {
  3.9828181906973343`*^9, 
  3.982818190865354*^9}},ExpressionUUID->"e4045bc6-6dfd-495e-a2cd-\
ae5aba47049d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DER\[Alpha]Outsiderbardummy", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
    "rbar", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DER\[Alpha]Outsiderbar", "[", 
    RowBox[{"r_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"1", "-", 
        FractionBox["1", 
         RowBox[{"2", " ", "rbar"}]]}], 
       RowBox[{"2", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "+", 
           FractionBox["1", 
            RowBox[{"2", " ", "rbar"}]]}], ")"}], "2"], " ", 
        SuperscriptBox["rbar", "2"]}]], "+", 
      FractionBox["1", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          FractionBox["1", 
           RowBox[{"2", " ", "rbar"}]]}], ")"}], " ", 
        SuperscriptBox["rbar", "2"]}]]}], " ", ")"}], "/.", " ", 
    RowBox[{"rbar", " ", "->", " ", 
     RowBox[{"rbarofrOutside", "[", "r", "]"}]}]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "More", " ", "accurate", " ", "subbing", " ", "in", " ", "after", " ", 
    "for", " ", "rbar", " ", 
    RowBox[{"maybe", "?"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"drbardr", "[", 
   RowBox[{"r_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox[
    RowBox[{"rbarofrOutside", "[", "r", "]"}], "r"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox[
       RowBox[{"2", "M"}], "r"]}], ")"}], 
    RowBox[{"-", 
     FractionBox["1", "2"]}]]}]}]}], "Input",
 CellChangeTimes->{{3.982393741125156*^9, 3.9823937448050137`*^9}, {
  3.982393806669126*^9, 3.982393871731821*^9}, {3.982398059609561*^9, 
  3.982398156392806*^9}, {3.982398204816495*^9, 3.9823982572471333`*^9}, {
  3.98239830059966*^9, 3.9823983187834263`*^9}, {3.9823984157983627`*^9, 
  3.982398430038177*^9}, {3.9823985107016172`*^9, 3.982398518949471*^9}, {
  3.98299875577149*^9, 3.982998756234054*^9}},
 CellLabel->"In[48]:=",ExpressionUUID->"07adca82-3b0e-4905-891b-d24a2a15e370"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DERalpha", "[", 
   RowBox[{"r_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"drbardr", "[", "r", "]"}], "  ", 
   RowBox[{"DER\[Alpha]Outsiderbar", "[", "r", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Chain", " ", "rule"}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.98239376174957*^9, 3.982393776652556*^9}, {
