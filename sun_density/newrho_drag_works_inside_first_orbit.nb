Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"(*", 
   RowBox[{
   "Evaluates", " ", "ok", " ", "at", " ", "zero", " ", "as", " ", "sarp", " ",
     "mentioned", " ", "but", " ", "integral", " ", 
    RowBox[{"doesn", "'"}], "t", " ", "like", " ", "it", " ", "one", " ", 
