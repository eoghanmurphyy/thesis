Cell[BoxData[{
 RowBox[{
  RowBox[{"Energy", " ", "=", " ", 
   RowBox[{"EnergyPerUnitMass", "[", 
    RowBox[{"ptilde", ",", " ", "eccentricity"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AngularMomentumUphi0", " ", "=", " ", 
   RowBox[{"LPerUnitMass", "[", 
    RowBox[{"ptilde", ",", " ", "M", ",", " ", "eccentricity"}], "]"}]}], 
  ";"}]}], "Input",
