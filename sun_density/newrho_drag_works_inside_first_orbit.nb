Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Pressure", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"P", "[", "r", "]"}], " ", "/.", " ", "sol1"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
