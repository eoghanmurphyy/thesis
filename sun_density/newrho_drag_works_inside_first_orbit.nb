Cell[TextData[StyleBox["Initial drop radius (apoapsis), closest point it goes \
to (perihelion), defining Isotropic star radius", "Subsubsection"]], "Text",
 CellChangeTimes->{{3.9806798730208483`*^9, 
  3.980679914740705*^9}},ExpressionUUID->"1011871d-38c8-4f9d-bb1f-\
18603b1094b9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"r0", " ", "=", " ", 
  RowBox[{"rapoapsis", "[", 
   RowBox[{"eccentricity", ",", " ", "ptilde", ",", " ", "M"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rbar0", " ", "=", " ", 
   RowBox[{"rbarofrOutside", "[", "r0", "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rperiapsis", "[", 
    RowBox[{"eccentricity", ",", " ", "ptilde"}], "]"}], ";"}], " ", 
  RowBox[{"(*", 
