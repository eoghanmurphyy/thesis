           FractionBox[
            RowBox[{"3", 
             SuperscriptBox["r", "4"]}], 
            RowBox[{"2", 
             SuperscriptBox["RStar", "4"]}]], "+", 
           FractionBox[
            SuperscriptBox["r", "3"], 
            RowBox[{"3", 
             SuperscriptBox["RStar", "3"]}]]}], ")"}]}], " ", ",", " ", 
        RowBox[{"r", " ", "<=", " ", "RStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
