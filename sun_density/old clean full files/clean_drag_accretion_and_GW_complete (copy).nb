 RowBox[{
  RowBox[{"hxOutside", "[", 
   RowBox[{
   "d_", ",", " ", "m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", 
    "uphi_", ",", " ", "phi_"}], "]"}], " ", ":=", " ", 
