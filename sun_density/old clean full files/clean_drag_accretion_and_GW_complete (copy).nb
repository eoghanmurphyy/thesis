Cell[BoxData[
 RowBox[{
  RowBox[{"MassFuncdummy", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"252", 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      SuperscriptBox["r", "9"], 
      RowBox[{"9", 
       SuperscriptBox["RStar", "9"]}]], "-", 
     FractionBox[
      RowBox[{"3", 
       SuperscriptBox["r", "8"]}], 
      RowBox[{"4", 
       SuperscriptBox["RStar", "8"]}]], "+", 
     FractionBox[
      RowBox[{"15", 
       SuperscriptBox["r", "7"]}], 
      RowBox[{"7", 
       SuperscriptBox["RStar", "7"]}]], "-", 
     FractionBox[
      RowBox[{"10", 
       SuperscriptBox["r", "6"]}], 
      RowBox[{"3", 
       SuperscriptBox["RStar", "6"]}]], "+", 
     FractionBox[
      RowBox[{"3", 
       SuperscriptBox["r", "5"]}], 
      SuperscriptBox["RStar", "5"]], "-", 
     FractionBox[
      RowBox[{"3", 
       SuperscriptBox["r", "4"]}], 
      RowBox[{"2", 
       SuperscriptBox["RStar", "4"]}]], "+", 
     FractionBox[
      SuperscriptBox["r", "3"], 
      RowBox[{"3", 
       SuperscriptBox["RStar", "3"]}]]}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.982996625963976*^9, 3.982996632044077*^9}},
