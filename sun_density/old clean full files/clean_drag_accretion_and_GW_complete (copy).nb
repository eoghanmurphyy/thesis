Cell[BoxData[
 RowBox[{
  RowBox[{"hplusOutside", "[", 
   RowBox[{
   "d_", ",", " ", "m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", 
    "uphi_", ",", " ", "phi_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarFull", "[", "rbar", "]"}]}], ",", " ", "rd", ",", " ", 
      "phid"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rd", " ", "=", " ", 
      RowBox[{"drBardt", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", " ", "=", " ", 
      RowBox[{"dphidtOutside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], "m"}], "d"], ")"}], 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{"M", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "phi"}], "]"}]}], "r"], " ", "-", " ", 
        RowBox[{
         SuperscriptBox["rd", "2"], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "phi"}], "]"}]}], " ", "+", " ", 
        RowBox[{"2", "rd", " ", "r", " ", "phid", " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"2", "phi"}], "]"}]}], " ", "+", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"r", " ", "phid"}], ")"}], "2"], 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "phi"}], "]"}]}]}], ")"}]}]}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
