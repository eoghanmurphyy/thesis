            RowBox[{"(", 
             RowBox[{"3", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"r", " ", "phid"}], ")"}], "^", "4"}]}], ")"}]}], "+", 
           RowBox[{
            RowBox[{"rd", "^", "2"}], " ", 
