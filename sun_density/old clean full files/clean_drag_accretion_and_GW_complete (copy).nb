Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtOutside", "[", 
   RowBox[{"m_", ",", "rbar_", ",", "ur_", ",", "uphi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"rofrbarFull", "[", "rbar", "]"}]}], ",", "rd", ",", "phid"}], 
     "}"}], ",", 
    RowBox[{
     RowBox[{"rd", "=", 
      RowBox[{"drBardt", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", "=", 
      RowBox[{"dphidtOutside", "[", 
