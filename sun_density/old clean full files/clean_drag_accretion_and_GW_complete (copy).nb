 CellLabel->"In[59]:=",ExpressionUUID->"07adca82-3b0e-4905-891b-d24a2a15e370"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DERalpha", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"drbardr", "[", "r", "]"}], "  ", 
   RowBox[{"DER\[Alpha]Outsiderbar", "[", "r", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Chain", " ", "rule"}], "*)"}]}]}]], "Input",
