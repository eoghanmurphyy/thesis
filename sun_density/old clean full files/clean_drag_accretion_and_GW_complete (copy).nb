Cell[BoxData[
 RowBox[{
  RowBox[{"hxInside", "[", 
   RowBox[{
   "d_", ",", " ", "m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", 
    "uphi_", ",", " ", "phi_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarFull", "[", "rbar", "]"}]}], ",", " ", "rd", ",", " ", 
      "phid"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rd", " ", "=", " ", 
      RowBox[{"drBardtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", " ", "=", " ", 
      RowBox[{"dphidtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], "m"}], "d"], ")"}], 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{
          RowBox[{"MassFunc", "[", "r", "]"}], " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"2", " ", "phi"}], "]"}]}], "r"], " ", "-", " ", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"rd", " ", 
            RowBox[{"Sin", "[", "phi", "]"}]}], " ", "+", " ", 
           RowBox[{"r", " ", "phid", " ", 
            RowBox[{"Cos", "[", "phi", "]"}]}]}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"rd", " ", 
            RowBox[{"Cos", "[", "phi", "]"}]}], " ", "-", " ", 
           RowBox[{"r", " ", "phid", " ", 
            RowBox[{"Sin", "[", "phi", "]"}]}]}], ")"}]}]}], ")"}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.982910496536334*^9, 3.9829104975922327`*^9}, {
  3.982910563943831*^9, 3.982910635559394*^9}},
