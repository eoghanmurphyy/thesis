            RowBox[{
             RowBox[{"(", 
              RowBox[{"r", " ", "phid"}], ")"}], "^", "2"}]}]}], ")"}]}], "+", 
        RowBox[{"r", " ", "M", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"6", " ", 
            RowBox[{"rd", "^", "4"}]}], "-", 
