Cell[CellGroupData[{

Cell["Instantaneous energy loss (coordinate system dependent)", "Subsection",
 CellChangeTimes->{{3.98290861036561*^9, 
  3.982908637213344*^9}},ExpressionUUID->"5594f9f0-6e85-4ae6-a834-\
eab006daefa3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dEdtInside", "[", 
   RowBox[{"m_", ",", "rbar_", ",", "ur_", ",", "uphi_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", "=", 
       RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], ",", "rd", ",", 
      "phid"}], "}"}], ",", 
    RowBox[{
     RowBox[{"rd", "=", 
      RowBox[{"drBardtInside", "[", 
