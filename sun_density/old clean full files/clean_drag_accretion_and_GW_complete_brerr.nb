Cell[BoxData[
 RowBox[{
  RowBox[{"hplusInside", "[", 
   RowBox[{
   "d_", ",", " ", "m_", ",", " ", "rbar_", ",", " ", "ur_", ",", " ", 
    "uphi_", ",", " ", "phi_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], ",", " ", "rd", ",", 
      " ", "phid"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"rd", " ", "=", " ", 
      RowBox[{"drBardtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"phid", " ", "=", " ", 
      RowBox[{"dphidtInside", "[", 
       RowBox[{"rbar", ",", "ur", ",", "uphi"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], "m"}], "d"], ")"}], 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         RowBox[{
          RowBox[{"MassFunc", "[", "r", "]"}], " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "phi"}], "]"}]}], "r"], " ", "-", " ", 
        RowBox[{
         SuperscriptBox["rd", "2"], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "phi"}], "]"}]}], " ", "+", " ", 
        RowBox[{"2", "rd", " ", "r", " ", "phid", " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"2", "phi"}], "]"}]}], " ", "+", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"r", " ", "phid"}], ")"}], "2"], 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "phi"}], "]"}]}]}], ")"}]}]}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 CellChangeTimes->{{3.982909649686586*^9, 3.9829097224854193`*^9}, {
  3.9829098243086843`*^9, 3.9829098245564327`*^9}, {3.982909873660438*^9, 
