Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"DER\[Alpha]Outside", "[", "rbar_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"r", " ", "=", " ", 
       RowBox[{"rofrbarOutside", "[", "rbar", "]"}]}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"drbardr", "[", "r", "]"}], "  ", 
      RowBox[{"DER\[Alpha]Outsiderbar", "[", "r", "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DER\[Alpha]Inside", "[", "rbar_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", " ", "=", " ", 
      RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
