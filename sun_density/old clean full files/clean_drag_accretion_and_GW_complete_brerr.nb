Cell[BoxData[
 RowBox[{
  RowBox[{"asosPiecewise", "[", 
   RowBox[{"rbar_", "?", "NumericQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], "}"}], ",", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"dPdr", "[", 
            RowBox[{"r", ",", 
             RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], "/", 
           RowBox[{"drhodr", "[", "r", "]"}]}], "]"}], ",", 
         RowBox[{"rbar", "<", "cutoffIso"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"asosEnd", "[", "rbar", "]"}], ",", 
         RowBox[{"cutoffIso", "<=", "rbar", "<=", "rbarStar"}]}], "}"}]}], 
      "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
