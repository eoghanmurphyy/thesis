   3.9823915790869703`*^9}, {3.982404709363402*^9, 3.9824047098352737`*^9}, {
   3.982556501089521*^9, 3.982556502833229*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"12df92a2-2e1f-449f-87a5-f63bd0a458e4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Phi", " ", "differential", " ", "equation", " ", "for", " ", "metric"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"(", 
     FractionBox[
      RowBox[{
       RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
       RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
        SuperscriptBox["r", "3"]}]}], 
      RowBox[{"r", 
       RowBox[{"(", 
        RowBox[{"r", "-", 
         RowBox[{"2", 
          RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.982122270771688*^9, 3.982122347371161*^9}, 
   3.982391602103158*^9, {3.9825565041772747`*^9, 3.982556505897291*^9}, 
   3.9825566470569277`*^9},
 CellLabel->"In[14]:=",ExpressionUUID->"16fc508b-83cc-44fd-8caa-34e7955c55cc"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Numerically integrating these coupled ODEs", \
"Subsection"]], "Subsubsection",
 CellChangeTimes->{{3.982122414666267*^9, 3.982122461514476*^9}, {
  3.982124096429223*^9, 3.982124100636909*^9}, {3.982817795476213*^9, 
  3.982817823068244*^9}},ExpressionUUID->"83a3fc05-26f4-48f4-bc08-\
afcf248d88b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rmin", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "6"}]]}], " ", 
  RowBox[{"(*", 
   RowBox[{"For", " ", "these", " ", "integrations"}], "*)"}], ";"}]], "Input",\

 CellChangeTimes->{{3.982124889135005*^9, 3.982124904695006*^9}, {
   3.9822966879901857`*^9, 3.982296688061829*^9}, 3.983716088595092*^9},
 CellLabel->"In[15]:=",ExpressionUUID->"213df192-ab7f-4a84-a52b-d93b1d63f9d1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq1", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"P", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPdr", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq2", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Phi", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BCs", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"P", "[", "RStar", "]"}], " ", "==", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"Phi", "[", "RStar", "]"}], " ", "==", " ", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], "]"}]}]}]}], "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Phi", "[", "RStar", "]"}], " ", "from", " ", "the", " ", 
    "Schwarzschild", " ", "metric"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982122468706362*^9, 3.9821225498339243`*^9}, {
  3.982123843807171*^9, 3.982123907678915*^9}, {3.9823916180786943`*^9, 
  3.982391618438609*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"7b8d8367-53bf-41c1-9952-3066776a590d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"sol1", " ", "=", " ", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "eq1", ",", "\[IndentingNewLine]", "eq2", ",", "\[IndentingNewLine]", 
         "BCs"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"P", ",", " ", "Phi"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "RStar", ",", " ", "rmin"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"WorkingPrecision", "->", "20"}]}], "\[IndentingNewLine]", 
      "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Very", " ", "small", " ", "rmin", " ", "to", " ", "avoid", " ", 
    "singularity", " ", "sarp", " ", "mentioned"}], "*)"}]}]], "Input",
