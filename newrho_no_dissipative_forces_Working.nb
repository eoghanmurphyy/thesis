Cell[CellGroupData[{

Cell["\<\
Putting this together to find the new interior metric functions\
\>", "Subsection",
 CellChangeTimes->{{3.98212643045017*^9, 3.9821264399862757`*^9}, {
  3.982126650232746*^9, 
  3.982126652400714*^9}},ExpressionUUID->"c3bcc7d4-f571-4a40-b6cf-\
318cb28f5ce3"],

Cell[CellGroupData[{

Cell["finding alpha in terms of normal r first", "Subsubsection",
 CellChangeTimes->{{3.9823934116154003`*^9, 
  3.982393419471624*^9}},ExpressionUUID->"558a2ee0-5156-49d7-8b1b-\
18602978d726"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dPhidrMetric", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"(", 
   FractionBox[
    RowBox[{
     RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
     RowBox[{"4", " ", "Pi", " ", 
      RowBox[{"Pressure", "[", "r", "]"}], " ", 
      SuperscriptBox["r", "3"]}]}], 
    RowBox[{"r", 
     RowBox[{"(", 
      RowBox[{"r", "-", 
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}]], "Input",
 CellChangeTimes->{{3.982393502718885*^9, 3.9823935097345247`*^9}, {
  3.982399278079626*^9, 3.982399279215176*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"515f1ef7-7469-42e0-aee7-ee3412433acc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"alpha", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"Exp", "[", 
   RowBox[{"PhiMetric", "[", "r", "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DERalphaIns", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"dPhidrMetric", "[", "r", "]"}], " ", 
   RowBox[{"alpha", "[", "r", "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.982393421464878*^9, 3.982393486503831*^9}, {
  3.982393520726775*^9, 3.982393525326456*^9}, {3.982393731557509*^9, 
  3.982393731861285*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"56ff7bf8-857a-4103-8844-e47b229c404c"],

Cell["Exterior alpha derivative", "Text",
 CellChangeTimes->{{3.982393538336166*^9, 
  3.982393542438478*^9}},ExpressionUUID->"e4045bc6-6dfd-495e-a2cd-\
ae5aba47049d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DER\[Alpha]Outsiderbardummy", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Derivative", "[", "1", "]"}], "[", "\[Alpha]", "]"}], "[", 
    "rbar", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"DER\[Alpha]Outsiderbar", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      FractionBox[
       RowBox[{"1", "-", 
        FractionBox["1", 
         RowBox[{"2", " ", "rbar"}]]}], 
       RowBox[{"2", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "+", 
           FractionBox["1", 
            RowBox[{"2", " ", "rbar"}]]}], ")"}], "2"], " ", 
        SuperscriptBox["rbar", "2"]}]], "+", 
      FractionBox["1", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          FractionBox["1", 
           RowBox[{"2", " ", "rbar"}]]}], ")"}], " ", 
        SuperscriptBox["rbar", "2"]}]]}], " ", ")"}], "/.", " ", 
    RowBox[{"rbar", " ", "->", " ", 
     RowBox[{"rbarofrOutside", "[", "r", "]"}]}]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "More", " ", "accurate", " ", "subbing", " ", "in", " ", "after", " ", 
    "for", " ", "rbar", " ", 
    RowBox[{"maybe", "?"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"drbardr", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{
   FractionBox[
    RowBox[{"rbarofrOutside", "[", "r", "]"}], "r"], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", " ", "-", " ", 
      FractionBox[
       RowBox[{"2", 
        RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
    RowBox[{"-", 
     FractionBox["1", "2"]}]]}]}]}], "Input",
 CellChangeTimes->{{3.982393741125156*^9, 3.9823937448050137`*^9}, {
  3.982393806669126*^9, 3.982393871731821*^9}, {3.982398059609561*^9, 
