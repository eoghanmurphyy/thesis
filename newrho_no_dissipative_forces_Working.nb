Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"(*", 
   RowBox[{
   "Evaluates", " ", "ok", " ", "at", " ", "zero", " ", "as", " ", "sapr", " ",
     "mentioned", " ", "but", " ", "integral", " ", 
    RowBox[{"doesn", "'"}], "t", " ", "like", " ", "it", " ", "one", " ", 
    "bit"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.982125950494925*^9, 3.982125966510107*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"d6c3b0fe-886c-4aef-a032-f82335edee9b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Inverse", " ", "Interpolation"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"rofrbarInside", " ", "=", " ", 
    RowBox[{"Interpolation", "[", "data", "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Builds", " ", "a", " ", "function", " ", "from", " ", "the", " ", "data",
      " ", "passing", " ", "through", " ", "all", " ", "points", " ", 
     "unlike", " ", "Fit", " ", "which", " ", "approximately", " ", "matches",
      " ", "the", " ", "data", " ", "to", " ", "a", " ", "function", " ", "I",
      " ", "give", " ", "it", " ", "with", " ", "parameters"}], ",", "  ", 
    RowBox[{
    "FindFit", " ", "finds", " ", "the", " ", "parameters", " ", "for", " ", 
     "me", " ", "given", " ", "I", " ", "guess", " ", "a", " ", "suitable", " ",
      "function"}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.9821259732469397`*^9, 3.982126030638027*^9}, {
  3.9821262064686623`*^9, 3.98212623222003*^9}, {3.9821263055473022`*^9, 
