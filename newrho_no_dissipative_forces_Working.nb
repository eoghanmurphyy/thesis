Cell[CellGroupData[{

Cell["Getting new equations for the new interior metric:", "Subsection",
 CellChangeTimes->{{3.980759833065682*^9, 3.980759839256179*^9}, {
  3.982122248004889*^9, 3.982122264995124*^9}, {3.982126398426784*^9, 
  3.982126413874289*^9}},ExpressionUUID->"e582958d-dac6-487a-9e68-\
b4681244c6e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"TOV", " ", "differential", " ", "equation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPdr", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rho", "[", "r", "]"}], " ", "+", " ", "Pressure"}], ")"}]}], 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
         RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
          SuperscriptBox["r", "3"]}]}], 
        RowBox[{"r", 
         RowBox[{"(", 
          RowBox[{"r", "-", 
           RowBox[{"2", 
            RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}], 
     "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.9807601294062366`*^9, 3.98076013474163*^9}, {
   3.980760167277755*^9, 3.980760297804946*^9}, {3.98076131275782*^9, 
   3.980761317285252*^9}, {3.980761630595008*^9, 3.980761651114334*^9}, {
   3.981015108916844*^9, 3.9810151437874613`*^9}, {3.981015203498157*^9, 
   3.981015209182917*^9}, 3.9816058987047577`*^9, {3.982122185731833*^9, 
   3.982122238987522*^9}, {3.9821222783397818`*^9, 3.982122281595154*^9}, {
   3.982391355256955*^9, 3.982391409128538*^9}, {3.98239155213509*^9, 
   3.9823915790869703`*^9}, {3.982404709363402*^9, 3.9824047098352737`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"12df92a2-2e1f-449f-87a5-f63bd0a458e4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Phi", " ", "differential", " ", "equation", " ", "for", " ", "metric"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Simplify", "[", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
        RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
         SuperscriptBox["r", "3"]}]}], 
       RowBox[{"r", 
        RowBox[{"(", 
         RowBox[{"r", "-", 
          RowBox[{"2", 
           RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.982122270771688*^9, 3.982122347371161*^9}, 
   3.982391602103158*^9},
 CellLabel->"In[15]:=",ExpressionUUID->"16fc508b-83cc-44fd-8caa-34e7955c55cc"],

Cell[CellGroupData[{

Cell["\<\
Numerically Integrate these two partially coupled differential equations\
\>", "Subsubsection",
 CellChangeTimes->{{3.982122414666267*^9, 3.982122461514476*^9}, {
  3.982124096429223*^9, 
  3.982124100636909*^9}},ExpressionUUID->"83a3fc05-26f4-48f4-bc08-\
afcf248d88b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rmin", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "16"}]]}], " ", 
  RowBox[{"(*", 
   RowBox[{"For", " ", "these", " ", "integrations"}], "*)"}], ";"}]], "Input",\

 CellChangeTimes->{{3.982124889135005*^9, 3.982124904695006*^9}, {
  3.9822966879901857`*^9, 3.982296688061829*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"213df192-ab7f-4a84-a52b-d93b1d63f9d1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq1", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"P", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPdr", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq2", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Phi", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BCs", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"P", "[", "RStar", "]"}], " ", "==", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"Phi", "[", "RStar", "]"}], " ", "==", " ", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], "]"}]}]}]}], "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Phi", "[", "RStar", "]"}], " ", "from", " ", "the", " ", 
    "Schwarzschild", " ", "metric"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982122468706362*^9, 3.9821225498339243`*^9}, {
  3.982123843807171*^9, 3.982123907678915*^9}, {3.9823916180786943`*^9, 
  3.982391618438609*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"7b8d8367-53bf-41c1-9952-3066776a590d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"sol1", " ", "=", " ", 
    RowBox[{
     RowBox[{"NDSolve", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "eq1", ",", "\[IndentingNewLine]", "eq2", ",", "\[IndentingNewLine]", 
         "BCs"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"P", ",", " ", "Phi"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"r", ",", " ", "RStar", ",", " ", "rmin"}], "}"}]}], 
      "\[IndentingNewLine]", "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Very", " ", "small", " ", "rmin", " ", "to", " ", "avoid", " ", 
    "singularity", " ", "sarp", " ", "mentioned"}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.980761191230756*^9, 3.9807611984861517`*^9}, {
   3.9807612617574863`*^9, 3.98076139206083*^9}, {3.980761732033964*^9, 
   3.980761769297784*^9}, {3.981014861929912*^9, 3.981014872213565*^9}, {
   3.9810150273676367`*^9, 3.98101502770056*^9}, {3.9810152450375032`*^9, 
   3.981015247055459*^9}, {3.9816059117211533`*^9, 3.9816059167241*^9}, {
   3.9821239237825747`*^9, 3.9821240381976213`*^9}, 3.982124633089094*^9, {
   3.982124910686879*^9, 3.9821249110625467`*^9}, {3.982124989758234*^9, 
   3.982125002366246*^9}, 3.982296707198036*^9, {3.9823909975958157`*^9, 
   3.982391001731625*^9}, {3.982391620670397*^9, 3.982391621054566*^9}, 
   3.9824047356589823`*^9},
 CellLabel->"In[20]:=",ExpressionUUID->"404238f2-0b25-414e-8dee-8556b9a1809d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Pressure", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"P", "[", "r", "]"}], " ", "/.", " ", "sol1"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
