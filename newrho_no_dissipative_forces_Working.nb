Cell[CellGroupData[{

Cell[TextData[{
 "Solving for the new ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["r", "_"], TraditionalForm]],ExpressionUUID->
  "8bcac07a-5e67-4f4b-8c61-795c9b60472b"],
 "(r) and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", 
    OverscriptBox["r", "_"], ")"}], TraditionalForm]],ExpressionUUID->
  "5e20a1ad-08e2-4e60-98a6-116d2b3b8699"],
 " inside, obtaining ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "(", 
    OverscriptBox["r", "_"]}], TraditionalForm]],ExpressionUUID->
  "6bb94468-d81f-4084-b344-5d21705ad02c"],
 ") via the interpolation trick Sarp explained"
}], "Subsubsection",
 CellChangeTimes->{{3.9821241092691*^9, 3.982124151653302*^9}, {
  3.982124203125842*^9, 
  3.982124221268506*^9}},ExpressionUUID->"70037c0d-c0dd-43c3-9542-\
4665bc223b37"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Defining", " ", "the", " ", "ODE"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"drbardr", "[", 
    RowBox[{"rbar_", ",", " ", "r_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    FractionBox["rbar", "r"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       FractionBox[
        RowBox[{"2", 
         RowBox[{"MassFunc", "[", "r", "]"}]}], "r"]}], ")"}], 
     RowBox[{"-", 
      FractionBox["1", "2"]}]]}]}]}]], "Input",
 CellChangeTimes->{{3.982124161189411*^9, 3.98212418850879*^9}, {
   3.982124241267745*^9, 3.9821242702282133`*^9}, {3.982124302635882*^9, 
   3.982124346387186*^9}, 3.982124382595275*^9, {3.982124431866364*^9, 
   3.982124441298533*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"a29dec26-d9a8-4798-af01-02e21511adde"],

