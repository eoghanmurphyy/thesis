Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"asos", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", "\[IndentingNewLine]", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"dPdr", "[", 
            RowBox[{"r", ",", " ", 
             RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], 
           RowBox[{"drhodr", "[", "r", "]"}]], ")"}], 
         FractionBox["1", "2"]], ",", " ", 
        RowBox[{"r", " ", "<", "cutoff"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          FractionBox[
           RowBox[{"M", 
            RowBox[{"(", 
             RowBox[{"RStar", "-", "r"}], ")"}]}], 
           RowBox[{"6", "RStar", 
            RowBox[{"(", 
             RowBox[{"RStar", "-", 
              RowBox[{"2", "M"}]}], ")"}]}]], ")"}], 
         FractionBox["1", "2"]], ",", " ", 
        RowBox[{"r", " ", ">=", " ", "cutoff"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
