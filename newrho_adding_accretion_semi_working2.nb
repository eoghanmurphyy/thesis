Cell[BoxData[
 RowBox[{
  RowBox[{"dPhidrMetric", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"(", 
   FractionBox[
    RowBox[{
     RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
