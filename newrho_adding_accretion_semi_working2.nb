     " ", 
    FractionBox[
     RowBox[{
      RowBox[{"(", "ptilde", ")"}], "*", "Mass"}], 
     RowBox[{"1", " ", "-", " ", "eccen"}]]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "In", " ", "Schwarzschild", " ", "areal", " ", "r", " ", "coordinates"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rperiapsis", "[", 
    RowBox[{"eccen_", ",", " ", "ptilde_"}], "]"}], " ", ":=", " ", 
   FractionBox["ptilde", 
    RowBox[{"1", "+", "eccen"}]]}], ";"}]}], "Input",
