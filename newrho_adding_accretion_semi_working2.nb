 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Getting", " ", "the", " ", "derivative", " ", "of", " ", "the", " ", 
    "density"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"rhodummy", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{"rho0", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        FractionBox["r", "RStar"]}], ")"}], "6"]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rhodummy", "'"}], "[", "r", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"drhodr", "[", "r_", "]"}], " ", ":=", " ", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"-", "6"}], " ", "rho0"}], "RStar"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", 
        FractionBox["r", "RStar"]}], ")"}], "5"]}]}]}]}]], "Input",
