Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Phi", " ", "differential", " ", "equation", " ", "for", " ", "metric"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"(", 
     FractionBox[
      RowBox[{
       RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
