Cell[BoxData[
 RowBox[{
  RowBox[{"asosPiecewise", "[", 
   RowBox[{"rbar_", "?", "NumericQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"rofrbarInside", "[", "rbar", "]"}]}], "}"}], ",", 
    RowBox[{"Piecewise", "[", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "@", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"dPdr", "[", 
             RowBox[{"r", ",", 
              RowBox[{"Pressure", "[", "r", "]"}]}], "]"}], "/", 
            RowBox[{"drhodr", "[", "r", "]"}]}], "]"}]}], ",", 
         RowBox[{"rbar", "<", "cutoffIso"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "@", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"M", " ", 
              RowBox[{"(", 
               RowBox[{"RStar", "-", "r"}], ")"}]}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"6", " ", "RStar", " ", 
              RowBox[{"(", 
               RowBox[{"RStar", "-", 
                RowBox[{"2", " ", "M"}]}], ")"}]}], ")"}]}], "]"}]}], ",", 
         RowBox[{"cutoffIso", "<=", "rbar", "<", "rbarStar"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         SuperscriptBox["10", 
          RowBox[{"-", "6"}]], ",", " ", 
         RowBox[{"rbar", " ", ">=", " ", "rbarStar"}]}], "}"}]}], 
      "\[IndentingNewLine]", "}"}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.9825581013337317`*^9, 3.982558162686511*^9}, {
   3.982558240902266*^9, 3.982558250364765*^9}, {3.9825589782951307`*^9, 
