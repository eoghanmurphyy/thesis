 CellLabel->"In[14]:=",ExpressionUUID->"16fc508b-83cc-44fd-8caa-34e7955c55cc"],

Cell[CellGroupData[{

Cell["\<\
Numerically Integrate these two partially coupled differential equations\
\>", "Subsubsection",
 CellChangeTimes->{{3.982122414666267*^9, 3.982122461514476*^9}, {
  3.982124096429223*^9, 
  3.982124100636909*^9}},ExpressionUUID->"83a3fc05-26f4-48f4-bc08-\
afcf248d88b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rmin", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "16"}]]}], " ", 
  RowBox[{"(*", 
   RowBox[{"For", " ", "these", " ", "integrations"}], "*)"}], ";"}]], "Input",\

 CellChangeTimes->{{3.982124889135005*^9, 3.982124904695006*^9}, {
  3.9822966879901857`*^9, 3.982296688061829*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"213df192-ab7f-4a84-a52b-d93b1d63f9d1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq1", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"P", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPdr", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq2", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Phi", "'"}], "[", "r", "]"}], " ", "==", " ", 
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r", ",", " ", 
      RowBox[{"P", "[", "r", "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BCs", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"P", "[", "RStar", "]"}], " ", "==", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"Phi", "[", "RStar", "]"}], " ", "==", " ", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
          RowBox[{"2", 
           FractionBox["M", "RStar"]}]}], "]"}]}]}]}], "}"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Phi", "[", "RStar", "]"}], " ", "from", " ", "the", " ", 
    "Schwarzschild", " ", "metric"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982122468706362*^9, 3.9821225498339243`*^9}, {
  3.982123843807171*^9, 3.982123907678915*^9}, {3.9823916180786943`*^9, 
  3.982391618438609*^9}},
