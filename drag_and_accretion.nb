   RowBox[{"rho", "[", "r_", "]"}], " ", ":=", " ", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rho0", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            FractionBox["r", "RStar"]}], ")"}], "6"]}], ",", " ", 
        RowBox[{"r", " ", "<", " ", "RStar"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{"r", " ", ">=", " ", "RStar"}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9807577923623877`*^9, 3.98075785617692*^9}, {
   3.9807579037758617`*^9, 3.980758119918268*^9}, {3.980759150141821*^9, 
