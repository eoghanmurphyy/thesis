Cell[CellGroupData[{

Cell["Getting new equations for the new interior metric:", "Subsection",
 CellChangeTimes->{{3.980759833065682*^9, 3.980759839256179*^9}, {
  3.982122248004889*^9, 3.982122264995124*^9}, {3.982126398426784*^9, 
  3.982126413874289*^9}},ExpressionUUID->"e582958d-dac6-487a-9e68-\
b4681244c6e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"TOV", " ", "differential", " ", "equation"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPdr", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"rho", "[", "r", "]"}], " ", "+", " ", "Pressure"}], ")"}]}], 
     
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
        RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
         SuperscriptBox["r", "3"]}]}], 
       RowBox[{"r", 
        RowBox[{"(", 
         RowBox[{"r", "-", 
          RowBox[{"2", 
           RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.9807601294062366`*^9, 3.98076013474163*^9}, {
   3.980760167277755*^9, 3.980760297804946*^9}, {3.98076131275782*^9, 
   3.980761317285252*^9}, {3.980761630595008*^9, 3.980761651114334*^9}, {
   3.981015108916844*^9, 3.9810151437874613`*^9}, {3.981015203498157*^9, 
   3.981015209182917*^9}, 3.9816058987047577`*^9, {3.982122185731833*^9, 
   3.982122238987522*^9}, {3.9821222783397818`*^9, 3.982122281595154*^9}, {
   3.982391355256955*^9, 3.982391409128538*^9}, {3.98239155213509*^9, 
   3.9823915790869703`*^9}, {3.982404709363402*^9, 3.9824047098352737`*^9}, {
   3.982556501089521*^9, 3.982556502833229*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"12df92a2-2e1f-449f-87a5-f63bd0a458e4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Phi", " ", "differential", " ", "equation", " ", "for", " ", "metric"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"dPhidrMetric", "[", 
     RowBox[{"r_", ",", " ", "Pressure_"}], "]"}], " ", ":=", " ", 
    RowBox[{"(", 
     FractionBox[
      RowBox[{
       RowBox[{"MassFunc", "[", "r", "]"}], " ", "+", " ", 
       RowBox[{"4", " ", "Pi", " ", "Pressure", " ", 
        SuperscriptBox["r", "3"]}]}], 
      RowBox[{"r", 
       RowBox[{"(", 
        RowBox[{"r", "-", 
         RowBox[{"2", 
          RowBox[{"MassFunc", "[", "r", "]"}]}]}], ")"}]}]], ")"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.982122270771688*^9, 3.982122347371161*^9}, 
   3.982391602103158*^9, {3.9825565041772747`*^9, 3.982556505897291*^9}, 
