  RowBox[{
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"R", "^", "3"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "*", "M"}], ")"}]}], "]"}], " ", "*", " ", 
   RowBox[{
    RowBox[{"Sech", "[", 
