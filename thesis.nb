    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"M", "/", "2"}], "R"}]}], ")"}], "^", "2"}], " ", "==", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"A", "[", "R", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lhs", " ", "=", " ", 
