Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"M", "/", "2"}], "R"}]}], ")"}], "^", "2"}], " ", "==", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"A", "[", "R", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lhs", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"M", "/", "2"}], "R"}]}], ")"}], "^", "2"}], " ", "*", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", "*", 
       RowBox[{"M", "/", "R"}]}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"solC", " ", "=", " ", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"lhs", " ", "==", " ", 
     RowBox[{"Sech", "[", 
      RowBox[{"C", " ", "+", " ", 
       RowBox[{"Log", "[", "R", "]"}]}], "]"}]}], ",", " ", "C", ",", " ", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", ">", "0"}], ",", " ", 
       RowBox[{"R", ">", "0"}]}], "}"}]}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Not", " ", "giving", " ", "what", " ", "said", " ", "it", " ", "should", " ",
     "be"}], "*)"}]}]}], "Code",
