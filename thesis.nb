Cell["\<\
Must fix C_1 such that the conformal factors match at the surface of the star.\
\>", "Text",
 CellChangeTimes->{{3.97723766583368*^9, 
  3.977237688105832*^9}},ExpressionUUID->"aa9ecf2f-135a-49a7-9182-\
78613990a41e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"M", "/", "2"}], "R"}]}], ")"}], "^", "2"}], " ", "==", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"A", "[", "R", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lhs", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"M", "/", "2"}], "R"}]}], ")"}], "^", "2"}], " ", "*", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"2", "*", 
       RowBox[{"M", "/", "R"}]}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"solC", " ", "=", " ", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"lhs", " ", "==", " ", 
     RowBox[{"Sech", "[", 
      RowBox[{"C", " ", "+", " ", 
       RowBox[{"Log", "[", "R", "]"}]}], "]"}]}], ",", " ", "C", ",", " ", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", ">", "0"}], ",", " ", 
       RowBox[{"R", ">", "0"}]}], "}"}]}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Not", " ", "giving", " ", "what", " ", "gpt", " ", "said", " ", "it", " ",
     "should", " ", "be"}], "*)"}]}]}], "Code",
 CellChangeTimes->{{3.977237694521449*^9, 3.9772377300258827`*^9}, {
  3.977238336140316*^9, 3.977238337652833*^9}, {3.977238393899789*^9, 
  3.977238426924061*^9}, {3.977238518795156*^9, 3.977238524594818*^9}, {
  3.977238564522928*^9, 3.9772385754905453`*^9}, {3.97723901378284*^9, 
