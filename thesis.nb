  3.977228929970379*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"bb1b535e-1130-44ce-8977-297819fab36d"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{
    SuperscriptBox["r", "\[Prime]",
     MultilineFunction->None], "[", "rbar", "]"}], 
   RowBox[{
    SqrtBox[
     RowBox[{"1", "-", 
      FractionBox[
       RowBox[{"2", " ", "M"}], 
       RowBox[{"r", "[", "rbar", "]"}]]}]], " ", 
    RowBox[{"r", "[", "rbar", "]"}]}]], "\[Equal]", 
