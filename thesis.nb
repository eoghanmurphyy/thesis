     RowBox[{"3", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"M", "/", "R"}]}], "]"}]}], " ", "-", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{"2", "*", "M", "*", 
        RowBox[{
         RowBox[{"r", "^", "2"}], "/", 
         RowBox[{"R", "^", "3"}]}]}]}], "]"}]}], ")"}]}]}], "\n", 
 RowBox[{"FullSimplify", "[", "gtt", "]"}]}], "Code",
