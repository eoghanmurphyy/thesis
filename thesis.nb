Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ConformalC", " ", "=", " ", 
    RowBox[{
     RowBox[{"ArcSech", "[", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"2", "*", 
         RowBox[{"M", "/", "R"}]}], "]"}], " ", "*", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"MR", "/", "2"}]}], ")"}], "^", "2"}]}], "]"}], " ", "-", 
     " ", 
     RowBox[{"Log", "[", "R", "]"}]}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Constant", " ", "for", " ", "continuity", " ", "of", " ", "Conformal", " ",
     "Factor"}], "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"A", "[", "rbar_", "]"}], " ", ":=", " ", 
  RowBox[{
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"R", "^", "3"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "*", "M"}], ")"}]}], "]"}], " ", "*", " ", 
   RowBox[{
    RowBox[{"Sech", "[", 
     RowBox[{"ConformalC", " ", "+", " ", 
      RowBox[{"Log", "[", "rbar", "]"}]}], "]"}], "/", "rbar"}]}]}]}], "Code",\

 CellChangeTimes->{{3.977239349635818*^9, 3.977239405843945*^9}, {
  3.977239511114953*^9, 3.9772395292826767`*^9}, {3.9772395816106853`*^9, 
