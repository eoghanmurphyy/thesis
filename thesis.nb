Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"expr", " ", "=", " ", 
  RowBox[{
   RowBox[{"rbar", "[", "r", "]"}], " ", "/.", " ", 
   RowBox[{"sol", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", 
 RowBox[{
  RowBox[{"expr", " ", "/.", " ", 
   RowBox[{"r", " ", "->", " ", 
    RowBox[{"2", "M"}]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "OG", " ", "sln", " ", "for", " ", "isotropic", " ", "coords", " ", 
    "mustve", " ", "embedded", " ", "C_", "1", " ", "to", " ", "be", " ", 
    "equal", " ", "to", " ", 
