Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", "M", "]"}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Clears", " ", "the", " ", "way", " ", "the", " ", "variables", " ", 
