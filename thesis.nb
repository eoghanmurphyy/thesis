Cell["Radial In-fall:", "Section",
 CellChangeTimes->{{3.977227560903408*^9, 
  3.9772275647575903`*^9}},ExpressionUUID->"725a23e7-48d9-4135-9803-\
bdb19eed5480"],

Cell[TextData[{
 "Working from MTW I derived the radial in-fall equation.\nBelow I will solve \
it from an arbitrary start point outside the star and let it fall in \
measuring the proper time for an outside observer.\n\nObtained the Radial \
in-fall equation by using exterior Schwarzschild spacetime and can integrate \
this to obtain the invariant proper time of the in fall. \n\n",
 StyleBox["Eqn",
  IgnoreSpellCheck->True],
 " will look different in each interior and exterior spacetime, but when \
integrated between the same two events on the worldline we get the same tau.\n\
\nThis case is a black hole so its Schwarzschild all the way to r=0"
}], "Text",
 CellChangeTimes->{{3.977224852693708*^9, 3.977224885299108*^9}, {
  3.977224950898856*^9, 3.977224963890997*^9}, {3.977225372751251*^9, 
  3.977225413486718*^9}, {3.977225508054246*^9, 3.977225569517726*^9}, {
  3.977225720660852*^9, 
  3.9772257654684687`*^9}},ExpressionUUID->"76a0acd6-80ce-4710-96ac-\
e6bc3020b2db"],

Cell[CellGroupData[{

