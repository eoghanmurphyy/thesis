Cell["\<\
Plugging in r eqn into the gtt component of the TOV const density metric to \
get the isotropic interior metric\
\>", "Text",
 CellChangeTimes->{{3.977239852841674*^9, 
  3.977239890975032*^9}},ExpressionUUID->"8698acd5-fb1c-45ee-84c0-\
3da7d8f7b6c2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"r", " ", "=", " ", 
    RowBox[{"rbar", " ", "*", " ", 
     RowBox[{"A", "[", "rbar", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"gtt", " ", "=", " ", 
  RowBox[{
   RowBox[{"1", "/", "4"}], " ", "*", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"3", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"M", "/", "R"}]}], "]"}]}], " ", "-", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{"2", "*", "M", "*", 
        RowBox[{
         RowBox[{"r", "^", "2"}], "/", 
         RowBox[{"R", "^", "3"}]}]}]}], "]"}]}], ")"}]}]}], "\n", 
 RowBox[{"FullSimplify", "[", "gtt", "]"}]}], "Code",
 CellChangeTimes->{{3.977239894183687*^9, 3.977239895839514*^9}, {
  3.977239952159256*^9, 3.977239952455348*^9}, {3.977240028086632*^9, 
  3.977240160605732*^9}},
 CellLabel->
  "In[308]:=",ExpressionUUID->"d40abc15-6753-41ca-8d0b-779edca7692d"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"3", " ", 
     SqrtBox[
      RowBox[{"1", "-", 
       FractionBox["M", "R"]}]]}], "-", 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Sech", "[", 
        RowBox[{
         RowBox[{"ArcSech", "[", 
          RowBox[{
           SqrtBox["2"], " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"1", "+", 
              FractionBox["MR", "2"]}], ")"}], "2"], " ", 
           SqrtBox[
            FractionBox["M", "R"]]}], "]"}], "-", 
         RowBox[{"Log", "[", "R", "]"}], "+", 
         RowBox[{"Log", "[", "rbar", "]"}]}], "]"}], "2"]}]]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{{3.977240099425111*^9, 3.977240161250573*^9}, 
   3.9773263948519917`*^9, {3.977326475124772*^9, 3.977326500235898*^9}, {
   3.977326580142733*^9, 3.9773265859508333`*^9}},
 CellLabel->
  "Out[309]=",ExpressionUUID->"41f9d7e4-3dff-4ca9-9dc9-af4234595dd4"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"3", " ", 
     SqrtBox[
      RowBox[{"1", "-", 
       FractionBox["M", "R"]}]]}], "-", 
    SqrtBox[
     SuperscriptBox[
      RowBox[{"Tanh", "[", 
       RowBox[{
        RowBox[{"ArcCosh", "[", 
         FractionBox[
          RowBox[{"2", " ", 
           SqrtBox["2"]}], 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"2", "+", "MR"}], ")"}], "2"], " ", 
           SqrtBox[
            FractionBox["M", "R"]]}]], "]"}], "-", 
        RowBox[{"Log", "[", "R", "]"}], "+", 
        RowBox[{"Log", "[", "rbar", "]"}]}], "]"}], "2"]]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{{3.977240099425111*^9, 3.977240161250573*^9}, 
