Cell["Doing Radial Drop", "Text",
 CellChangeTimes->{{3.977326618995146*^9, 
  3.977326621851384*^9}},ExpressionUUID->"1e5dc324-bee5-44f8-be4e-\
b11676ba3194"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rbarinit", " ", "=", " ", "100"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Star", " ", "Radius", " ", "set", " ", "equal", " ", "to", " ", "10"}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"R", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Final", " ", "Singularity"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"M", " ", "=", " ", "100"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Let", " ", "Mass", " ", "of", " ", "black", " ", "hole", " ", "be", " ", 
    "equal", " ", "to", " ", "1"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Energy", " ", "=", " ", "10"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{"-", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Energy", "^", "2"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{
                RowBox[{"M", "/", "2"}], "*", "rbar"}]}], ")"}], "^", "4"}], 
            ")"}], "*", 
           RowBox[{"(", 
            RowBox[{"1", " ", "-", " ", 
             RowBox[{"8", "*", 
              RowBox[{"M", "/", 
               RowBox[{"(", 
                RowBox[{"rbar", "*", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"2", "+", 
                    RowBox[{"M", "*", "rbar"}]}], ")"}], "^", "2"}]}], 
                ")"}]}]}]}], ")"}]}], ")"}]}], ")"}]}], " ", "-", " ", 
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"M", "/", "2"}], "*", "rbar"}]}], ")"}], "^", "4"}], 
        ")"}]}]}], "]"}]}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"rdot", "[", "rbar_", "]"}], " ", ":=", " ", 
  RowBox[{"Sqrt", "[", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"E", "^", "2"}], "/", 
       RowBox[{"(", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"8", "*", 
          RowBox[{"M", "/", 
           RowBox[{"(", 
            RowBox[{"rbar", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"2", "+", 
                RowBox[{"M", "*", "rbar"}]}], ")"}], "^", "2"}]}], 
            ")"}]}]}]}], ")"}]}], ")"}]}], " ", "-", " ", 
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{
          RowBox[{"M", "/", "2"}], "*", "rbar"}]}], ")"}], "^", "4"}], 
      ")"}]}]}], "]"}]}]}], "Code",
 CellChangeTimes->{{3.977326630715125*^9, 3.977326791002338*^9}, 
   3.977326856417273*^9, {3.977327077727171*^9, 3.977327085679989*^9}, {
   3.9773271766072817`*^9, 3.977327177391295*^9}, {3.977327270861948*^9, 
   3.977327362397779*^9}, {3.977327433029295*^9, 3.977327518724144*^9}, 
