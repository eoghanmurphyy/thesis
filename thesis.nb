Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"R", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Starting", " ", "Radius", " ", "set", " ", "equal", " ", "to", " ", 
    "10"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rf", " ", "=", " ", "0"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Final", " ", "Singularity"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"M", " ", "=", " ", "1"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Let", " ", "Mass", " ", "of", " ", "black", " ", "hole", " ", "be", " ", 
    "equal", " ", "to", " ", "1"}], "*)"}], "\n"}], "\n", 
 RowBox[{"tauExpression", " ", "=", " ", 
  RowBox[{"Integrate", "[", "\n", "\t\t", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", " ", "M"}], "]"}]}], "*", 
