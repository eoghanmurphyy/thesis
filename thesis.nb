     "i", " ", "should", " ", "choose", " ", 
    RowBox[{"here", ".", "\n", "I"}], " ", "didnt", " ", "see", " ", "how", " ",
     "the", " ", "constant", " ", "was", " ", "picked", " ", "because", " ", 
    "I", " ", 
    RowBox[{"don", "'"}], "t", " ", "remember", " ", "deriving", " ", "it"}], 
   "*)"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Taking", " ", "limit", " ", "to", " ", "infinity", " ", "of", " ", 
    "rbar"}], "*)"}]}], "\n", 
 RowBox[{"N", "[", 
