  RowBox[{"rho", " ", "*", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Aconstant", "[", "r", "]"}], " ", "-", " ", "B"}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", "*", "B"}], " ", "-", " ", 
       RowBox[{"Aconstant", "[", "r", "]"}]}], ")"}]}], ")"}]}]}]}], "Code",
