     RowBox[{"(", ")"}], " ", "==", " ", 
     RowBox[{"normal", " ", "algebra"}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Aconstant", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"1", "-", 
    RowBox[{"2", "*", "M", "*", 
     RowBox[{
      RowBox[{"r", "^", "2"}], "/", 
      RowBox[{"R", "^", "3"}]}]}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"B", " ", "=", " ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"1", "-", 
      RowBox[{"2", "*", 
       RowBox[{"M", "/", "R"}]}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"P", "[", 
   RowBox[{"r_", ",", " ", "rho_"}], "]"}], " ", ":=", " ", 
  RowBox[{"rho", " ", "*", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Aconstant", "[", "r", "]"}], " ", "-", " ", "B"}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", "*", "B"}], " ", "-", " ", 
       RowBox[{"Aconstant", "[", "r", "]"}]}], ")"}]}], ")"}]}]}]}], "Code",
