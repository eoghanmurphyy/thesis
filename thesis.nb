Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Clear", " ", "all", " ", "variables", " ", "for", " ", "a", " ", "fresh", 
    " ", "start"}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"[", "]"}], " ", "==", " ", 
     RowBox[{"function", " ", "call"}]}], ",", " ", 
    RowBox[{
     RowBox[{"(", ")"}], " ", "==", " ", 
     RowBox[{"normal", " ", "algebra"}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Aconstant", "[", "r_", "]"}], " ", ":=", " ", 
  RowBox[{"Sqrt", "[", 
   RowBox[{"1", "-", 
    RowBox[{"2", "*", "M", "*", 
     RowBox[{
      RowBox[{"r", "^", "2"}], "/", 
      RowBox[{"R", "^", "3"}]}]}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"B", " ", "=", " ", 
