Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"Physical", " ", "Constants"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"G", " ", "=", " ", 
    RowBox[{"6.67430", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "11"}]}]}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"m", "^", "3"}], " ", "/", " ", "kg"}], " ", 
    RowBox[{"s", "^", "2"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"c", " ", "=", " ", "299792458"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"m", "/", "s"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Msol", " ", "=", " ", 
    RowBox[{"1.989", "*", 
     RowBox[{"10", "^", "30"}]}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"kg", ",", " ", 
    RowBox[{"mass", " ", "of", " ", "sun"}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Conversion", " ", "Function", " ", "to", " ", "seconds", " ", "from", " ",
     "geometric", " ", "units"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ToSeconds", "[", 
    RowBox[{"tauGeom_", ",", " ", "Mkg_"}], "]"}], " ", ":=", " ", 
   RowBox[{"tauGeom", " ", "*", " ", "G", " ", "*", " ", 
    RowBox[{"Mkg", " ", "/", " ", 
     RowBox[{"c", "^", "3"}]}]}]}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"tauGeom", " ", "=", " ", 
     RowBox[{
      RowBox[{"proper", " ", "time", " ", "in", " ", "G"}], "=", 
      RowBox[{"c", "=", "1"}]}]}], ",", " ", 
    RowBox[{"(", 
     RowBox[{"Geometric", " ", "Units"}], ")"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Mkg", " ", "=", " ", 
     RowBox[{
     "Mass", " ", "of", " ", "black", " ", "hole", " ", "in", " ", "kg"}]}], ",",
     " ", 
    RowBox[{
    "at", " ", "the", " ", "end", " ", "of", " ", "the", " ", "day", " ", 
     "to", " ", "convert", " ", "back"}], ",", "\n", 
    RowBox[{
    "I", " ", "must", " ", "know", " ", "this", " ", "to", " ", "get", " ", 
     "physical", " ", "measurements"}]}], "*)"}]}]}], "Code",
 CellChangeTimes->{{3.97722663559766*^9, 3.9772267364763603`*^9}, {
