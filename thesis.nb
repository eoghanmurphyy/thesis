Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"C", "\[Rule]", 
     TemplateBox[{
       RowBox[{
         RowBox[{"-", 
           RowBox[{"ArcCosh", "[", 
             FractionBox[
              RowBox[{"2", " ", 
