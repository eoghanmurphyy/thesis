  3.977239497219303*^9}, {3.977239598594392*^9, 3.977239599058322*^9}},
 CellLabel->
  "In[303]:=",ExpressionUUID->"dc7986da-457c-4411-a46e-4e62013da329"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"C", "\[Rule]", 
     TemplateBox[{
       RowBox[{
         RowBox[{"-", 
           RowBox[{"ArcCosh", "[", 
             FractionBox[
              RowBox[{"2", " ", 
                SqrtBox["2"], " ", 
                SqrtBox[
                 FractionBox["R", "M"]]}], 
              SuperscriptBox[
               RowBox[{"(", 
                 RowBox[{"2", "+", 
                   RowBox[{"M", " ", "R"}]}], ")"}], "2"]], "]"}]}], "+", 
         RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Pi]", " ", 
           TemplateBox[{"1"}, "C"]}], "-", 
         RowBox[{"Log", "[", "R", "]"}]}], 
