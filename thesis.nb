Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"R", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Starting", " ", "Radius", " ", "set", " ", "equal", " ", "to", " ", 
    "10"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rf", " ", "=", " ", "0"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Final", " ", "Singularity"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"M", " ", "=", " ", "1"}], ";"}], " ", 
