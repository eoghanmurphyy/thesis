Cell["\<\
Dsolve returns a list of rules so we need to get the RHS.
Then we take limits.\
\>", "Text",
 CellChangeTimes->{{3.977230322894691*^9, 3.9772303437507143`*^9}, {
  3.977230951905744*^9, 
  3.977230959377356*^9}},ExpressionUUID->"8f5f7a4a-a778-4f52-b011-\
8469e299946b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"expr", " ", "=", " ", 
  RowBox[{
   RowBox[{"rbar", "[", "r", "]"}], " ", "/.", " ", 
   RowBox[{"sol", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", 
 RowBox[{
  RowBox[{"expr", " ", "/.", " ", 
   RowBox[{"r", " ", "->", " ", 
    RowBox[{"2", "M"}]}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "OG", " ", "sln", " ", "for", " ", "isotropic", " ", "coords", " ", 
    "mustve", " ", "embedded", " ", "C_", "1", " ", "to", " ", "be", " ", 
    "equal", " ", "to", " ", 
    RowBox[{"M", "/", "2"}], " ", "so", " ", "this", " ", "is", " ", "what", " ",
     "i", " ", "should", " ", "choose", " ", 
    RowBox[{"here", ".", "\n", "I"}], " ", "didnt", " ", "see", " ", "how", " ",
     "the", " ", "constant", " ", "was", " ", "picked", " ", "because", " ", 
    "I", " ", 
    RowBox[{"don", "'"}], "t", " ", "remember", " ", "deriving", " ", "it"}], 
   "*)"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Taking", " ", "limit", " ", "to", " ", "infinity", " ", "of", " ", 
    "rbar"}], "*)"}]}], "\n", 
 RowBox[{"N", "[", 
  RowBox[{"Limit", "[", 
   RowBox[{"expr", ",", " ", 
    RowBox[{"r", "->", "Infinity"}], ",", " ", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"{", 
      RowBox[{"M", ">", "0"}], "}"}]}]}], "]"}], "]"}]}], "Code",
 CellChangeTimes->{{3.97722999987353*^9, 3.9772300039780416`*^9}, {
