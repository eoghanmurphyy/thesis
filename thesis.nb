Cell[CellGroupData[{

Cell["Radial In-fall:", "Section",
 CellChangeTimes->{{3.977227560903408*^9, 
  3.9772275647575903`*^9}},ExpressionUUID->"725a23e7-48d9-4135-9803-\
bdb19eed5480"],

Cell[TextData[{
 "Working from MTW I derived the radial in-fall equation.\nBelow I will solve \
it from an arbitrary start point outside the star and let it fall in \
measuring the proper time for an outside observer.\n\nObtained the Radial \
in-fall equation by using exterior Schwarzschild spacetime and can integrate \
this to obtain the invariant proper time of the in fall. \n\n",
 StyleBox["Eqn",
  IgnoreSpellCheck->True],
 " will look different in each interior and exterior spacetime, but when \
integrated between the same two events on the worldline we get the same tau.\n\
\nThis case is a black hole so its Schwarzschild all the way to r=0"
}], "Text",
 CellChangeTimes->{{3.977224852693708*^9, 3.977224885299108*^9}, {
  3.977224950898856*^9, 3.977224963890997*^9}, {3.977225372751251*^9, 
  3.977225413486718*^9}, {3.977225508054246*^9, 3.977225569517726*^9}, {
  3.977225720660852*^9, 
  3.9772257654684687`*^9}},ExpressionUUID->"76a0acd6-80ce-4710-96ac-\
e6bc3020b2db"],

Cell[CellGroupData[{

Cell["Calculating the time to drop into the stars centre", "Subsection",
 CellChangeTimes->{{3.9772248153082037`*^9, 
  3.977224826212274*^9}},ExpressionUUID->"f67da7d8-1c84-429e-92c6-\
9fde9bf96734"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Physical", " ", "Constants"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"G", " ", "=", " ", 
     RowBox[{"6.67430", "*", 
      RowBox[{"10", "^", 
       RowBox[{"-", "11"}]}]}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"m", "^", "3"}], " ", "/", " ", "kg"}], " ", 
     RowBox[{"s", "^", "2"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"c", " ", "=", " ", "299792458"}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"m", "/", "s"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Msol", " ", "=", " ", 
     RowBox[{"1.989", "*", 
      RowBox[{"10", "^", "30"}]}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"kg", ",", " ", 
     RowBox[{"mass", " ", "of", " ", "sun"}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Conversion", " ", "Function", " ", "to", " ", "seconds", " ", "from", " ",
      "geometric", " ", "units"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ToSeconds", "[", 
     RowBox[{"tauGeom_", ",", " ", "Mkg_"}], "]"}], " ", ":=", " ", 
    RowBox[{"tauGeom", " ", "*", " ", "G", " ", "*", " ", 
     RowBox[{"Mkg", " ", "/", " ", 
      RowBox[{"c", "^", "3"}]}]}]}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"tauGeom", " ", "=", " ", 
      RowBox[{
       RowBox[{"proper", " ", "time", " ", "in", " ", "G"}], "=", 
       RowBox[{"c", "=", "1"}]}]}], ",", " ", 
     RowBox[{"(", 
      RowBox[{"Geometric", " ", "Units"}], ")"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Mkg", " ", "=", " ", 
      RowBox[{
      "Mass", " ", "of", " ", "black", " ", "hole", " ", "in", " ", "kg"}]}], 
     ",", " ", 
     RowBox[{
     "at", " ", "the", " ", "end", " ", "of", " ", "the", " ", "day", " ", 
      "to", " ", "convert", " ", "back"}], ",", "\n", 
     RowBox[{
     "I", " ", "must", " ", "know", " ", "this", " ", "to", " ", "get", " ", 
      "physical", " ", "measurements"}]}], "*)"}]}]}]], "Code",
 CellChangeTimes->{{3.97722663559766*^9, 3.9772267364763603`*^9}, {
  3.977226894651422*^9, 3.977227007666299*^9}, {3.977227174904776*^9, 
  3.977227206768813*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"87f694e0-c2bd-4432-955e-39104994d2e8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"R", " ", "=", " ", "10"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Starting", " ", "Radius", " ", "set", " ", "equal", " ", "to", " ", 
    "10"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rf", " ", "=", " ", "0"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Final", " ", "Singularity"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"M", " ", "=", " ", "1"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Let", " ", "Mass", " ", "of", " ", "black", " ", "hole", " ", "be", " ", 
    "equal", " ", "to", " ", "1"}], "*)"}], "\n"}], "\n", 
 RowBox[{"tauExpression", " ", "=", " ", 
  RowBox[{"Integrate", "[", "\n", "\t\t", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", " ", "M"}], "]"}]}], "*", 
     RowBox[{"1", "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"1", "/", "r"}], " ", "-", " ", 
        RowBox[{"1", "/", "R"}]}], "]"}]}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"r", ",", " ", "R", ",", " ", "rf"}], "}"}]}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "*", "means", " ", "multiply", " ", "as", " ", "in", " ", "python"}], " ",
     "*)"}], "\n", "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "is", " ", "in", " ", "Geometric", " ", "units", " ", "with",
      " ", "G"}], "=", 
    RowBox[{"c", "=", "1"}]}], "*)"}]}]}], "Code",
 CellChangeTimes->{{3.977225789005287*^9, 3.977225912739325*^9}, {
  3.977225968515654*^9, 3.9772259700908537`*^9}, {3.977226001626923*^9, 
  3.977226057834217*^9}, {3.977226225112904*^9, 3.9772264066236887`*^9}, {
