12db174f5200"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", "M", "]"}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Clears", " ", "the", " ", "way", " ", "the", " ", "variables", " ", 
     "were", " ", "defined", " ", "beforehand"}], ",", " ", 
    RowBox[{
    "useful", " ", "for", " ", "me", " ", "when", " ", "doing", " ", 
     "integrals", " ", "where", " ", "I", " ", "would", " ", "like", " ", 
     "to", " ", "see", " ", "the", " ", "symbol"}]}], "*)"}]}], "\n", 
 RowBox[{"eq", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"2", "*", 
         RowBox[{"M", "/", 
          RowBox[{"r", "[", "rbar", "]"}]}]}]}], "]"}]}], ")"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"r", "'"}], "[", "rbar", "]"}], "/", 
      RowBox[{"r", "[", "rbar", "]"}]}], ")"}]}], " ", "==", " ", 
   RowBox[{"1", "/", "rbar"}]}]}]}], "Code",
 CellChangeTimes->{{3.9772281776401978`*^9, 3.977228192840535*^9}, {
  3.9772282587277927`*^9, 3.977228331607439*^9}, {3.977228554141788*^9, 
