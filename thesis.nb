     RowBox[{"A", "[", "rbar", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"gtt", " ", "=", " ", 
  RowBox[{
   RowBox[{"1", "/", "4"}], " ", "*", " ", 
   RowBox[{"(", 
