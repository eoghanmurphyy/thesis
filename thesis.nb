Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ConformalC", " ", "=", " ", 
    RowBox[{
     RowBox[{"ArcSech", "[", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"2", "*", 
         RowBox[{"M", "/", "R"}]}], "]"}], " ", "*", " ", 
       RowBox[{
