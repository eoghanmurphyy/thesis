Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"2", "*", 
          RowBox[{"M", "/", "r"}]}]}], "]"}]}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{"1", "/", "r"}], ")"}]}], " ", "==", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"rbar", "'"}], "[", "r", "]"}], "/", 
     RowBox[{"rbar", "[", "r", "]"}]}]}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"sol", " ", "=", " ", 
   RowBox[{"DSolve", "[", "\n", "\t\t", 
    RowBox[{"eq", ",", " ", 
     RowBox[{"(*", 
      RowBox[{"Equation", " ", "to", " ", "work", " ", "with"}], "*)"}], "\n",
      "\t\t", 
     RowBox[{"rbar", "[", "r", "]"}], ",", " ", 
     RowBox[{"(*", 
      RowBox[{"Function", " ", "to", " ", "solve", " ", "for"}], "*)"}], "\n",
      "\t\t", "r"}], " ", 
    RowBox[{"(*", 
     RowBox[{"Independent", " ", "Variable"}], "*)"}], "\n", "]"}]}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Coordinates", " ", "have", " ", "freedom"}], ",", " ", 
    RowBox[{
    "rbar", " ", "is", " ", "just", " ", "a", " ", "radial", " ", 
     "coordinate"}], ",", " ", 
    RowBox[{
    "its", " ", "zero", " ", "point", " ", "or", " ", "scale", " ", "is", " ",
      "not", " ", "fixed", " ", "physically"}], ",", "\n", 
    RowBox[{
    "so", " ", "we", " ", "can", " ", "choose", " ", "C_", "1", " ", "to", " ",
      "simplify", " ", "the", " ", "solution", " ", "or", " ", "to", " ", 
     "make", " ", "the", " ", "coordinates", " ", "nice", " ", "at", " ", 
     "infinity"}]}], "*)"}]}]}], "Code",
 CellChangeTimes->{{3.977229497758479*^9, 3.977229521781814*^9}, {
