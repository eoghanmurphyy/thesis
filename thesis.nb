Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Clear", " ", "all", " ", "variables", " ", "for", " ", "a", " ", "fresh", 
    " ", "start"}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"[", "]"}], " ", "==", " ", 
