}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sol", " ", "=", " ", 
    RowBox[{"DSolve", "[", "\n", "\t\t", 
     RowBox[{"eq", ",", " ", 
      RowBox[{"(*", 
       RowBox[{"Equation", " ", "to", " ", "work", " ", "with"}], "*)"}], 
      "\n", "\t\t", 
      RowBox[{"r", "[", "rbar", "]"}], ",", " ", 
      RowBox[{"(*", 
       RowBox[{"Function", " ", "to", " ", "solve", " ", "for"}], "*)"}], 
      "\n", "\t\t", "rbar"}], " ", 
     RowBox[{"(*", 
      RowBox[{"Independent", " ", "Variable"}], "*)"}], "\n", "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"expr", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"sol", ",", " ", 
     RowBox[{"Assumptions", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rbar", " ", ">", " ", "0"}], ",", " ", 
        RowBox[{"M", " ", ">", " ", "0"}]}], "}"}]}]}], "]"}]}], ";"}], "\n", 

 RowBox[{
  RowBox[{"FactorTerms", "[", 
   RowBox[{"expr", ",", " ", "rbar"}], "]"}], 
  RowBox[{"(*", 
   RowBox[{
   "Trying", " ", "to", " ", "factor", " ", "out", " ", "the", " ", "rbar", " ",
     "to", " ", "get", " ", "the", " ", "form", " ", "I", " ", "want"}], 
   "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Should", " ", "get", " ", 
     RowBox[{"r", "[", "rbar", "]"}]}], " ", "=", " ", 
    RowBox[{"rbar", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         RowBox[{"M", "/", "2"}], "rbar"}]}], ")"}], "^", "2"}]}]}], 
   "*)"}]}]}], "Code",
 CellChangeTimes->{{3.977228597821986*^9, 3.977228645204743*^9}, {
  3.977228927002612*^9, 3.977228968450399*^9}, {3.9772290100502853`*^9, 
